---
import AppLayout from "../../layouts/layout.astro";
import { sql } from "../../lib/db/client";
import { ensureGymSchema } from "../../lib/db/ensure-gym-schema";
import { getTeamEditHref, getTeamNewHref } from "../../lib/utils/team-routes";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import TeamMembersTable from "../../components/team/TeamMembersTable.astro";
import type { TeamMember } from "../../components/team/TeamMembersTable.astro";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "gym_manager") {
  return Astro.redirect("/admin/trainers");
}

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");

await ensureGymSchema();

const teamMembers = await sql`
  SELECT u.id, u.name, u.email, u.role, u.created_at, g.name AS gym_name
  FROM users u
  LEFT JOIN gyms g ON g.id = u.gym_id
  WHERE u.role = 'trainer'
    AND u.gym_id = ${user.gymId}
  ORDER BY u.created_at DESC, u.id DESC
`;
const members = teamMembers as unknown as TeamMember[];

const newMemberHref = getTeamNewHref(user.role);
---

<AppLayout title="Equipo del gimnasio">
  <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Mi gimnasio"
      title="Equipo del gimnasio"
      description="Administra solo los entrenadores asignados a tu gimnasio."
    >
      <a
        slot="actions"
        href={newMemberHref}
        class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto"
      >
        + Nuevo entrenador
      </a>
    </SectionHeader>

    {status && message && (
      <div class={`mb-6 rounded-xl border px-4 py-3 text-sm ${status === "success" ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300" : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"}`}>
        {message}
      </div>
    )}

    {members.length === 0 ? (
      <EmptyState
        title="Aún no hay entrenadores registrados"
        description="Crea el primer entrenador para comenzar a organizar el equipo del gimnasio."
        actionHref={newMemberHref}
        actionLabel="Crear entrenador"
      />
    ) : (
      <TeamMembersTable members={members} getEditHref={(id) => getTeamEditHref(user.role, id)} />
    )}
  </div>
</AppLayout>
