---
import AppLayout from "../layouts/layout.astro";
import AuthNav from "../components/ui/AuthNav.astro";

const user = Astro.locals.user;
if (user) {
  return Astro.redirect(String(user.role) === "gym_manager" ? "/gym-manager" : "/dashboard");
}

const status = Astro.url.searchParams.get("status");
const resetPath = Astro.url.searchParams.get("reset_path");
---

<AppLayout title="Recuperar contraseña | FitAssess Pro">
  <div class="mx-auto max-w-md px-4 py-8 sm:py-10">
    <AuthNav items={[{ href: "/login", label: "Iniciar sesión" }, { href: "/forgot-password", label: "Recuperar", active: true }]} />

    <div class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Recuperar contraseña</h1>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Te generamos un enlace temporal para cambiar tu contraseña.</p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-900/95 sm:p-8">
      {status === "sent" && (
        <div class="mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/30 dark:text-emerald-300">
          Si el correo existe, ya generamos un enlace de recuperación.
        </div>
      )}

      <form action="/api/auth/password-reset-request" method="POST" class="space-y-5">
        <div>
          <label for="email" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Correo electrónico</label>
          <input id="email" name="email" type="email" required autocomplete="email" class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-emerald-500 dark:focus:ring-emerald-900/40" placeholder="tu@correo.com" />
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-600">Generar enlace</button>
      </form>

      {resetPath && (
        <div class="mt-6 rounded-2xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 dark:border-slate-800 dark:bg-slate-950/60 dark:text-slate-300">
          <p class="font-semibold text-slate-900 dark:text-slate-100">Enlace temporal generado</p>
          <p class="mt-2">En un entorno real se enviaría por correo. Aquí puedes abrirlo directamente:</p>
          <a href={resetPath} class="mt-3 inline-flex rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">Abrir recuperación</a>
        </div>
      )}

      <p class="mt-4 text-center text-sm text-slate-500 dark:text-slate-400"><a href="/login" class="font-semibold text-emerald-600 hover:underline dark:text-emerald-400">Volver al login</a></p>
    </div>
  </div>
</AppLayout>
