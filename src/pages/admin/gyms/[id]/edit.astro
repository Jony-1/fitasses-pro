---
import AppLayout from "../../../../layouts/Layout.astro";
import { sql } from "../../../../lib/db/client";
import { getSessionUser } from "../../../../lib/auth/session-user";

const user = getSessionUser(Astro.locals.user);
const { id } = Astro.params;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/admin/gyms?status=error&message=Gimnasio%20inválido");
}

const gymRows = await sql`
    SELECT id, name, invite_code, created_at
    FROM gyms
    WHERE id = ${Number(id)}
    LIMIT 1
`;

const gym = gymRows[0];

if (!gym) {
    return new Response("Gimnasio no encontrado", { status: 404 });
}

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");

const trainerCountRows = await sql`
    SELECT COUNT(*)::int AS total
    FROM users
    WHERE gym_id = ${gym.id}
      AND role = 'trainer'
`;

const managerCountRows = await sql`
    SELECT COUNT(*)::int AS total
    FROM users
    WHERE gym_id = ${gym.id}
      AND role = 'gym_manager'
`;

const clientCountRows = await sql`
    SELECT COUNT(*)::int AS total
    FROM clients c
    INNER JOIN users u ON u.id = c.trainer_id
    WHERE u.gym_id = ${gym.id}
`;
---

<AppLayout title={`Editar gimnasio - ${gym.name}`}>
    <div class="mx-auto max-w-4xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a href="/admin/gyms" class="text-sm font-medium text-slate-500 hover:text-emerald-600">← Volver a gimnasios</a>
            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Editar gimnasio</h1>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Ajusta el nombre y revisa su uso interno.</p>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Código de invitación: <strong>{gym.invite_code ?? "sin código"}</strong></p>
        </div>

        {status && message && (
            <div class={`mb-6 rounded-xl border px-4 py-3 text-sm ${status === "success" ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300" : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"}`}>
                {message}
            </div>
        )}

        <div class="grid gap-6 lg:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800 lg:col-span-2">
                <form method="POST" action="/api/admin/gyms/update" class="space-y-5">
                    <input type="hidden" name="id" value={gym.id} />
                    <div>
                        <label for="name" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200">Nombre</label>
                        <input id="name" name="name" type="text" required value={gym.name} class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100" />
                    </div>
                    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto">Guardar cambios</button>
                        <a href="/admin/gyms" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">Cancelar</a>
                    </div>
                </form>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Resumen</h2>
                <div class="mt-4 space-y-3 text-sm text-slate-600 dark:text-slate-400">
                    <p>Entrenadores: <strong>{trainerCountRows[0]?.total ?? 0}</strong></p>
                    <p>Gestores: <strong>{managerCountRows[0]?.total ?? 0}</strong></p>
                    <p>Clientes: <strong>{clientCountRows[0]?.total ?? 0}</strong></p>
                </div>

                <form method="POST" action="/api/admin/gyms/delete" class="mt-6" onsubmit="return confirm('¿Eliminar este gimnasio? Solo se permitirá si no tiene trainers asignados.');">
                    <input type="hidden" name="id" value={gym.id} />
                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-red-300 bg-red-50 px-5 py-3 text-sm font-bold text-red-700 hover:bg-red-100 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300 dark:hover:bg-red-950/50">Eliminar gimnasio</button>
                </form>
            </div>
        </div>
    </div>
</AppLayout>
