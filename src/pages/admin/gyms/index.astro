---
import AppLayout from "../../../layouts/layout.astro";
import { sql } from "../../../lib/db/client";
import SectionHeader from "../../../components/ui/SectionHeader.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";

const user = Astro.locals.user as AppUser;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}

const gyms = await sql`
    SELECT
        g.id,
        g.name,
        g.invite_code,
        g.created_at,
        COUNT(DISTINCT u.id) FILTER (WHERE u.role = 'trainer')::int AS trainers_total,
        COUNT(DISTINCT u.id) FILTER (WHERE u.role = 'gym_manager')::int AS managers_total,
        COUNT(DISTINCT c.id)::int AS clients_total
    FROM gyms g
    LEFT JOIN users u ON u.gym_id = g.id
    LEFT JOIN clients c ON c.trainer_id = u.id
    GROUP BY g.id
    ORDER BY g.created_at DESC, g.id DESC
`;

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");
---

<AppLayout title="Gimnasios">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <SectionHeader
            eyebrow="Administración"
            title="Gimnasios"
            description="Gestiona los gimnasios y revisa cuántos entrenadores, gestores y clientes pertenecen a cada uno."
        >
            <a slot="actions" href="/admin/trainers/new" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto">
                + Nuevo integrante
            </a>
        </SectionHeader>

        {status && message && (
            <div class={`mb-6 rounded-xl border px-4 py-3 text-sm ${status === "success" ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300" : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"}`}>
                {message}
            </div>
        )}

        <div class="grid gap-6 lg:grid-cols-3">
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 lg:col-span-1">
                <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Crear gimnasio</h2>
                <form method="POST" action="/api/admin/gyms/create" class="mt-5 space-y-4">
                    <div>
                        <label for="name" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200">Nombre</label>
                        <input id="name" name="name" type="text" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100" placeholder="Ej. Central Fit" />
                    </div>
                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto">Crear gimnasio</button>
                </form>
            </div>

            <div class="lg:col-span-2">
        {gyms.length === 0 ? (
            <EmptyState title="No hay gimnasios aún" description="Crea el primero para comenzar a organizar entrenadores y gestores." />
        ) : (
            <div class="space-y-4">
                {gyms.map((gym) => (
                    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 dark:text-slate-100">{gym.name}</h3>
                                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Código: <strong>{gym.invite_code ?? "sin código"}</strong></p>
                                <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Entrenadores: <strong>{gym.trainers_total}</strong> · Gestores: <strong>{gym.managers_total}</strong> · Clientes: <strong>{gym.clients_total}</strong></p>
                            </div>
                            <div class="flex flex-wrap gap-3">
                                <a href={`/admin/gyms/${gym.id}/edit`} class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-700 sm:w-auto">Editar</a>
                                <a href={`/admin/trainers/new?gym_id=${gym.id}`} class="inline-flex w-full items-center justify-center rounded-xl border border-emerald-300 px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50 dark:border-emerald-800 dark:text-emerald-300 dark:hover:bg-emerald-950/30 sm:w-auto">Agregar integrante</a>
                            </div>
                        </div>
                    </article>
                ))}
                    </div>
                )}
            </div>
        </div>
    </div>
</AppLayout>
