---
import AppLayout from "../../../layouts/layout.astro";
import { sql } from "../../../lib/db/client";
import { ensureGymSchema } from "../../../lib/db/ensure-gym-schema";
import { formatDateOnly } from "../../../lib/utils/date";
import SectionHeader from "../../../components/ui/SectionHeader.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";

type PageUser = {
    id: number;
    name: string;
    email: string;
    role: "admin" | "gym_manager" | "trainer" | "client";
    gymId: number | null;
} | null;

const user = Astro.locals.user as PageUser;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin" && user.role !== "gym_manager") {
    return Astro.redirect("/dashboard?error=forbidden");
}

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");

await ensureGymSchema();

const trainers =
    user.role === "admin"
        ? await sql`
              SELECT u.id, u.name, u.email, u.role, u.created_at, g.name AS gym_name
              FROM users u
              LEFT JOIN gyms g ON g.id = u.gym_id
              WHERE u.role IN ('trainer', 'gym_manager')
              ORDER BY u.created_at DESC, u.id DESC
          `
        : await sql`
              SELECT u.id, u.name, u.email, u.role, u.created_at, g.name AS gym_name
              FROM users u
              LEFT JOIN gyms g ON g.id = u.gym_id
              WHERE u.role = 'trainer'
                AND u.gym_id = ${user.gymId}
              ORDER BY u.created_at DESC, u.id DESC
          `;
---

<AppLayout title="Gestión de trainers">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <SectionHeader
            eyebrow={user.role === "admin" ? "Administración" : "Mi gimnasio"}
            title="Gestión de trainers"
            description={
                user.role === "admin"
                    ? "Administra las cuentas de entrenadores registradas en la plataforma."
                    : "Administra solo los entrenadores asignados a tu gimnasio."
            }
        >
            <a
                slot="actions"
                href="/admin/trainers/new"
                class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto"
            >
                + Nuevo trainer
            </a>
        </SectionHeader>

        {
            status && message && (
                <div
                    class={`mb-6 rounded-xl border px-4 py-3 text-sm ${
                        status === "success"
                            ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300"
                            : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"
                    }`}
                >
                    {message}
                </div>
            )
        }

        {
            trainers.length === 0 ? (
                <EmptyState
                    title="Aún no hay trainers registrados"
                    description="Crea el primer entrenador para comenzar la gestión administrativa."
                    actionHref="/admin/trainers/new"
                    actionLabel="Crear trainer"
                />
            ) : (
                <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white/95 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
                            <thead class="bg-slate-50 dark:bg-slate-900/40">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Nombre
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Correo
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Rol
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Gimnasio
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Creado
                                    </th>
                                    <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                                        Acción
                                    </th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                {trainers.map((trainer) => (
                                    <tr>
                                        <td class="px-4 py-4 text-sm font-medium text-slate-900 dark:text-slate-100">
                                            {trainer.name}
                                        </td>
                                        <td class="px-4 py-4 text-sm text-slate-600 dark:text-slate-300">
                                            {trainer.email}
                                        </td>
                                        <td class="px-4 py-4">
                                            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                                                {trainer.role}
                                            </span>
                                        </td>
                                        <td class="px-4 py-4 text-sm text-slate-600 dark:text-slate-300">
                                            {trainer.gym_name ?? "-"}
                                        </td>
                                        <td class="px-4 py-4 text-sm text-slate-600 dark:text-slate-300">
                                            {formatDateOnly(trainer.created_at)}
                                        </td>
                                        <td class="px-4 py-4 text-right">
                                            <a
                                                href={`/admin/trainers/${trainer.id}/edit`}
                                                class="inline-flex items-center rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                                            >
                                                Editar
                                            </a>
                                        </td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>
            )
        }
    </div>
</AppLayout>
