---
import AppLayout from "../../../layouts/Layout.astro";
import { sql } from "../../../lib/db/client";
import { ensureGymSchema } from "../../../lib/db/ensure-gym-schema";
import SectionHeader from "../../../components/ui/SectionHeader.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";
import TeamMembersTable from "../../../components/team/TeamMembersTable.astro";
import type { TeamMember } from "../../../components/team/TeamMembersTable.astro";
import { getTeamEditHref, getTeamNewHref } from "../../../lib/utils/team-routes";

type PageUser = {
    id: number;
    name: string;
    email: string;
    role: "admin" | "gym_manager" | "trainer" | "client";
    gymId: number | null;
} | null;

const user = Astro.locals.user as PageUser;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role === "gym_manager") {
    const params = Astro.url.searchParams.toString();
    return Astro.redirect(`/gym/team${params ? `?${params}` : ""}`);
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");

await ensureGymSchema();

const trainers =
    user.role === "admin"
        ? await sql`
              SELECT u.id, u.name, u.email, u.role, u.created_at, g.name AS gym_name
              FROM users u
              LEFT JOIN gyms g ON g.id = u.gym_id
              WHERE u.role IN ('trainer', 'gym_manager')
              ORDER BY u.created_at DESC, u.id DESC
          `
        : await sql`
              SELECT u.id, u.name, u.email, u.role, u.created_at, g.name AS gym_name
              FROM users u
              LEFT JOIN gyms g ON g.id = u.gym_id
              WHERE u.role = 'trainer'
                AND u.gym_id = ${user.gymId}
              ORDER BY u.created_at DESC, u.id DESC
          `;
const teamMembers = trainers as unknown as TeamMember[];
---

<AppLayout title="Gestión del equipo">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <SectionHeader
            eyebrow={user.role === "admin" ? "Administración" : "Mi gimnasio"}
            title="Gestión del equipo"
            description={
                user.role === "admin"
                    ? "Administra las cuentas del equipo registradas en la plataforma."
                    : "Administra solo los entrenadores asignados a tu gimnasio."
            }
        >
            <a
                slot="actions"
                href={getTeamNewHref(user.role)}
                class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto"
            >
                + Nueva cuenta
            </a>
        </SectionHeader>

        {
            status && message && (
                <div
                    class={`mb-6 rounded-xl border px-4 py-3 text-sm ${
                        status === "success"
                            ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300"
                            : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"
                    }`}
                >
                    {message}
                </div>
            )
        }

        {
            teamMembers.length === 0 ? (
                <EmptyState
                    title="Aún no hay cuentas del equipo"
                    description="Crea la primera cuenta para comenzar la gestión administrativa."
                    actionHref={getTeamNewHref(user.role)}
                    actionLabel="Crear cuenta"
                />
            ) : (
                <TeamMembersTable members={teamMembers} getEditHref={(id) => getTeamEditHref(user.role, id)} />
            )
        }
    </div>
</AppLayout>
