---
import AppLayout from "../../../layouts/Layout.astro";
import { sql } from "../../../lib/db/client";
import { ensureGymSchema } from "../../../lib/db/ensure-gym-schema";
import { getSessionUser } from "../../../lib/auth/session-user";
import { getTeamListHref } from "../../../lib/utils/team-routes";

const user = getSessionUser(Astro.locals.user);

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (!["admin", "gym_manager"].includes(String(user.role))) {
    return Astro.redirect("/dashboard?error=forbidden");
}

await ensureGymSchema();

const gyms =
    user.role === "admin"
        ? await sql`
              SELECT id, name
              FROM gyms
              ORDER BY name ASC, id ASC
          `
        : [];

const selectedGymId = Astro.url.searchParams.get("gym_id") ?? String(user.gymId ?? "");

const roles = user.role === "admin"
    ? [
          { value: "trainer", label: "Entrenador" },
          { value: "gym_manager", label: "Gestor de gimnasio" },
      ]
    : [{ value: "trainer", label: "Entrenador" }];
---

<AppLayout title="Nueva cuenta del equipo">
    <div class="mx-auto max-w-3xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a
                href={getTeamListHref(user.role)}
                class="text-sm font-medium text-slate-500 hover:text-emerald-600"
            >
                ← Volver al equipo
            </a>

            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                Nueva cuenta del equipo
            </h1>

                <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                    {user.role === "admin"
                        ? "Crea una nueva cuenta de entrenador para cualquier gimnasio."
                        : "Crea una nueva cuenta de entrenador para tu gimnasio."}
                </p>
            </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 sm:p-8">
            <form method="POST" action="/api/admin/trainers/create" class="space-y-5">
                    {user.role === "admin" && (
                        <div>
                            <label for="role" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200">
                                Rol
                            </label>
                            <select id="role" name="role" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                {roles.map((item) => (
                                    <option value={item.value}>{item.label}</option>
                                ))}
                            </select>
                        </div>
                    )}

                    {user.role === "admin" ? (
                        <div>
                            <label
                                for="gym_id"
                                class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                            >
                                Gimnasio
                            </label>
                            <select
                                id="gym_id"
                                name="gym_id"
                                required
                                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                            >
                                <option value="">Selecciona un gimnasio</option>
                                {gyms.map((gym) => (
                                    <option value={gym.id} selected={selectedGymId === String(gym.id)}>{gym.name}</option>
                                ))}
                            </select>
                        </div>
                    ) : (
                        <input type="hidden" name="gym_id" value={user.gymId ?? ""} />
                    )}

                    <div>
                        <label
                            for="name"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Nombre completo
                    </label>
                    <input
                        id="name"
                        name="name"
                        type="text"
                        required
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="Ej. Laura Gómez"
                    />
                </div>

                <div>
                    <label
                        for="email"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Correo electrónico
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="trainer@fitassess.pro"
                    />
                </div>

                <div>
                    <label
                        for="password"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Contraseña temporal
                    </label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        required
                        minlength="4"
                        maxlength="72"
                        pattern="^(?=.*[A-Z])(?=.*\\d).{4,72}$"
                        title="Debe tener al menos 4 caracteres, una mayúscula y un número."
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="4 caracteres, mayúscula y número"
                    />
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                        Esta contraseña podrá cambiarse más adelante.
                    </p>
                </div>

                <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end">
                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto">
                        Crear cuenta
                    </button>

                    <a
                        href={getTeamListHref(user.role)}
                        class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto"
                    >
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</AppLayout>
