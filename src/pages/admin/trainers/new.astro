---
import AppLayout from "../../../layouts/layout.astro";

const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}
---

<AppLayout title="Nuevo trainer">
    <div class="mx-auto max-w-3xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a
                href="/admin/trainers"
                class="text-sm font-medium text-slate-500 hover:text-emerald-600"
            >
                ← Volver a trainers
            </a>

            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                Nuevo trainer
            </h1>

            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Crea una nueva cuenta de entrenador para la plataforma.
            </p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <form
                method="POST"
                action="/api/admin/trainers/create"
                class="space-y-5"
            >
                <div>
                    <label
                        for="name"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Nombre completo
                    </label>
                    <input
                        id="name"
                        name="name"
                        type="text"
                        required
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="Ej. Laura Gómez"
                    />
                </div>

                <div>
                    <label
                        for="email"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Correo electrónico
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="trainer@fitassess.pro"
                    />
                </div>

                <div>
                    <label
                        for="password"
                        class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                    >
                        Contraseña temporal
                    </label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        required
                        minlength="6"
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="Mínimo 6 caracteres"
                    />
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                        Esta contraseña podrá cambiarse más adelante.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3 pt-2">
                    <button
                        type="submit"
                        class="inline-flex items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600"
                    >
                        Crear trainer
                    </button>

                    <a
                        href="/admin/trainers"
                        class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                    >
                        Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</AppLayout>