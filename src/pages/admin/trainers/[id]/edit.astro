---
import AppLayout from "../../../../layouts/layout.astro";
import { sql } from "../../../../lib/db/client";
import { ensureGymSchema } from "../../../../lib/db/ensure-gym-schema";
import { getTeamListHref } from "../../../../lib/utils/team-routes";

const user = Astro.locals.user as {
    id: number;
    name: string;
    email: string;
    role: "admin" | "gym_manager" | "trainer" | "client";
    gymId: number | null;
} | null;
const { id } = Astro.params;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin" && user.role !== "gym_manager") {
    return Astro.redirect("/dashboard?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect(
        "/admin/trainers?status=error&message=Cuenta%20inválida",
    );
}

const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message");

const trainerRows =
    user.role === "admin"
        ? await sql`
              SELECT id, name, email, role, gym_id, created_at
              FROM users
              WHERE id = ${Number(id)}
                AND role IN ('trainer', 'gym_manager')
              LIMIT 1
          `
        : await sql`
              SELECT id, name, email, role, gym_id, created_at
              FROM users
              WHERE id = ${Number(id)}
                AND role = 'trainer'
                AND gym_id = ${user.gymId}
              LIMIT 1
`;

await ensureGymSchema();

const gyms =
    user.role === "admin"
        ? await sql`
              SELECT id, name
              FROM gyms
              ORDER BY name ASC, id ASC
          `
        : [];

const trainer = trainerRows[0] as {
    id: number;
    name: string;
    email: string;
    role: "trainer" | "gym_manager";
    gym_id: number | null;
};

if (!trainer) {
    return new Response("Cuenta no encontrada", { status: 404 });
}
---

<AppLayout title={`Editar cuenta - ${trainer.name}`}>
    <div class="mx-auto max-w-4xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
                <a href={getTeamListHref(user.role)} class="text-sm font-medium text-slate-500 hover:text-emerald-600">
                    ← Volver al equipo
                </a>

            <h1
                class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100"
            >
                Editar cuenta
            </h1>

            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                {user.role === "admin"
                    ? `Administra la cuenta de ${trainer.name}.`
                    : `Administra la cuenta de ${trainer.name} dentro de tu gimnasio.`}
            </p>
        </div>

        {
            status && message && (
                <div
                    class={`mb-6 rounded-xl border px-4 py-3 text-sm ${
                        status === "success"
                            ? "border-emerald-200 bg-emerald-50 text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300"
                            : "border-red-200 bg-red-50 text-red-700 dark:border-red-900/40 dark:bg-red-950/30 dark:text-red-300"
                    }`}
                >
                    {message}
                </div>
            )
        }

        <div class="grid grid-cols-1 gap-6">
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 sm:p-8">
                <h2
                    class="text-lg font-bold text-slate-900 dark:text-slate-100"
                >
                    Datos de la cuenta
                </h2>

                <form method="POST" action="/api/admin/trainers/update" class="mt-5 space-y-5">
                    <input type="hidden" name="id" value={trainer.id} />

                    {user.role === "admin" && (
                        <div>
                            <label for="role" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200">Rol</label>
                            <select id="role" name="role" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                <option value="trainer" selected={trainer.role === "trainer"}>Trainer</option>
                                <option value="gym_manager" selected={trainer.role === "gym_manager"}>Gym manager</option>
                            </select>
                        </div>
                    )}

                    {user.role === "admin" && (
                        <div>
                            <label for="gym_id" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200">Gimnasio</label>
                            <select id="gym_id" name="gym_id" required class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                {gyms.map((gym) => (
                                    <option value={gym.id} selected={String(trainer.gym_id ?? "") === String(gym.id)}>{gym.name}</option>
                                ))}
                            </select>
                        </div>
                    )}

                    <div>
                        <label
                            for="name"
                            class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                        >
                            Nombre completo
                        </label>
                        <input
                            id="name"
                            name="name"
                            type="text"
                            required
                            value={trainer.name}
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        />
                    </div>

                    <div>
                        <label
                            for="email"
                            class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                        >
                            Correo electrónico
                        </label>
                        <input
                            id="email"
                            name="email"
                            type="email"
                            required
                            value={trainer.email}
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        />
                    </div>

                    <div class="flex flex-wrap gap-3 pt-2">
                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white hover:bg-emerald-600 sm:w-auto">
                        Guardar cambios
                    </button>

                        <a
                            href={getTeamListHref(user.role)}
                        class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto"
                    >
                        Cancelar
                    </a>
                    </div>
                </form>
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 sm:p-8">
                <h2
                    class="text-lg font-bold text-slate-900 dark:text-slate-100"
                >
                    Restablecer contraseña
                </h2>

                <form
                    method="POST"
                    action="/api/admin/trainers/reset-password"
                    class="mt-5 space-y-5"
                >
                    <input type="hidden" name="id" value={trainer.id} />

                    <div>
                        <label
                            for="password"
                            class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-200"
                        >
                            Nueva contraseña temporal
                        </label>
                        <input
                            id="password"
                            name="password"
                            type="password"
                        required
                        minlength="4"
                        maxlength="72"
                        pattern="^(?=.*[A-Z])(?=.*\\d).{4,72}$"
                        title="Debe tener al menos 4 caracteres, una mayúscula y un número."
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none ring-0 placeholder:text-slate-400 focus:border-emerald-500 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
                        placeholder="4 caracteres, mayúscula y número"
                        />
                    </div>

                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-amber-300 bg-amber-50 px-5 py-3 text-sm font-bold text-amber-700 hover:bg-amber-100 dark:border-amber-900/40 dark:bg-amber-950/30 dark:text-amber-300 dark:hover:bg-amber-950/50 sm:w-auto">
                        Restablecer contraseña
                    </button>
                </form>
            </div>
        </div>
    </div>
</AppLayout>
