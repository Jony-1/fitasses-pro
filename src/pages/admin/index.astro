---
import AppLayout from "../../layouts/layout.astro";
import { sql } from "../../lib/db/client";

const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}

const trainerCountRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM users
  WHERE role = 'trainer'
`;

const clientCountRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM users
  WHERE role = 'client'
`;

const clientsRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM clients
`;

const trainersTotal = trainerCountRows[0]?.total ?? 0;
const clientUsersTotal = clientCountRows[0]?.total ?? 0;
const clientsTotal = clientsRows[0]?.total ?? 0;
---

<AppLayout title="Administración">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-8">
            <p class="text-sm font-medium text-emerald-600">Panel administrativo</p>
            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                Administración
            </h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                Desde aquí podrás gestionar trainers y revisar información general del sistema.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
                    Trainers registrados
                </p>
                <p class="mt-3 text-3xl font-bold text-slate-900 dark:text-slate-100">
                    {trainersTotal}
                </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
                    Usuarios cliente
                </p>
                <p class="mt-3 text-3xl font-bold text-slate-900 dark:text-slate-100">
                    {clientUsersTotal}
                </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
                    Clientes creados
                </p>
                <p class="mt-3 text-3xl font-bold text-slate-900 dark:text-slate-100">
                    {clientsTotal}
                </p>
            </div>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
            <a
                href="/admin/trainers"
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-emerald-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-emerald-700"
            >
                <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
                    Gestionar trainers
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                    Ver, crear y administrar cuentas de entrenadores.
                </p>
            </a>

            <a
                href="/dashboard"
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-slate-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-slate-600"
            >
                <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">
                    Volver al dashboard
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                    Regresar al flujo principal de la aplicación.
                </p>
            </a>
        </div>
    </div>
</AppLayout>