---
import AppLayout from "../../layouts/layout.astro";
import { sql } from "../../lib/db/client";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import StatCard from "../../components/ui/StatCard.astro";
import ActionCard from "../../components/ui/ActionCard.astro";

const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

if (user.role !== "admin") {
    return Astro.redirect("/dashboard?error=forbidden");
}

const trainerCountRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM users
  WHERE role = 'trainer'
`;

const clientCountRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM users
  WHERE role = 'client'
`;

const clientsRows = await sql`
  SELECT COUNT(*)::int AS total
  FROM clients
`;

const trainersTotal = trainerCountRows[0]?.total ?? 0;
const clientUsersTotal = clientCountRows[0]?.total ?? 0;
const clientsTotal = clientsRows[0]?.total ?? 0;
---

<AppLayout title="Administración">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <SectionHeader
            eyebrow="Panel administrativo"
            title="Administración"
            description="Desde aquí podrás gestionar trainers y revisar información general del sistema."
        />

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
            <StatCard label="Trainers registrados" value={trainersTotal} />
            <StatCard label="Usuarios cliente" value={clientUsersTotal} />
            <StatCard label="Clientes creados" value={clientsTotal} />
        </div>

        <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
            <ActionCard
                href="/admin/trainers"
                title="Gestionar trainers"
                description="Ver, crear y administrar cuentas de entrenadores."
            />

            <ActionCard
                href="/admin/gyms"
                title="Gestionar gimnasios"
                description="Crear gimnasios y revisar su estructura interna."
            />

            <ActionCard
                href="/admin/trainers/new"
                title="Crear cuenta"
                description="Crear trainers o gym managers y asignarlos a un gimnasio."
            />

            <ActionCard
                href="/dashboard"
                title="Volver al dashboard"
                description="Regresar al flujo principal de la aplicación."
            />
        </div>
    </div>
</AppLayout>
