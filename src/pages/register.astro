---
import AppLayout from "../layouts/layout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import ActionCard from "../components/ui/ActionCard.astro";
import AuthNav from "../components/ui/AuthNav.astro";
---

<AppLayout title="Registro">
    <div class="mx-auto max-w-4xl px-4 py-8 sm:py-12">
        <AuthNav
            items={[
                { href: "/login", label: "Iniciar sesión" },
                { href: "/register", label: "Registro", active: true },
            ]}
        />

        <SectionHeader
            title="Crear cuenta"
            description="Elige el tipo de cuenta con el que deseas registrarte: cliente, entrenador o gestor de gimnasio."
        />

        <div class="mt-10 grid gap-6 md:grid-cols-3">
            <ActionCard
                href="/clients/register/client"
                title="Cliente"
                description="Consulta tu progreso, valoraciones e historial personal."
            />

            <ActionCard
                href="/clients/register/trainer"
                title="Entrenador"
                description="Administra clientes, valoraciones y seguimiento de tus atletas."
            />

            <ActionCard
                href="/clients/register/gym-manager"
                title="Gestor de gimnasio"
                description="Accede con el código de tu gimnasio para gestionar tu equipo."
            />
        </div>

        <p class="mt-8 text-center text-sm text-slate-600 dark:text-slate-400">
            ¿Ya tienes cuenta?
            <a
                href="/login"
                class="font-semibold text-emerald-600 hover:text-emerald-500 hover:underline dark:text-emerald-400 dark:hover:text-emerald-300"
            >
                Inicia sesión
            </a>
        </p>
    </div>
</AppLayout>
