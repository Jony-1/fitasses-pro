---
import AppLayout from "../layouts/layout.astro";
---

<AppLayout title="Registro">
    <div class="mx-auto max-w-4xl px-4 py-12">
        <div class="text-center">
            <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">
                Crear cuenta
            </h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">
                Elige el tipo de cuenta con el que deseas registrarte.
            </p>
        </div>

        <div class="mt-10 grid gap-6 md:grid-cols-2">
            <a
                href="/clients/register/client"
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-emerald-400 hover:shadow-lg dark:border-slate-700 dark:bg-slate-900"
            >
                <h2
                    class="text-xl font-bold text-slate-900 dark:text-slate-100"
                >
                    Cliente
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                    Consulta tu progreso, valoraciones e historial.
                </p>
            </a>

            <a
                href="/clients/register/trainer"
                class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-emerald-400 hover:shadow-lg dark:border-slate-700 dark:bg-slate-900"
            >
                <h2
                    class="text-xl font-bold text-slate-900 dark:text-slate-100"
                >
                    Trainer
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                    Administra clientes, valoraciones y seguimiento.
                </p>
            </a>
        </div>

        <p class="mt-8 text-center text-sm text-slate-600 dark:text-slate-400">
            ¿Ya tienes cuenta?
            <a
                href="/login"
                class="font-semibold text-emerald-600 hover:text-emerald-500 hover:underline dark:text-emerald-400 dark:hover:text-emerald-300"
            >
                Inicia sesión
            </a>
        </p>
    </div>
</AppLayout>
