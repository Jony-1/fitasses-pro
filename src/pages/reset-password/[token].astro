---
import AppLayout from "../../layouts/layout.astro";
import AuthNav from "../../components/ui/AuthNav.astro";

const token = Astro.params.token;

if (!token) {
  return Astro.redirect("/forgot-password");
}

const error = Astro.url.searchParams.get("error");
const message = error === "invalid_token"
  ? "El enlace no es válido o ya expiró."
  : error === "missing_fields"
    ? "Debes completar ambos campos."
    : error === "weak_password"
      ? "La contraseña debe tener al menos 8 caracteres, una mayúscula y un número."
      : error === "password_mismatch"
        ? "Las contraseñas no coinciden."
        : null;
---

<AppLayout title="Nueva contraseña | FitAssess Pro">
  <div class="mx-auto max-w-md px-4 py-8 sm:py-10">
    <AuthNav items={[{ href: "/login", label: "Iniciar sesión" }, { href: "/forgot-password", label: "Recuperar contraseña" }]} />

    <div class="mb-6 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Nueva contraseña</h1>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Escribe una contraseña nueva para tu cuenta.</p>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-900/95 sm:p-8">
      {message && (
        <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900 dark:bg-red-950/30 dark:text-red-300">{message}</div>
      )}

      <form action="/api/auth/password-reset" method="POST" class="space-y-5">
        <input type="hidden" name="token" value={token} />

        <div>
          <label for="password" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Nueva contraseña</label>
          <input id="password" name="password" type="password" required minlength="8" maxlength="72" autocomplete="new-password" pattern="^(?=.*[A-Z])(?=.*\d).{8,72}$" class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-emerald-500 dark:focus:ring-emerald-900/40" />
        </div>

        <div>
          <label for="confirm_password" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">Confirmar contraseña</label>
          <input id="confirm_password" name="confirm_password" type="password" required minlength="8" maxlength="72" autocomplete="new-password" class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-emerald-500 dark:focus:ring-emerald-900/40" />
        </div>

        <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-600">Guardar contraseña</button>
      </form>
    </div>
  </div>
</AppLayout>
