---
import AppLayout from "../../layouts/layout.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import { ensureRoutineSchema, getRoutineListForUser } from "../../lib/utils/routines";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

if (user.role !== "trainer" && user.role !== "admin" && user.role !== "gym_manager") {
  return Astro.redirect("/login?error=forbidden");
}

await ensureRoutineSchema();
const routines = await getRoutineListForUser(user);
---

<AppLayout title="Rutinas">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="MVP de rutinas"
      title="Rutinas"
      description="Crea plantillas por días y asignalas a cada cliente como una rutina personalizada."
    >
      <a slot="actions" href="/routines/new" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-900 hover:bg-emerald-300 sm:w-auto">
        + Nueva rutina
      </a>
    </SectionHeader>

    {routines.length === 0 ? (
      <EmptyState
        title="Aún no hay rutinas"
        description="Crea una plantilla por días y luego asígnala a un cliente."
        actionHref="/routines/new"
        actionLabel="Crear rutina"
      />
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {routines.map((routine) => (
          <a
            href={`/routines/${routine.id}`}
            class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-md dark:border-slate-800 dark:bg-slate-900"
          >
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                  {routine.is_template ? "Plantilla" : "Asignada"}
                </p>
                <h2 class="mt-2 text-xl font-bold text-slate-900 dark:text-slate-100">
                  {routine.name}
                </h2>
              </div>

              <span class:list={[
                "rounded-full px-3 py-1 text-xs font-semibold",
                routine.active
                  ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"
                  : "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300",
              ]}>
                {routine.active ? "Activa" : "Pausada"}
              </span>
            </div>

            <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
              {routine.objective ?? "Sin objetivo definido"}
            </p>

            <div class="mt-5 grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
              <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/60">
                <p class="text-xs uppercase tracking-wide text-slate-400">Días</p>
                <p class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{routine.days_total}</p>
              </div>

              <div class="rounded-2xl bg-slate-50 p-3 dark:bg-slate-800/60">
                <p class="text-xs uppercase tracking-wide text-slate-400">Ejercicios</p>
                <p class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{routine.exercises_total}</p>
              </div>
            </div>

            <div class="mt-4 flex flex-col gap-2 text-sm text-slate-500 dark:text-slate-400 sm:flex-row sm:items-center sm:justify-between">
              <span>{routine.level ?? "Nivel libre"}</span>
              <span>{routine.is_template ? `${routine.assigned_clients_total} clientes` : routine.client_name ?? "Sin asignar"}</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</AppLayout>
