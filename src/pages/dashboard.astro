---
import AppLayout from "../layouts/Layout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import DashboardOverview from "../components/dashboard/DashboardOverview.astro";
import { getDashboardData } from "../lib/utils/dashboard";
import { sql } from "../lib/db/client";
import { getSessionUser } from "../lib/auth/session-user";
import { getTeamListHref, getTeamNewHref } from "../lib/utils/team-routes";

const user = getSessionUser(Astro.locals.user);

if (!user) {
  return Astro.redirect("/login");
}

const linkedClientRows = user.role === "client"
  ? await sql`
      SELECT id
      FROM clients
      WHERE user_id = ${user.id}
      LIMIT 1
    `
  : [];

const linkedClientId = linkedClientRows[0]?.id as number | undefined;

if (user.role === "gym_manager") {
  return Astro.redirect("/gym-manager");
}

if (user.role === "client") {
  if (linkedClientId) {
    return Astro.redirect(`/clients/${linkedClientId}/routine`);
  }

  return Astro.redirect("/client-home");
}

if (!['admin', 'gym_manager', 'trainer', 'client'].includes(user.role)) {
  return Astro.redirect("/login?error=forbidden");
}

const dashboardUser: any = {
  id: user.id,
  name: user.name,
  role: user.role,
  gymId: user.gymId,
};

const dashboard: any = await getDashboardData(dashboardUser);

const isAdmin = dashboard.role === "admin";
const isGymManager = String(dashboard.role) === "gym_manager";
const dashboardIntro = isAdmin
  ? "Monitorea crecimiento, carga operativa y accesos de gestión desde un solo lugar."
  : "Revisa clientes que requieren seguimiento, últimas valoraciones y atajos para avanzar rápido.";
const topPriority = dashboard.stats.clientsWithoutRecentAssessment;
const thisMonthAssessments = dashboard.stats.assessmentsThisMonth;
const recentClients = dashboard.recentClients.length;
---

<AppLayout title="FitAssess Pro | Panel principal">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
        eyebrow={
          isAdmin
            ? "Panel administrativo"
          : isGymManager
            ? `Gimnasio: ${dashboard.gymName ?? "sin nombre"}`
            : "Panel del entrenador"
        }
      title={`Hola, ${user.name}`}
      description={
        isAdmin
          ? "Resumen general del sistema, métricas operativas y atajos de administración."
        : isGymManager
            ? "Resumen del gimnasio, sus entrenadores y la actividad reciente de su red."
            : "Métricas clave, seguimiento reciente y acciones rápidas para la gestión diaria."
      }
    >
      {!isGymManager && (
        <>
          <a
            slot="actions"
            href="/clients"
            class="inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200 sm:w-auto"
          >
            Ir a clientes
          </a>

          <a
            slot="actions"
            href="/clients/new"
            class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto"
          >
            Nuevo cliente
          </a>
        </>
      )}

      {isGymManager && (
        <a
          slot="actions"
          href={getTeamNewHref(user.role)}
          class="inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200 sm:w-auto"
        >
          Nuevo entrenador
        </a>
      )}

      {isAdmin && (
        <a
          slot="actions"
          href={getTeamListHref(user.role)}
          class="inline-flex w-full items-center justify-center rounded-xl border border-emerald-300 px-4 py-2.5 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50 dark:border-emerald-800 dark:text-emerald-300 dark:hover:bg-emerald-950/30 sm:w-auto"
        >
          Gestionar entrenadores
        </a>
      )}

      {isGymManager && (
        <a
          slot="actions"
          href="/admin/trainers"
          class="inline-flex w-full items-center justify-center rounded-xl border border-emerald-300 px-4 py-2.5 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50 dark:border-emerald-800 dark:text-emerald-300 dark:hover:bg-emerald-950/30 sm:w-auto"
        >
          Mis entrenadores
        </a>
      )}
    </SectionHeader>

    <div class="mt-6 grid gap-4 xl:grid-cols-[1.15fr_0.85fr]">
      <section class="rounded-3xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm dark:border-emerald-900/40 dark:bg-emerald-950/20">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-300">Guía rápida para iniciar</p>
        <h2 class="mt-2 text-xl font-bold text-emerald-950 dark:text-emerald-100">Empieza aquí para mostrar valor en menos de un minuto</h2>
        <p class="mt-2 text-sm text-emerald-800 dark:text-emerald-200">{dashboardIntro}</p>
        <p class="mt-3 text-sm text-emerald-800 dark:text-emerald-200">Ruta sugerida: abre clientes, entra a una rutina, registra una sesión y vuelve a progreso para enseñar el resultado.</p>
      </section>

      <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Prioridades de hoy</p>
        <div class="mt-4 grid gap-3 sm:grid-cols-3 xl:grid-cols-1">
          <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/40">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Sin seguimiento</p>
            <p class="mt-1 text-2xl font-black text-slate-900 dark:text-slate-100">{topPriority}</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/40">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Valoraciones del mes</p>
            <p class="mt-1 text-2xl font-black text-slate-900 dark:text-slate-100">{thisMonthAssessments}</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/40">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Clientes recientes</p>
            <p class="mt-1 text-2xl font-black text-slate-900 dark:text-slate-100">{recentClients}</p>
          </div>
        </div>
      </section>
    </div>

    <div class="mt-6">
      <DashboardOverview dashboard={dashboard} showAlerts showTrends />
    </div>
    </div>
</AppLayout>
