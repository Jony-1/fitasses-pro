---
import AppLayout from "../layouts/layout.astro";

const title = "FitAssess Pro | Dashboard";

const quickLinks = [
    {
        title: "Clientes",
        description: "Consulta, crea y administra clientes registrados.",
        href: "/clients",
        icon: "👥",
    },
    {
        title: "Valoraciones",
        description: "Registra y revisa valoraciones físicas y medidas.",
        href: "/assessments",
        icon: "📋",
    },
    {
        title: "Progreso",
        description: "Visualiza avances, evolución y seguimiento.",
        href: "/progress",
        icon: "📈",
    },
    {
        title: "Configuración",
        description: "Ajusta opciones generales de la aplicación.",
        href: "/settings",
        icon: "⚙️",
    },
];
---

<AppLayout title={title}>
    <section class="space-y-6">
        <div
            class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
        >
            <div
                class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between"
            >
                <div>
                    <span
                        class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-500/10 dark:text-amber-300"
                    >
                        En construcción
                    </span>

                    <h1
                        class="mt-3 text-3xl font-black tracking-tight text-slate-900 dark:text-white md:text-4xl"
                    >
                        Dashboard en desarrollo
                    </h1>

                    <p
                        class="mt-3 max-w-2xl text-sm text-slate-600 dark:text-slate-300 md:text-base"
                    >
                        Estamos trabajando en este panel para mostrar métricas,
                        actividad reciente, accesos rápidos y un resumen general
                        de FitAssess Pro.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <a
                        href="/clients"
                        class="inline-flex items-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
                    >
                        Ir a clientes
                    </a>

                    <a
                        href="/assessments"
                        class="inline-flex items-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                    >
                        Ir a valoraciones
                    </a>
                </div>
            </div>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
            <article
                class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900"
            >
                <div class="text-2xl">🚧</div>
                <h2
                    class="mt-3 text-lg font-bold text-slate-900 dark:text-white"
                >
                    Módulo en construcción
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                    Esta vista todavía está siendo organizada para que quede
                    útil y limpia.
                </p>
            </article>

            <article
                class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900"
            >
                <div class="text-2xl">🧭</div>
                <h2
                    class="mt-3 text-lg font-bold text-slate-900 dark:text-white"
                >
                    Navegación disponible
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                    Ya puedes moverte a otros módulos sin depender del botón
                    atrás del navegador.
                </p>
            </article>

            <article
                class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900"
            >
                <div class="text-2xl">✨</div>
                <h2
                    class="mt-3 text-lg font-bold text-slate-900 dark:text-white"
                >
                    Próximas mejoras
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
                    Luego aquí podemos poner tarjetas, indicadores, accesos
                    rápidos y actividad reciente.
                </p>
            </article>
        </div>

        <section
            class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
        >
            <div class="mb-5">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">
                    Accesos rápidos
                </h2>
                <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                    Mientras terminamos el dashboard, puedes entrar directo a
                    estas secciones.
                </p>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                {
                    quickLinks.map((item) => (
                        <a
                            href={item.href}
                            class="group rounded-2xl border border-slate-200 bg-slate-50 p-4 transition hover:-translate-y-0.5 hover:border-slate-300 hover:bg-slate-100 dark:border-slate-800 dark:bg-slate-950 dark:hover:border-slate-700 dark:hover:bg-slate-800"
                        >
                            <div class="text-2xl">{item.icon}</div>
                            <h3 class="mt-3 font-semibold text-slate-900 dark:text-white">
                                {item.title}
                            </h3>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                                {item.description}
                            </p>
                        </a>
                    ))
                }
            </div>
        </section>
    </section>
</AppLayout>
