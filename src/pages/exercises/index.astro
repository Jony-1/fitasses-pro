---
import AppLayout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import ExercisePlaceholder from "../../components/exercises/ExercisePlaceholder.astro";
import {
  ensureExerciseSchema,
  getExerciseCatalog,
  getExerciseReferenceImage,
} from "../../lib/utils/exercise-library";
import { getClientByUserId } from "../../lib/utils/client-profile";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

const ownerClient = user.role === "client" ? await getClientByUserId(user.id) : null;
const ownerTrainerId = user.role === "trainer" ? user.id : ownerClient?.trainer_id ?? null;
const canEditExercise = user.role !== "client";
const canSyncExerciseCatalog = user.role === "trainer" || user.role === "admin" || user.role === "gym_manager";
const normalize = (value: string) => value.trim().toLowerCase();
const search = normalize(Astro.url.searchParams.get("q") ?? "");
const category = Astro.url.searchParams.get("category") ?? "Todos";
const muscle = Astro.url.searchParams.get("muscle") ?? "Todos";
const equipment = Astro.url.searchParams.get("equipment") ?? "Todos";
const pageSize = 24;
const currentPage = Math.max(1, Number(Astro.url.searchParams.get("page") ?? "1") || 1);
const buildPageHref = (page: number) => {
  const params = new URLSearchParams(Astro.url.searchParams);
  params.set("page", String(page));
  return `/exercises?${params.toString()}`;
};

await ensureExerciseSchema();

type ExerciseCardData = {
  id?: number;
  key: string;
  name: string;
  category: string;
  muscle: string;
  equipment: string;
  image: string;
  imageUrl?: string | null;
  accent: string;
  glyph: string;
  source?: "static" | "base" | "trainer";
};

const exerciseCatalog = (await getExerciseCatalog(ownerTrainerId)) as ExerciseCardData[];
const filteredExercises = exerciseCatalog.filter((exercise) => {
  const matchesSearch = !search || `${exercise.name} ${exercise.category} ${exercise.muscle} ${exercise.equipment}`.toLowerCase().includes(search);
  const matchesCategory = category === "Todos" || exercise.category === category;
  const matchesMuscle = muscle === "Todos" || exercise.muscle === muscle;
  const matchesEquipment = equipment === "Todos" || exercise.equipment === equipment;

  return matchesSearch && matchesCategory && matchesMuscle && matchesEquipment;
});
const totalExercises = filteredExercises.length;
const totalPages = Math.max(1, Math.ceil(totalExercises / pageSize));
const pageIndex = Math.min(currentPage, totalPages);
const startIndex = (pageIndex - 1) * pageSize;
const visibleExercises = filteredExercises.slice(startIndex, startIndex + pageSize);
const displayStart = totalExercises === 0 ? 0 : startIndex + 1;
const displayEnd = totalExercises === 0 ? 0 : Math.min(startIndex + pageSize, totalExercises);
const visibleExercisesWithImages = await Promise.all(
  visibleExercises.map(async (exercise) => ({
    ...exercise,
    displayImageUrl: exercise.imageUrl ?? (await getExerciseReferenceImage(exercise)) ?? null,
  })),
);
const categories = ["Todos", ...new Set(exerciseCatalog.map((exercise) => exercise.category))];
const muscles = ["Todos", ...new Set(exerciseCatalog.map((exercise) => exercise.muscle))];
const equipments = ["Todos", ...new Set(exerciseCatalog.map((exercise) => exercise.equipment))];
const sourceFilters = ["Todos", "Base", "Personalizados"];
const categoryCount = exerciseCatalog.reduce<Record<string, number>>((acc, exercise) => {
  acc[exercise.category] = (acc[exercise.category] ?? 0) + 1;
  return acc;
}, {});
const sourceCount = exerciseCatalog.reduce<Record<string, number>>((acc, exercise) => {
  const source = exercise.source === "trainer" ? "Personalizados" : "Base";
  acc[source] = (acc[source] ?? 0) + 1;
  return acc;
}, {});
---

<AppLayout title="Biblioteca de ejercicios">
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Catálogo visual"
      title="Biblioteca de ejercicios"
      description="Crea, edita y usa ejercicios en un solo lugar."
    >
      {canEditExercise && (
        <button
          slot="actions"
          type="button"
          data-open-modal="create"
          class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 hover:bg-emerald-300 sm:w-auto"
        >
          + Nuevo ejercicio
        </button>
      )}

      {canSyncExerciseCatalog && (
        <form slot="actions" method="POST" action="/api/exercises/sync">
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">
            Sincronizar catálogo
          </button>
        </form>
      )}
    </SectionHeader>

    <form method="GET" class="space-y-4">
      <input type="hidden" name="page" value="1" />

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {categories.map((item) => {
          const count = item === "Todos" ? exerciseCatalog.length : categoryCount[item] ?? 0;

          return (
            <button
              type="submit"
              name="category"
              value={item}
              class:list={[
                "rounded-3xl border p-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg",
                item === category
                  ? "border-slate-900 bg-slate-900 text-white"
                  : "border-slate-200 bg-white text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-100",
              ]}
            >
              <p class="text-xs font-semibold uppercase tracking-[0.2em] opacity-70">{item}</p>
              <p class="mt-2 text-2xl font-bold">{count}</p>
              <p class="mt-1 text-sm opacity-80">Ejercicios</p>
            </button>
          );
        })}
      </div>

      <div class="mt-6 grid gap-3 lg:grid-cols-[1fr_auto]">
        <label class="block space-y-2">
          <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Buscar ejercicio</span>
          <input
            type="search"
            name="q"
            value={Astro.url.searchParams.get("q") ?? ""}
            placeholder="Sentadilla, press, core..."
            class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm outline-none transition placeholder:text-slate-400 focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10"
          />
        </label>

        <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400">
          El botón <span class="font-semibold text-slate-900 dark:text-slate-100">Usar en rutina</span> abre el creador con ese ejercicio.
        </div>
      </div>

      <div class="mt-8 rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-950/40">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Filtros avanzados</p>
            <h3 class="mt-1 text-base font-bold text-slate-900 dark:text-slate-100">Refina la lista</h3>
          </div>

          <div class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-500 shadow-sm dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400">
            Vista rápida: abre detalles
          </div>
        </div>

        <div class="mt-4 grid gap-3 lg:grid-cols-2">
          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Filtrar por músculo</span>
            <select name="muscle" value={muscle} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10">
              {muscles.map((item) => <option value={item}>{item}</option>)}
            </select>
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Filtrar por equipo</span>
            <select name="equipment" value={equipment} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10">
              {equipments.map((item) => <option value={item}>{item}</option>)}
            </select>
          </label>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
          <button type="submit" class="rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 hover:bg-emerald-300">
            Aplicar filtros
          </button>
          <a href="/exercises" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
            Limpiar
          </a>
        </div>
      </div>
    </form>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {visibleExercisesWithImages.map((exercise) => (
        <article
          data-exercise-card
          data-category={exercise.category}
          data-name={exercise.name}
          data-source={exercise.source === "trainer" ? "Personalizados" : "Base"}
          class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_16px_50px_rgba(15,23,42,0.10)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_24px_70px_rgba(15,23,42,0.16)] dark:border-slate-800 dark:bg-slate-950"
        >
          <div class="relative">
            <div class="h-2 w-full" style={`background:${exercise.accent}`}></div>
          <div class="relative h-44 overflow-hidden bg-slate-950">
              {exercise.displayImageUrl ? (
                <img src={exercise.displayImageUrl} alt={exercise.name} class="h-full w-full object-cover" loading="lazy" decoding="async" />
              ) : (
                <ExercisePlaceholder accent={exercise.accent} glyph={exercise.glyph} title={exercise.name} />
              )}
              <div class="absolute inset-x-3 bottom-3 rounded-2xl border border-white/10 bg-slate-950/50 p-3 text-white backdrop-blur-md">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/70">{exercise.category}</p>
                    <h3 class="mt-1 text-lg font-bold leading-tight text-white">{exercise.name}</h3>
                  </div>

                  <span class="rounded-full bg-white/15 px-3 py-1 text-[11px] font-semibold text-white">
                    {exercise.source === "trainer" ? "Custom" : "Base"}
                  </span>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-slate-950 px-4 py-4 text-white">
            <div class="flex flex-wrap gap-2 text-[11px] font-semibold">
              <span class="rounded-full bg-white/10 px-2.5 py-1 text-white/85">{exercise.category}</span>
              <span class="rounded-full bg-white/10 px-2.5 py-1 text-white/85">{exercise.muscle}</span>
              <span class="rounded-full bg-white/10 px-2.5 py-1 text-white/85">{exercise.equipment}</span>
            </div>

            <p class="mt-3 text-sm text-white/70">
              {exercise.source === "trainer" ? "Personalizado" : "Biblioteca base"}
            </p>

            <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
              {canEditExercise && (
                <a href={`/routines/new?exercise=${exercise.key}`} class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-950 hover:bg-emerald-300 sm:w-auto">
                  Usar en rutina
                </a>
              )}

              <a href={`/exercises/${exercise.key}${ownerTrainerId ? `?trainer_id=${ownerTrainerId}` : ""}`} class="inline-flex w-full items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white hover:bg-white/10 sm:w-auto">
                Detalles
              </a>

              {exercise.source === "trainer" ? (
                <button
                  type="button"
                  data-open-modal="edit"
                  data-exercise-id={exercise.id ?? ""}
                  data-exercise-key={exercise.key}
                  data-exercise-name={exercise.name}
                  data-exercise-category={exercise.category}
                  data-exercise-muscle={exercise.muscle}
                  data-exercise-equipment={exercise.equipment}
                  data-exercise-accent={exercise.accent}
                  data-exercise-glyph={exercise.glyph}
                  data-exercise-image-url={exercise.displayImageUrl ?? ""}
                  data-exercise-video-url={exercise.videoUrl ?? ""}
                  class="inline-flex w-full items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white hover:bg-white/10 sm:w-auto"
                >
                  Editar
                </button>
              ) : (
                <button
                  type="button"
                  data-open-modal="create"
                  class="inline-flex w-full items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white hover:bg-white/10 sm:w-auto"
                >
                  Crear ejercicio
                </button>
              )}

              {exercise.source === "trainer" && exercise.id && (
                <form method="POST" action="/api/exercises/delete" onsubmit="return confirm('Eliminar este ejercicio?');">
                  <input type="hidden" name="id" value={exercise.id} />
                  <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-red-400/40 bg-red-500/10 px-4 py-2.5 text-sm font-semibold text-red-200 hover:bg-red-500/20 sm:w-auto">
                    Eliminar
                  </button>
                </form>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-4 rounded-3xl border border-slate-200 bg-white px-4 py-4 shadow-sm dark:border-slate-800 dark:bg-slate-950/80 md:flex-row">
      <p class="text-sm text-slate-600 dark:text-slate-400">
        Mostrando {displayStart}-{displayEnd} de {totalExercises}
      </p>

      <div class="flex items-center gap-2">
        <a
          href={buildPageHref(Math.max(1, pageIndex - 1))}
          class:list={[
            "rounded-xl border px-4 py-2.5 text-sm font-semibold",
            pageIndex === 1
              ? "pointer-events-none border-slate-200 text-slate-400 dark:border-slate-800 dark:text-slate-600"
              : "border-slate-300 text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800",
          ]}
        >
          Anterior
        </a>

        <span class="rounded-xl bg-slate-100 px-4 py-2.5 text-sm font-semibold text-slate-700 dark:bg-slate-900 dark:text-slate-200">
          Página {pageIndex} / {totalPages}
        </span>

        <a
          href={buildPageHref(Math.min(totalPages, pageIndex + 1))}
          class:list={[
            "rounded-xl border px-4 py-2.5 text-sm font-semibold",
            pageIndex === totalPages
              ? "pointer-events-none border-slate-200 text-slate-400 dark:border-slate-800 dark:text-slate-600"
              : "border-slate-300 text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800",
          ]}
        >
          Siguiente
        </a>
      </div>
    </div>
  </div>

  <dialog id="exercise-modal" hidden={!canEditExercise} class="exercise-modal fixed inset-0 m-0 h-[100dvh] w-[100vw] max-w-none bg-transparent p-4 backdrop:bg-slate-950/85 backdrop:backdrop-blur-md dark:backdrop:bg-slate-950/90">
    <form method="POST" action="/api/exercises/save" class="w-full max-w-6xl overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-[0_30px_120px_rgba(0,0,0,0.55)] dark:border-slate-800 dark:bg-slate-950">
      <div class="flex items-start justify-between gap-3 border-b border-slate-200 bg-white px-5 py-4 dark:border-slate-800 dark:bg-slate-950">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Biblioteca</p>
          <h2 id="exercise-modal-title" class="mt-1 text-2xl font-bold text-slate-900 dark:text-slate-100">Nuevo ejercicio</h2>
        </div>

        <button type="button" data-close-modal class="rounded-xl border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-600 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
          Cerrar
        </button>
      </div>

      <div class="grid gap-6 bg-white p-5 dark:bg-slate-950 lg:grid-cols-[1.05fr_0.95fr]">
        <input type="hidden" name="id" value="" data-field="id" />
        <input type="hidden" name="key" value="" data-field="key" />

        <div class="space-y-4 lg:order-first">
          <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/80 lg:sticky lg:top-4">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Vista previa</p>
                <h3 data-preview-name class="mt-1 text-lg font-bold text-slate-900 dark:text-slate-100">Ejercicio</h3>
              </div>

              <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-sm dark:bg-slate-900 dark:text-slate-200">Vista ligera</span>
            </div>

            <div class="mt-4 overflow-hidden rounded-3xl border border-slate-200 bg-slate-900 shadow-sm dark:border-slate-700">
              <img data-preview-image src="" alt="Vista previa" class="h-72 w-full object-cover sm:h-80 lg:h-[28rem]" />
              <div class="p-4">
                <div class="flex flex-wrap gap-2 text-[11px] font-semibold">
                  <span data-preview-category class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 shadow-sm dark:bg-slate-800 dark:text-slate-200"></span>
                  <span data-preview-muscle class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 shadow-sm dark:bg-slate-800 dark:text-slate-200"></span>
                  <span data-preview-equipment class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 shadow-sm dark:bg-slate-800 dark:text-slate-200"></span>
                </div>
              </div>
            </div>

            <div class="mt-4 overflow-hidden rounded-3xl border border-slate-200 bg-slate-950 shadow-sm dark:border-slate-700">
              <div class="flex items-center justify-between gap-3 border-b border-white/10 px-4 py-3 text-white">
                <div>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/60">Video</p>
                  <p class="mt-1 text-sm font-bold">Vista inferior</p>
                </div>
                <a data-preview-video-link href="#" target="_blank" rel="noreferrer" class="rounded-full border border-white/15 px-3 py-1.5 text-xs font-semibold text-white hover:bg-white/10">Abrir video</a>
              </div>
              <div data-preview-video-shell class="bg-black"></div>
            </div>

            <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">Si no agregas URL, se genera una ilustración automática con pose específica para el ejercicio.</p>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 lg:order-last">
          <label class="space-y-2 md:col-span-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Nombre</span>
            <input name="name" required data-field="name" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Sentadilla libre" />
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Categoría</span>
            <select name="category" required data-field="category" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100">
              <option>Fuerza</option>
              <option>Push</option>
              <option>Pull</option>
              <option>Pierna</option>
              <option>Core</option>
              <option>Cardio</option>
              <option>Accesorio</option>
              <option>Posterior</option>
              <option>Movilidad</option>
            </select>
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Músculo</span>
            <input name="muscle" required data-field="muscle" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Piernas" />
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Equipo</span>
            <input name="equipment" required data-field="equipment" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Barra" />
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Color</span>
            <input name="accent" required data-field="accent" type="color" class="h-12 w-full rounded-2xl border border-slate-300 bg-white p-2 shadow-sm dark:border-slate-700 dark:bg-slate-950" value="#14b8a6" />
          </label>

          <label class="space-y-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Sigla</span>
            <input name="glyph" required data-field="glyph" maxlength="3" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm uppercase dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="SQ" />
          </label>

          <label class="space-y-2 md:col-span-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Imagen URL (opcional)</span>
            <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-950/40">
              <input
                type="file"
                accept="image/*"
                data-field="imageFile"
                class="block w-full text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-slate-800 dark:text-slate-300"
              />
              <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Sube una imagen o deja vacío para usar la ilustración de ejemplo con figura sin rostro.</p>
            </div>
            <input name="image_url" data-field="imageUrl" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="https://..." />
          </label>

          <label class="space-y-2 md:col-span-2">
            <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Video URL (opcional)</span>
            <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-950/40">
              <input
                type="file"
                accept="video/*"
                data-field="videoFile"
                class="block w-full text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:file:bg-slate-800 dark:text-slate-300"
              />
              <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Sube un video corto o pega un enlace de YouTube/MP4. El video aparecerá debajo de la imagen.</p>
            </div>
            <input name="video_url" data-field="videoUrl" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="https://...mp4 o YouTube" />
          </label>
        </div>

        
      </div>

      <div class="flex items-center justify-end gap-3 border-t border-slate-200 bg-white px-5 py-4 dark:border-slate-800 dark:bg-slate-950">
        <button type="button" data-close-modal class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
          Cancelar
        </button>

        <button type="submit" class="rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 hover:bg-emerald-300">
          Guardar ejercicio
        </button>
      </div>
    </form>
  </dialog>

  <style>
    .exercise-modal {
      max-height: calc(100dvh - 2rem);
    }

    .exercise-modal[open] {
      display: grid;
      align-items: center;
      justify-content: center;
    }

    .exercise-modal::backdrop {
      background: rgba(15, 23, 42, 0.72);
    }

    .exercise-modal > form {
      width: 100%;
      max-height: calc(100dvh - 2rem);
      overflow: auto;
    }
  </style>

  <script>
    const searchInput = document.querySelector("[data-exercise-search]");
    const filterButtons = document.querySelectorAll("[data-exercise-filter]");
    const sourceFilterButtons = document.querySelectorAll("[data-exercise-source-filter]");
    const muscleFilter = document.querySelector("[data-exercise-muscle-filter]");
    const equipmentFilter = document.querySelector("[data-exercise-equipment-filter]");
    const cards = document.querySelectorAll("[data-exercise-card]");
    const modal = document.querySelector("#exercise-modal");
    const modalTitle = document.querySelector("#exercise-modal-title");
    const closeButtons = document.querySelectorAll("[data-close-modal]");
    const openButtons = document.querySelectorAll("[data-open-modal]");
    const previewImage = document.querySelector("[data-preview-image]");
    const previewVideoShell = document.querySelector("[data-preview-video-shell]");
    const previewVideoLink = document.querySelector("[data-preview-video-link]");
    const previewName = document.querySelector("[data-preview-name]");
    const previewCategory = document.querySelector("[data-preview-category]");
    const previewMuscle = document.querySelector("[data-preview-muscle]");
    const previewEquipment = document.querySelector("[data-preview-equipment]");
    const imageFileInput = document.querySelector('[data-field="imageFile"]');
    const videoFileInput = document.querySelector('[data-field="videoFile"]');
    const imageUrlInput = document.querySelector('[data-field="imageUrl"]');
    const videoUrlInput = document.querySelector('[data-field="videoUrl"]');
    const fields = {
      id: document.querySelector('[data-field="id"]'),
      key: document.querySelector('[data-field="key"]'),
      name: document.querySelector('[data-field="name"]'),
      category: document.querySelector('[data-field="category"]'),
      muscle: document.querySelector('[data-field="muscle"]'),
      equipment: document.querySelector('[data-field="equipment"]'),
      accent: document.querySelector('[data-field="accent"]'),
      glyph: document.querySelector('[data-field="glyph"]'),
      imageUrl: imageUrlInput,
      videoUrl: videoUrlInput,
    };

    const normalize = (value) => value.trim().toLowerCase();
    const isLikelyImageUrl = (value) => {
      const raw = String(value || "").trim();
      if (!raw) return false;
      if (raw.startsWith("data:image/")) return true;

      try {
        const url = new URL(raw);
        const host = url.hostname.toLowerCase();
        const path = url.pathname.toLowerCase();
        if (host.includes("source.unsplash.com") || host.includes("images.unsplash.com")) return true;
        return /\.(png|jpe?g|gif|webp|avif|svg)$/.test(path);
      } catch {
        return false;
      }
    };
    let previewFallbackUsed = false;
    let activeCategory = "Todos";
    let activeSource = "Todos";

    const activeButtonClasses = [
      "border-slate-900",
      "bg-slate-900",
      "text-white",
      "dark:border-slate-100",
      "dark:bg-slate-100",
      "dark:text-slate-950",
      "shadow-md",
    ];

    const inactiveButtonClasses = [
      "border-slate-200",
      "bg-white",
      "text-slate-700",
      "dark:border-slate-800",
      "dark:bg-slate-900",
      "dark:text-slate-100",
    ];

    const setButtonState = (button, active) => {
      button.classList.remove(...activeButtonClasses, ...inactiveButtonClasses);
      button.classList.add(...(active ? activeButtonClasses : inactiveButtonClasses));
      button.dataset.active = active ? "true" : "false";
    };

    const makeExampleArtwork = () => "/favicon.png";

    const applyFilters = () => {
      const term = normalize(searchInput?.value ?? "");
      const selectedMuscle = muscleFilter?.value ?? "Todos";
      const selectedEquipment = equipmentFilter?.value ?? "Todos";

      cards.forEach((card) => {
        const category = card.dataset.category ?? "";
        const name = card.dataset.name ?? "";
        const muscle = card.dataset.muscle ?? "";
        const equipment = card.dataset.equipment ?? "";
        const source = card.dataset.source ?? "";
        const matchesCategory = activeCategory === "Todos" || category === activeCategory;
        const matchesSource = activeSource === "Todos" || source === activeSource;
        const matchesMuscle = selectedMuscle === "Todos" || muscle === selectedMuscle;
        const matchesEquipment = selectedEquipment === "Todos" || equipment === selectedEquipment;
        const matchesTerm = !term || `${name} ${category} ${muscle} ${equipment} ${source}`.toLowerCase().includes(term);

        card.classList.toggle("hidden", !(matchesCategory && matchesSource && matchesMuscle && matchesEquipment && matchesTerm));
      });
    };

    const previewFromFields = () => {
      if (!fields.name || !fields.category || !fields.muscle || !fields.equipment || !fields.accent || !fields.glyph || !fields.imageUrl || !fields.videoUrl) return;

      const name = fields.name.value || "Ejercicio";
      const category = fields.category.value || "";
      const muscle = fields.muscle.value || "";
      const equipment = fields.equipment.value || "";
      const imageUrl = fields.imageUrl.value || "";
      const videoUrl = fields.videoUrl.value || "";
      const accent = fields.accent.value || "#14b8a6";
      const glyph = fields.glyph.value || "FX";

      if (previewName) previewName.textContent = name || "Ejercicio";
      if (previewCategory) previewCategory.textContent = category;
      if (previewMuscle) previewMuscle.textContent = muscle;
      if (previewEquipment) previewEquipment.textContent = equipment;
      if (previewImage) {
        previewFallbackUsed = false;
        previewImage.onerror = () => {
          if (previewFallbackUsed) return;
          previewFallbackUsed = true;
          previewImage.src = makeExampleArtwork(name, accent, glyph);
        };
        previewImage.src = isLikelyImageUrl(imageUrl) ? imageUrl : makeExampleArtwork(name, accent, glyph);
      }

      if (previewVideoShell) {
        if (videoUrl) {
          const isYouTube = videoUrl.includes("youtube.com") || videoUrl.includes("youtu.be");
          const videoMarkup = isYouTube
            ? `<iframe src="${videoUrl.includes("embed") ? videoUrl : videoUrl.replace("watch?v=", "embed/").replace("youtu.be/", "www.youtube.com/embed/")}" class="h-72 w-full sm:h-80" title="${name}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`
            : `<video src="${videoUrl}" controls class="h-72 w-full object-cover sm:h-80"></video>`;

          previewVideoShell.innerHTML = videoMarkup;
          if (previewVideoLink instanceof HTMLAnchorElement) previewVideoLink.href = videoUrl;
        } else {
          previewVideoShell.innerHTML = `<div class="flex h-40 items-center justify-center p-6 text-sm text-slate-400">Agrega un video para verlo aquí.</div>`;
          if (previewVideoLink instanceof HTMLAnchorElement) previewVideoLink.href = "#";
        }
      }
    };

    const openModal = (mode, data = {}) => {
      if (!modal || !modalTitle || !fields.id || !fields.key || !fields.name || !fields.category || !fields.muscle || !fields.equipment || !fields.accent || !fields.glyph || !fields.imageUrl || !fields.videoUrl) return;

      modalTitle.textContent = mode === "edit" ? "Editar ejercicio" : data.id ? "Duplicar ejercicio" : "Nuevo ejercicio";
      fields.id.value = data.id || "";
      fields.key.value = data.key || "";
      fields.name.value = data.name || "";
      fields.category.value = data.category || "Fuerza";
      fields.muscle.value = data.muscle || "";
      fields.equipment.value = data.equipment || "";
      fields.accent.value = data.accent || "#14b8a6";
      fields.glyph.value = data.glyph || "FX";
      fields.imageUrl.value = data.imageUrl || "";
      fields.videoUrl.value = data.videoUrl || "";
      if (imageFileInput) imageFileInput.value = "";
      if (videoFileInput) videoFileInput.value = "";

      previewFromFields();
      modal.showModal();
    };

    const readFileAsDataUrl = (file) =>
      new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ""));
        reader.onerror = () => reject(reader.error);
        reader.readAsDataURL(file);
      });

    searchInput?.addEventListener("input", applyFilters);
    muscleFilter?.addEventListener("change", applyFilters);
    equipmentFilter?.addEventListener("change", applyFilters);

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.exerciseFilter || "Todos";
        filterButtons.forEach((item) => {
          setButtonState(item, item === button);
        });
        applyFilters();
      });
    });

    sourceFilterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeSource = button.dataset.exerciseSourceFilter || "Todos";
        sourceFilterButtons.forEach((item) => {
          setButtonState(item, item === button);
        });
        applyFilters();
      });
    });

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        openModal(button.dataset.openModal || "create", {
          id: button.dataset.exerciseId || "",
          key: button.dataset.exerciseKey || "",
          name: button.dataset.exerciseName || "",
          category: button.dataset.exerciseCategory || "Fuerza",
          muscle: button.dataset.exerciseMuscle || "",
          equipment: button.dataset.exerciseEquipment || "",
          accent: button.dataset.exerciseAccent || "#14b8a6",
          glyph: button.dataset.exerciseGlyph || "FX",
          imageUrl: button.dataset.exerciseImageUrl || "",
        });
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        modal?.close?.();
      });
    });

    if (imageFileInput && fields.imageUrl) {
      imageFileInput.addEventListener("change", async () => {
        const file = imageFileInput.files?.[0];
        if (!file) return;
        const dataUrl = await readFileAsDataUrl(file);
        fields.imageUrl.value = dataUrl;
        previewFromFields();
      });
    }

    if (videoFileInput && fields.videoUrl) {
      videoFileInput.addEventListener("change", async () => {
        const file = videoFileInput.files?.[0];
        if (!file) return;
        const dataUrl = await readFileAsDataUrl(file);
        fields.videoUrl.value = dataUrl;
        previewFromFields();
      });
    }

    document.querySelectorAll("[data-field]").forEach((field) => {
      field.addEventListener("input", previewFromFields);
      field.addEventListener("change", previewFromFields);
    });

    filterButtons.forEach((button) => setButtonState(button, (button.dataset.exerciseFilter || "Todos") === activeCategory));
    sourceFilterButtons.forEach((button) => setButtonState(button, (button.dataset.exerciseSourceFilter || "Todos") === activeSource));

    applyFilters();
  </script>
</AppLayout>
