---
import AppLayout from "../../layouts/layout.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import {
  ensureExerciseSchema,
  getExerciseByKey,
  getExerciseGuide,
  getExerciseReferenceImage,
} from "../../lib/utils/exercise-library";
import { getClientByUserId } from "../../lib/utils/client-profile";

const user = Astro.locals.user;
const key = Astro.params.key;
const trainerIdParam = Astro.url.searchParams.get("trainer_id");

if (!user) {
  return Astro.redirect("/login");
}

if (!key) {
  return Astro.redirect("/exercises");
}

await ensureExerciseSchema();
const client = user.role === "client" ? await getClientByUserId(user.id) : null;
const trainerId = trainerIdParam ? Number(trainerIdParam) : user.role === "trainer" ? user.id : client?.trainer_id ?? null;
const exercise = await getExerciseByKey(key, Number.isNaN(trainerId as number) ? null : trainerId);

if (!exercise) {
  return new Response("Ejercicio no encontrado", { status: 404 });
}

const guide = getExerciseGuide(exercise);
const canEditExercise = ["trainer", "gym_manager", "admin"].includes(user.role as string);
const referenceImage = exercise.imageUrl ?? await getExerciseReferenceImage(exercise);
---

<AppLayout title={exercise.name}>
  <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow={exercise.source === "trainer" ? "Ejercicio personalizado" : "Biblioteca"}
      title={exercise.name}
      description={`${exercise.category} · ${exercise.muscle} · ${exercise.equipment}`}
    >
      <a slot="actions" href="/exercises" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">
        ← Volver
      </a>
    </SectionHeader>

    <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
      <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <div class="h-2 w-full" style={`background:${exercise.accent}`}></div>
        {exercise.videoUrl ? (
          <div class="bg-slate-950">
            {exercise.videoUrl.includes("youtube.com") || exercise.videoUrl.includes("youtu.be") ? (
              <iframe src={exercise.videoUrl.includes("embed") ? exercise.videoUrl : exercise.videoUrl.replace("watch?v=", "embed/").replace("youtu.be/", "www.youtube.com/embed/")} class="h-72 w-full sm:h-80" title={exercise.name} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            ) : (
              <video src={exercise.videoUrl} controls class="h-72 w-full object-cover sm:h-80"></video>
            )}
          </div>
        ) : referenceImage ? (
          <img src={referenceImage} alt={exercise.name} class="h-72 w-full object-cover sm:h-80" />
        ) : exercise.imageUrl ? (
          <img src={exercise.imageUrl} alt={exercise.name} class="h-72 w-full object-cover sm:h-80" />
        ) : (
          <div class="flex h-72 w-full items-end bg-gradient-to-br from-slate-950 via-slate-900 to-slate-800 p-6 text-white sm:h-80">
            <div class="max-w-xl rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-white/60">Vista previa del ejercicio</p>
              <h2 class="mt-2 text-3xl font-black leading-tight sm:text-4xl">{exercise.name}</h2>
              <p class="mt-2 text-sm text-white/70">Referencia visual limpia para acompañar la explicación.</p>
            </div>
          </div>
        )}
        <div class="p-6">
          <div class="flex flex-wrap gap-2 text-[11px] font-semibold">
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{exercise.category}</span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{exercise.muscle}</span>
            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-slate-700 dark:bg-slate-800 dark:text-slate-200">{exercise.equipment}</span>
          </div>

          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/50">
              <p class="text-xs uppercase tracking-wide text-slate-400">Tipo</p>
              <p class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{exercise.source === "trainer" ? "Personalizado" : "Base"}</p>
            </div>

            <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/50">
              <p class="text-xs uppercase tracking-wide text-slate-400">Color</p>
              <p class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{exercise.accent}</p>
            </div>

            <div class="rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/50">
              <p class="text-xs uppercase tracking-wide text-slate-400">Sigla</p>
              <p class="mt-1 font-semibold text-slate-900 dark:text-slate-100">{exercise.glyph}</p>
            </div>
          </div>

          <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            {canEditExercise && (
              <a href={`/routines/new?exercise=${exercise.key}`} class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 hover:bg-emerald-300 sm:w-auto">
                Usar en rutina
              </a>
            )}

            <a href="/exercises" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">
              Ver biblioteca
            </a>
          </div>
        </div>
      </section>

      <section class="space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Cómo hacerlo</p>
          <h2 class="mt-2 text-2xl font-bold text-slate-900 dark:text-slate-100">Guía rápida</h2>
          <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">{guide.overview}</p>

          <ol class="mt-5 space-y-3">
            {guide.steps.map((step: string, index: number) => (
              <li class="flex gap-3 rounded-2xl bg-slate-50 p-4 dark:bg-slate-950/50">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-400 text-sm font-bold text-slate-900">{index + 1}</span>
                <p class="text-sm text-slate-700 dark:text-slate-200">{step}</p>
              </li>
            ))}
          </ol>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Consejos</p>
          <div class="mt-4 space-y-3">
            {guide.tips.map((tip: string) => (
              <div class="rounded-2xl bg-slate-50 p-4 text-sm text-slate-700 dark:bg-slate-950/50 dark:text-slate-200">{tip}</div>
            ))}
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-600 dark:text-emerald-400">Errores comunes</p>
          <div class="mt-4 space-y-3">
            {guide.commonMistakes.map((mistake: string) => (
              <div class="rounded-2xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-900/30 dark:bg-amber-950/20 dark:text-amber-200">{mistake}</div>
            ))}
          </div>
        </div>

        {canEditExercise && (
          <div class="rounded-3xl border border-emerald-200 bg-emerald-50 p-6 shadow-sm dark:border-emerald-900/40 dark:bg-emerald-500/10">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700 dark:text-emerald-300">Edición</p>
            <h2 class="mt-2 text-2xl font-bold text-slate-900 dark:text-slate-100">{exercise.source === "trainer" ? "Editar ejercicio" : "Crear versión editable"}</h2>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">Solo entrenadores, managers y admin pueden cambiar imagen o video. Clientes no ven este bloque.</p>

            <form method="POST" action="/api/exercises/save" class="mt-5 space-y-4">
              <input type="hidden" name="id" value={exercise.id ?? ""} />
              <input type="hidden" name="key" value={exercise.key} />
              <input type="hidden" name="name" value={exercise.name} />
              <input type="hidden" name="category" value={exercise.category} />
              <input type="hidden" name="muscle" value={exercise.muscle} />
              <input type="hidden" name="equipment" value={exercise.equipment} />
              <input type="hidden" name="accent" value={exercise.accent} />
              <input type="hidden" name="glyph" value={exercise.glyph} />

              <label class="block space-y-2">
                <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Imagen URL</span>
                <input name="image_url" value={exercise.imageUrl ?? ""} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10" placeholder="https://..." />
              </label>

              <label class="block space-y-2">
                <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Video URL</span>
                <input name="video_url" value={exercise.videoUrl ?? ""} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm shadow-sm outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10" placeholder="https://...mp4 o YouTube" />
              </label>

              <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-bold text-white hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200 sm:w-auto">
                Guardar cambios
              </button>
            </form>
          </div>
        )}
      </section>
    </div>
  </div>
</AppLayout>
