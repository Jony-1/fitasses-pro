---
import AppLayout from "../../../layouts/layout.astro";
import { sql } from "../../../lib/db/client";
import { dateOnlyInputValue } from "../../../lib/utils/date";
import { calculateAge } from "../../../lib/utils/age";

const { id } = Astro.params;

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const result = await sql`
  SELECT
  c.id,
  c.full_name,
  c.birth_date,
  c.height_m,
  c.notes,
  c.gender,
  c.user_id,
  c.created_at,
  u.email AS access_email
FROM clients c
LEFT JOIN users u ON u.id = c.user_id
WHERE c.id = ${Number(id)}
LIMIT 1
`;

const client = result[0];
const age = calculateAge(client.birth_date);

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const birthDateValue = dateOnlyInputValue(client.birth_date);
const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login");
}

if (user.role !== "trainer" && user.role !== "admin") {
  return Astro.redirect("/login?error=forbidden");
}

const accessStatus = Astro.url.searchParams.get("access_status");
const accessMessage = Astro.url.searchParams.get("access_message");
---

<AppLayout title={`Editar cliente #${client.id}`}>
    <div class="mx-auto max-w-3xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a
                href={`/clients/${client.id}`}
                class="text-sm font-medium text-slate-500 hover:text-emerald-600"
            >
                ← Volver al perfil
            </a>

            <h1 class="mt-2 text-3xl font-bold tracking-tight">
                Editar cliente
            </h1>
            <p class="mt-1 text-sm text-slate-600">
                Actualiza la información general del cliente.
            </p>
        </div>

        {
            accessMessage && accessStatus === "success" && (
                <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/30 dark:text-emerald-300">
                    {accessMessage}
                </div>
            )
        }

        {
            accessMessage && accessStatus === "error" && (
                <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900 dark:bg-red-950/30 dark:text-red-300">
                    {accessMessage}
                </div>
            )
        }

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-800/95 sm:p-8">
            <form id="edit-client-form" class="space-y-6">
                <div>
                    <label
                        for="full_name"
                        class="mb-2 block text-sm font-semibold text-slate-700"
                    >
                        Nombre completo
                    </label>
                    <input
                        id="full_name"
                        name="full_name"
                        type="text"
                        value={client.full_name ?? ""}
                        required
                        class="w-full rounded-lg border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                    />
                </div>

                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div>
                        <label
                            for="birth_date"
                            class="mb-2 block text-sm font-semibold text-slate-700"
                        >
                            Fecha de nacimiento
                        </label>
                        <input
                            id="birth_date"
                            name="birth_date"
                            type="date"
                            value={birthDateValue}
                            class="w-full rounded-lg border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                        />
                    </div>
                    <div>
                        <label
                            for="gender"
                            class="mb-2 block text-sm font-semibold text-slate-700"
                        >
                            Genero
                        </label>
                        <input
                            id="gender"
                            type="text"
                            value={client.gender ?? ""}
                            disabled
                            class="w-full rounded-lg border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-semibold text-slate-700 dark:text-slate-300"
                        >
                            Edad
                        </label>

                        <input
                            id="age_display"
                            type="text"
                            value={age ? `${age} años` : "-"}
                            disabled
                            class="mt-1 w-full rounded-xl border border-slate-300 bg-slate-100 px-4 py-3 text-slate-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200"
                        />
                    </div>

                    <div>
                        <label
                            for="height_m"
                            class="mb-2 block text-sm font-semibold text-slate-700"
                        >
                            Altura (m)
                        </label>
                        <input
                            id="height_m"
                            name="height_m"
                            type="number"
                            step="0.01"
                            min="0.5"
                            max="2.5"
                            value={client.height_m ?? ""}
                            placeholder="Ej: 1.70"
                            class="w-full rounded-lg border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                        />
                    </div>
                </div>

                <div>
                    <label
                        for="notes"
                        class="mb-2 block text-sm font-semibold text-slate-700"
                    >
                        Observaciones
                    </label>
                    <textarea
                        id="notes"
                        name="notes"
                        rows="5"
                        class="w-full rounded-lg border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                        >{client.notes ?? ""}</textarea
                    >
                </div>

                <div
                    id="form-message"
                    class="hidden rounded-lg px-4 py-3 text-sm font-medium"
                >
                </div>

                <div class="flex items-center justify-end gap-3">
                    <a
                        href={`/clients/${client.id}`}
                        class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
                    >
                        Cancelar
                    </a>

                    <button
                        type="submit"
                        class="inline-flex items-center rounded-lg bg-emerald-500 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-600"
                    >
                        Guardar cambios
                    </button>
                </div>
            </form>
        </div>
        
        <section
            class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900"
        >
            <h2 class="text-xl font-semibold text-slate-900 dark:text-white">
                Gestión de acceso
            </h2>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Administra las credenciales para que este cliente pueda iniciar
                sesión y ver su progreso.
            </p>

            {
                !client.user_id ? (
                    <div class="mt-6">
                        <p class="mb-4 text-sm text-slate-600 dark:text-slate-400">
                            Este cliente aún no tiene acceso creado.
                        </p>

                        <form
                            action={`/api/clients/${client.id}/create-access`}
                            method="POST"
                            class="space-y-4"
                        >
                            <div>
                                <label
                                    for="access_email"
                                    class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300"
                                >
                                    Correo
                                </label>
                                <input
                                    id="access_email"
                                    name="email"
                                    type="email"
                                    required
                                    class="w-full rounded-xl border border-slate-300 px-4 py-2 outline-none focus:border-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                                />
                            </div>

                            <div>
                                <label
                                    for="access_password"
                                    class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300"
                                >
                                    Contraseña temporal
                                </label>
                                <input
                                    id="access_password"
                                    name="password"
                                    type="password"
                                    required
                                    minlength="8"
                                    maxlength="72"
                                    pattern="^(?=.*[A-Z])(?=.*\d).{8,72}$"
                                    title="Debe tener al menos 8 caracteres, una mayúscula y un número."
                                    class="w-full rounded-xl border border-slate-300 px-4 py-2 outline-none focus:border-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                                    placeholder="8 caracteres, mayúscula y número"
                                />
                            </div>

                            <button
                                type="submit"
                                class="rounded-xl bg-slate-900 px-4 py-2 font-medium text-white hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-white"
                            >
                                Crear acceso
                            </button>
                        </form>
                    </div>
                ) : (
                    <div class="mt-6 space-y-6">
                        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/30 dark:text-emerald-300">
                            Este cliente ya tiene una cuenta vinculada.
                        </div>

                        <div>
                            <p class="text-sm text-slate-500 dark:text-slate-400">
                                Correo actual
                            </p>
                            <p class="mt-1 font-medium text-slate-900 dark:text-white">
                                {client.access_email || "Sin correo"}
                            </p>
                        </div>

                        <form
                            action={`/api/clients/${client.id}/update-access-email`}
                            method="POST"
                            class="space-y-4"
                        >
                            <div>
                                <label
                                    for="new_access_email"
                                    class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300"
                                >
                                    Actualizar correo
                                </label>
                                <input
                                    id="new_access_email"
                                    name="email"
                                    type="email"
                                    required
                                    value={client.access_email || ""}
                                    class="w-full rounded-xl border border-slate-300 px-4 py-2 outline-none focus:border-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                                />
                            </div>

                            <button
                                type="submit"
                                class="rounded-xl border border-slate-300 px-4 py-2 font-medium text-slate-700 hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
                            >
                                Actualizar correo
                            </button>
                        </form>

                        <form
                            action={`/api/clients/${client.id}/reset-access-password`}
                            method="POST"
                            class="space-y-4"
                        >
                            <div>
                                <label
                                    for="reset_access_password"
                                    class="mb-1 block text-sm font-medium text-slate-700 dark:text-slate-300"
                                >
                                    Nueva contraseña temporal
                                </label>
                                <input
                                    id="reset_access_password"
                                    name="password"
                                    type="password"
                                    required
                                    minlength="8"
                                    maxlength="72"
                                    pattern="^(?=.*[A-Z])(?=.*\d).{8,72}$"
                                    title="Debe tener al menos 8 caracteres, una mayúscula y un número."
                                    class="w-full rounded-xl border border-slate-300 px-4 py-2 outline-none focus:border-slate-500 dark:border-slate-700 dark:bg-slate-950 dark:text-white"
                                    placeholder="8 caracteres, mayúscula y número"
                                />
                            </div>

                            <button
                                type="submit"
                                class="rounded-xl border border-amber-300 bg-amber-50 px-4 py-2 font-medium text-amber-800 hover:bg-amber-100 dark:border-amber-900 dark:bg-amber-950/30 dark:text-amber-300 dark:hover:bg-amber-950/50"
                            >
                                Restablecer contraseña
                            </button>
                        </form>
                    </div>
                )
            }
        </section>
    </div>
</AppLayout>

<script define:vars={{ clientId: client.id }}>
    const form = document.getElementById("edit-client-form");
    const messageBox = document.getElementById("form-message");

    function showMessage(text, type = "error") {
        if (!messageBox) return;

        messageBox.textContent = text;
        messageBox.classList.remove("hidden");
        messageBox.className =
            "rounded-lg px-4 py-3 text-sm font-medium " +
            (type === "success"
                ? "bg-emerald-100 text-emerald-800"
                : "bg-red-100 text-red-800");
    }

    form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const formData = new FormData(form);

        const payload = {
            full_name: String(formData.get("full_name") ?? "").trim(),
            birth_date: String(formData.get("birth_date") ?? "").trim(),
            height_m: String(formData.get("height_m") ?? "").trim(),
            notes: String(formData.get("notes") ?? "").trim(),
        };

        try {
            const response = await fetch(`/api/clients/${clientId}`, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify(payload),
            });

            const data = await response.json();

            if (!response.ok) {
                showMessage(data.error || "No se pudo actualizar el cliente");
                return;
            }

            showMessage("Cliente actualizado correctamente", "success");

            setTimeout(() => {
                window.location.href = `/clients/${clientId}`;
            }, 700);
        } catch (error) {
            showMessage("Ocurrió un error inesperado al guardar");
        }
    });
</script>
