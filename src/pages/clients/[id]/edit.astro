---
import AppLayout from "../../../layouts/Layout.astro";
import { sql } from "../../../lib/db/client";
import { getClientByIdForUser } from "../../../lib/utils/client-profile";
import { dateOnlyInputValue } from "../../../lib/utils/date";
import { calculateAge } from "../../../lib/utils/age";

const { id } = Astro.params;

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login");
}

if (user.role !== "trainer" && user.role !== "admin" && user.role !== "gym_manager") {
    return Astro.redirect("/login?error=forbidden");
}

const hasAccess = await getClientByIdForUser(Number(id), user);
if (!hasAccess) {
    return Astro.redirect("/clients?error=forbidden");
}

const result = await sql`
  SELECT
    c.id,
    c.full_name,
    c.birth_date,
    c.height_m,
    c.notes,
    c.gender,
    c.user_id,
    c.created_at,
    u.email AS access_email
  FROM clients c
  LEFT JOIN users u ON u.id = c.user_id
  WHERE c.id = ${Number(id)}
  LIMIT 1
`;

const client = result[0];

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const age = calculateAge(client.birth_date);
const birthDateValue = dateOnlyInputValue(client.birth_date);

const accessStatus = Astro.url.searchParams.get("access_status");
const accessMessage = Astro.url.searchParams.get("access_message");
---

<AppLayout title={`Editar cliente #${client.id}`}>
    <div class="mx-auto max-w-5xl px-4 py-4 sm:px-6 sm:py-6 lg:px-8">
        <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-slate-950 shadow-xl dark:border-slate-800">
            <div class="grid gap-0 lg:grid-cols-[1fr_1.05fr]">
                <div class="relative overflow-hidden bg-gradient-to-br from-sky-500 via-cyan-500 to-emerald-400 p-6 text-slate-950 sm:p-8 lg:min-h-[calc(100vh-4rem)] lg:p-10">
                    <div class="absolute -right-12 -top-12 h-40 w-40 rounded-full bg-white/20 blur-2xl"></div>
                    <div class="absolute -bottom-16 right-12 h-56 w-56 rounded-full bg-black/10 blur-3xl"></div>

                    <a href={`/clients/${client.id}`} class="text-xs font-bold uppercase tracking-[0.3em] text-slate-900/70 hover:text-slate-950">
                        ← Volver al perfil
                    </a>

                    <h1 class="mt-4 max-w-md text-3xl font-black tracking-tight text-slate-950 sm:text-4xl lg:text-5xl">
                        Editar cliente con una vista limpia y rápida.
                    </h1>
                    <p class="mt-4 max-w-md text-sm leading-6 text-slate-900/80">
                        Actualiza datos generales, revisa acceso y mantén todo ordenado desde una sola pantalla.
                    </p>

                    <div class="mt-8 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
                        <div class="rounded-2xl border border-white/30 bg-white/25 p-4 backdrop-blur">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-900/60">Cliente</p>
                            <p class="mt-1 text-sm font-bold text-slate-950">#{client.id}</p>
                        </div>
                        <div class="rounded-2xl border border-white/30 bg-white/25 p-4 backdrop-blur">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-900/60">Edad</p>
                            <p class="mt-1 text-sm font-bold text-slate-950">{age ? `${age} años` : "-"}</p>
                        </div>
                        <div class="rounded-2xl border border-white/30 bg-white/25 p-4 backdrop-blur">
                            <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-900/60">Acceso</p>
                            <p class="mt-1 text-sm font-bold text-slate-950">{client.user_id ? "Vinculado" : "Pendiente"}</p>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-950 p-4 sm:p-6 lg:p-8">
                    <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <h2 class="text-xl font-bold text-slate-100 sm:text-2xl">Formulario</h2>
                            <p class="mt-1 text-sm text-slate-400">Actualiza los datos del cliente.</p>
                        </div>

                        <a href={`/clients/${client.id}`} class="rounded-xl border border-slate-700 px-4 py-2 text-sm font-semibold text-slate-200 hover:bg-slate-900">
                            Volver
                        </a>
                    </div>

                    {accessMessage && accessStatus === "success" && (
                        <div class="mb-6 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/30 dark:text-emerald-300">
                            {accessMessage}
                        </div>
                    )}

                    {accessMessage && accessStatus === "error" && (
                        <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-900 dark:bg-red-950/30 dark:text-red-300">
                            {accessMessage}
                        </div>
                    )}

                    <div class="rounded-[1.75rem] border border-slate-800 bg-slate-900/90 p-5 shadow-2xl sm:p-6">
                        <form id="edit-client-form" class="space-y-6">
                            <div class="space-y-2">
                                <label for="full_name" class="block text-sm font-semibold text-slate-200">
                                    Nombre completo
                                </label>
                                <input
                                    id="full_name"
                                    name="full_name"
                                    type="text"
                                    value={client.full_name ?? ""}
                                    required
                                    class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                />
                            </div>

                            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                                <div class="space-y-2">
                                    <label for="birth_date" class="block text-sm font-semibold text-slate-200">
                                        Fecha de nacimiento
                                    </label>
                                    <input
                                        id="birth_date"
                                        name="birth_date"
                                        type="date"
                                        value={birthDateValue}
                                        class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                    />
                                </div>

                                <div class="space-y-2">
                                    <label for="gender" class="block text-sm font-semibold text-slate-200">
                                        Género
                                    </label>
                                    <input
                                        id="gender"
                                        type="text"
                                        value={client.gender ?? ""}
                                        disabled
                                        class="w-full rounded-xl border border-slate-700 bg-slate-900 px-4 py-3 text-slate-300 outline-none"
                                    />
                                </div>

                                <div class="space-y-2">
                                    <label class="block text-sm font-semibold text-slate-200">
                                        Edad
                                    </label>
                                    <input
                                        id="age_display"
                                        type="text"
                                        value={age ? `${age} años` : "-"}
                                        disabled
                                        class="w-full rounded-xl border border-slate-700 bg-slate-900 px-4 py-3 text-slate-300 outline-none"
                                    />
                                </div>

                                <div class="space-y-2">
                                    <label for="height_m" class="block text-sm font-semibold text-slate-200">
                                        Altura (m)
                                    </label>
                                    <input
                                        id="height_m"
                                        name="height_m"
                                        type="number"
                                        step="0.01"
                                        min="0.5"
                                        max="2.5"
                                        value={client.height_m ?? ""}
                                        placeholder="Ej: 1.70"
                                        class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                    />
                                </div>
                            </div>

                            <div class="space-y-2">
                                <label for="notes" class="block text-sm font-semibold text-slate-200">
                                    Observaciones
                                </label>
                                <textarea
                                    id="notes"
                                    name="notes"
                                    rows="5"
                                    class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-3 text-slate-100 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                >{client.notes ?? ""}</textarea>
                            </div>

                            <div id="form-message" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

                            <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                                <a
                                    href={`/clients/${client.id}`}
                                    class="inline-flex items-center justify-center rounded-xl border border-slate-700 px-4 py-2.5 text-sm font-bold text-slate-200 hover:bg-slate-800"
                                >
                                    Cancelar
                                </a>

                                <button
                                    type="submit"
                                    class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-2.5 text-sm font-bold text-slate-950 hover:bg-emerald-300"
                                >
                                    Guardar cambios
                                </button>
                            </div>
                        </form>
                    </div>

                    <section class="mt-8 rounded-3xl border border-slate-800 bg-slate-900 p-6 shadow-sm">
                        <h2 class="text-xl font-semibold text-slate-100">Gestión de acceso</h2>
                        <p class="mt-1 text-sm text-slate-400">
                            Administra las credenciales para que este cliente pueda iniciar sesión y ver su progreso.
                        </p>

                        {
                            !client.user_id ? (
                                <div class="mt-6">
                                    <p class="mb-4 text-sm text-slate-400">
                                        Este cliente aún no tiene acceso creado.
                                    </p>

                                    <form action={`/api/clients/${client.id}/create-access`} method="POST" class="space-y-4">
                                        <div class="space-y-2">
                                            <label for="access_email" class="block text-sm font-medium text-slate-200">
                                                Correo
                                            </label>
                                            <input
                                                id="access_email"
                                                name="email"
                                                type="email"
                                                required
                                                class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                            />
                                        </div>

                                        <div class="space-y-2">
                                            <label for="access_password" class="block text-sm font-medium text-slate-200">
                                                Contraseña temporal
                                            </label>
                                            <input
                                                id="access_password"
                                                name="password"
                                                type="password"
                                                required
                                                minlength="4"
                                                maxlength="72"
                                                pattern="^(?=.*[A-Z])(?=.*\\d).{4,72}$"
                                                title="Debe tener al menos 4 caracteres, una mayúscula y un número."
                                                class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                                placeholder="4 caracteres, mayúscula y número"
                                            />
                                        </div>

                                        <button type="submit" class="rounded-xl bg-slate-100 px-4 py-2.5 font-medium text-slate-900 hover:bg-white">
                                            Crear acceso
                                        </button>
                                    </form>
                                </div>
                            ) : (
                                <div class="mt-6 space-y-6">
                                    <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800 dark:border-emerald-900 dark:bg-emerald-950/30 dark:text-emerald-300">
                                        Este cliente ya tiene una cuenta vinculada.
                                    </div>

                                    <div>
                                        <p class="text-sm text-slate-400">Correo actual</p>
                                        <p class="mt-1 font-medium text-slate-100">{client.access_email || "Sin correo"}</p>
                                    </div>

                                    <form action={`/api/clients/${client.id}/update-access-email`} method="POST" class="space-y-4">
                                        <div class="space-y-2">
                                            <label for="new_access_email" class="block text-sm font-medium text-slate-200">
                                                Actualizar correo
                                            </label>
                                            <input
                                                id="new_access_email"
                                                name="email"
                                                type="email"
                                                required
                                                value={client.access_email || ""}
                                                class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                            />
                                        </div>

                                        <button type="submit" class="rounded-xl border border-slate-700 px-4 py-2.5 font-medium text-slate-200 hover:bg-slate-800">
                                            Actualizar correo
                                        </button>
                                    </form>

                                    <form action={`/api/clients/${client.id}/reset-access-password`} method="POST" class="space-y-4">
                                        <div class="space-y-2">
                                            <label for="reset_access_password" class="block text-sm font-medium text-slate-200">
                                                Nueva contraseña temporal
                                            </label>
                                            <input
                                                id="reset_access_password"
                                                name="password"
                                                type="password"
                                                required
                                                minlength="4"
                                                maxlength="72"
                                                pattern="^(?=.*[A-Z])(?=.*\\d).{4,72}$"
                                                title="Debe tener al menos 4 caracteres, una mayúscula y un número."
                                                class="w-full rounded-xl border border-slate-700 bg-slate-950 px-4 py-2.5 text-slate-100 outline-none focus:border-emerald-400 focus:ring-4 focus:ring-emerald-500/10"
                                                placeholder="4 caracteres, mayúscula y número"
                                            />
                                        </div>

                                        <button type="submit" class="rounded-xl border border-amber-300 bg-amber-50 px-4 py-2.5 font-medium text-amber-800 hover:bg-amber-100">
                                            Restablecer contraseña
                                        </button>
                                    </form>
                                </div>
                            )
                        }
                    </section>
                </div>
            </div>
        </div>
    </div>
</AppLayout>

<script define:vars={{ clientId: client.id }}>
    const form = document.getElementById("edit-client-form");
    const messageBox = document.getElementById("form-message");

    function showMessage(text, type = "error") {
        if (!messageBox) return;

        messageBox.textContent = text;
        messageBox.classList.remove("hidden");
        messageBox.className =
            "rounded-lg px-4 py-3 text-sm font-medium " +
            (type === "success"
                ? "bg-emerald-100 text-emerald-800"
                : "bg-red-100 text-red-800");
    }

    form?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const formData = new FormData(form);

        const payload = {
            full_name: String(formData.get("full_name") ?? "").trim(),
            birth_date: String(formData.get("birth_date") ?? "").trim(),
            height_m: String(formData.get("height_m") ?? "").trim(),
            notes: String(formData.get("notes") ?? "").trim(),
        };

        try {
            const response = await fetch(`/api/clients/${clientId}`, {
                method: "PUT",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify(payload),
            });

            const data = await response.json();

            if (!response.ok) {
                showMessage(data.error || "No se pudo actualizar el cliente");
                return;
            }

            showMessage("Cliente actualizado correctamente", "success");

            setTimeout(() => {
                window.location.href = `/clients/${clientId}`;
            }, 700);
        } catch {
            showMessage("Ocurrió un error inesperado al guardar");
        }
    });
</script>
