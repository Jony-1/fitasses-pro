---
import AppLayout from "../../../../layouts/Layout.astro";
import AssessmentForm from "../../../../components/assessments/AssessmentForm.astro";
import { sql } from "../../../../lib/db/client";
import { getClientByIdForUser } from "../../../../lib/utils/client-profile";
import { canManageAssessments } from "../../../../lib/auth/roles";

const { id } = Astro.params;

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

if (!canManageAssessments(user.role)) {
  return Astro.redirect("/login?error=forbidden");
}

const client = await getClientByIdForUser(Number(id), user) as { id: number; full_name: string; height_m: number | null } | null;

if (!client) {
  return new Response("Cliente no encontrado", { status: 404 });
}

const lastAssessmentRows = await sql`
  SELECT
    a.id,
    a.assessment_date,
    a.weight_kg,
    a.body_fat_pct,
    a.muscle_pct,
    a.daily_calories,
    a.metabolic_age,
    a.visceral_fat,
    a.notes,
    m.shoulders_cm,
    m.chest_cm,
    m.right_arm_cm,
    m.waist_cm,
    m.hips_cm,
    m.right_thigh_cm,
    m.calf_cm
  FROM assessments a
  LEFT JOIN assessment_measurements m
    ON m.assessment_id = a.id
  WHERE a.client_id = ${Number(id)}
  ORDER BY a.assessment_date DESC, a.id DESC
  LIMIT 1
`;

const lastAssessment = lastAssessmentRows[0];

function todayDateInput() {
    const now = new Date();
    const year = now.getFullYear();
    const month = String(now.getMonth() + 1).padStart(2, "0");
    const day = String(now.getDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
}

function formatInitialNumber(value: unknown) {
  if (value === null || value === undefined || value === "") return "";

  const num = Number(value);
  if (Number.isNaN(num)) return String(value);

  return String(num);
}


const initialValues = {
  assessment_id: "",
  assessment_date: todayDateInput(),
  weight_kg: formatInitialNumber(lastAssessment?.weight_kg),
  body_fat_pct: formatInitialNumber(lastAssessment?.body_fat_pct),
  muscle_pct: formatInitialNumber(lastAssessment?.muscle_pct),
  daily_calories: String(lastAssessment?.daily_calories ?? ""),
  metabolic_age: String(lastAssessment?.metabolic_age ?? ""),
  visceral_fat: String(lastAssessment?.visceral_fat ?? ""),
  shoulders_cm: formatInitialNumber(lastAssessment?.shoulders_cm),
  chest_cm: formatInitialNumber(lastAssessment?.chest_cm),
  right_arm_cm: formatInitialNumber(lastAssessment?.right_arm_cm),
  waist_cm: formatInitialNumber(lastAssessment?.waist_cm),
  hips_cm: formatInitialNumber(lastAssessment?.hips_cm),
  right_thigh_cm: formatInitialNumber(lastAssessment?.right_thigh_cm),
  calf_cm: formatInitialNumber(lastAssessment?.calf_cm),
  notes: "",
};

---

<AppLayout title={`Nueva valoración - ${client.full_name}`}>
    <div class="mx-auto max-w-4xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a
                href={`/clients/${client.id}`}
                class="text-sm font-medium text-slate-500 hover:text-emerald-600 dark:text-slate-400 dark:hover:text-emerald-400"
            >
                ← Volver al cliente
            </a>

            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">
                Nueva valoración
            </h1>

            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                Registra una nueva valoración física para <strong
                    >{client.full_name}</strong
                >.
            </p>
        </div>

        <AssessmentForm
            clientId={client.id}
            clientHeightM={client.height_m}
            actionUrl="/api/assessments/valoracion_create"
            submitLabel="Guardar valoración"
            successRedirect={`/clients/${client.id}/assessments/`}
            cancelHref={`/clients/${client.id}`}
            initialValues={initialValues}
        />
    </div>
</AppLayout>
