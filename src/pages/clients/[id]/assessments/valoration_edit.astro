---
const { id } = Astro.params;
const assessmentId = Astro.url.searchParams.get("assessmentId");

if (!id || Number.isNaN(Number(id))) {
  return Astro.redirect("/clients");
}

const target = assessmentId
  ? `/clients/${id}/assessments/valoracion_edit?assessmentId=${encodeURIComponent(assessmentId)}`
  : `/clients/${id}/assessments`;

return Astro.redirect(target);
---
