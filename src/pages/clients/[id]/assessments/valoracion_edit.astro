---
import AppLayout from "../../../../layouts/layout.astro";
import AssessmentForm from "../../../../components/assessments/AssessmentForm.astro";
import { sql } from "../../../../lib/db/client";
import { getClientByIdForUser } from "../../../../lib/utils/client-profile";
import { canManageAssessments } from "../../../../lib/auth/roles";

const { id } = Astro.params;
const assessmentId = Number(Astro.url.searchParams.get("assessmentId"));
const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login?error=unauthorized");
}

const canManageClientAssessments = canManageAssessments(user.role);

if (!canManageClientAssessments) {
    return Astro.redirect("/dashboard?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

if (!assessmentId || Number.isNaN(assessmentId)) {
    return Astro.redirect(`/clients/${id}/assessments`);
}

const client = await getClientByIdForUser(Number(id), user) as { id: number; full_name: string; height_m: number | null } | null;

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const assessmentRows = await sql`
  SELECT
    a.id,
    a.client_id,
    a.assessment_date,
    a.weight_kg,
    a.body_fat_pct,
    a.muscle_pct,
    a.daily_calories,
    a.metabolic_age,
    a.visceral_fat,
    a.bmi,
    a.notes,
    m.shoulders_cm,
    m.chest_cm,
    m.right_arm_cm,
    m.waist_cm,
    m.hips_cm,
    m.right_thigh_cm,
    m.calf_cm
  FROM assessments a
  LEFT JOIN assessment_measurements m
    ON m.assessment_id = a.id
  WHERE a.id = ${assessmentId}
    AND a.client_id = ${Number(id)}
  LIMIT 1
`;

const assessment = assessmentRows[0];

if (!assessment) {
    return new Response("Valoración no encontrada", { status: 404 });
}

function formatDateInput(value: unknown) {
    if (!value) return "";

    const date = value instanceof Date ? value : new Date(String(value));
    if (Number.isNaN(date.getTime())) return "";

    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");

    return `${year}-${month}-${day}`;
}

function formatInitialNumber(value: unknown) {
    if (value === null || value === undefined || value === "") return "";

    const num = Number(value);
    if (Number.isNaN(num)) return String(value);

    return String(num);
}

const initialValues = {
    assessment_id: String(assessment.id ?? ""),
    assessment_date: formatDateInput(assessment.assessment_date),
    weight_kg: formatInitialNumber(assessment.weight_kg),
    body_fat_pct: formatInitialNumber(assessment.body_fat_pct),
    muscle_pct: formatInitialNumber(assessment.muscle_pct),
    daily_calories: String(assessment.daily_calories ?? ""),
    metabolic_age: String(assessment.metabolic_age ?? ""),
    visceral_fat: String(assessment.visceral_fat ?? ""),
    shoulders_cm: formatInitialNumber(assessment.shoulders_cm),
    chest_cm: formatInitialNumber(assessment.chest_cm),
    right_arm_cm: formatInitialNumber(assessment.right_arm_cm),
    waist_cm: formatInitialNumber(assessment.waist_cm),
    hips_cm: formatInitialNumber(assessment.hips_cm),
    right_thigh_cm: formatInitialNumber(assessment.right_thigh_cm),
    calf_cm: formatInitialNumber(assessment.calf_cm),
    notes: String(assessment.notes ?? ""),
};
---

<AppLayout title={`Editar valoración - ${client.full_name}`}>
    <div class="mx-auto max-w-4xl px-4 py-6 sm:px-6 lg:px-8">
        <div class="mb-6">
            <a
                href={`/clients/${client.id}/assessments`}
                class="text-sm font-medium text-slate-500 hover:text-emerald-600"
            >
                ← Volver al historial
            </a>

            <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-900">
                Editar valoración
            </h1>

            <p class="mt-1 text-sm text-slate-600">
                Actualiza la valoración física de <strong
                    >{client.full_name}</strong
                >.
            </p>
        </div>

        <AssessmentForm
            clientId={client.id}
            clientHeightM={client.height_m}
            actionUrl="/api/assessments/valoracion_edit"
            submitLabel="Guardar cambios"
            successRedirect={`/clients/${client.id}/assessments`}
            cancelHref={`/clients/${client.id}/assessments`}
            initialValues={initialValues}
        />
    </div>
</AppLayout>
