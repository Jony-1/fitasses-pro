---
import AppLayout from "../../../layouts/Layout.astro";
import EmptyState from "../../../components/ui/EmptyState.astro";
import ClientPageHeader from "../../../components/clients/ClientPageHeader.astro";
import ClientHeaderActions from "../../../components/clients/ClientHeaderActions.astro";
import ClientDeleteAction from "../../../components/clients/ClientDeleteAction.astro";
import ExerciseCard from "../../../components/exercises/ExerciseCard.astro";
import { sql } from "../../../lib/db/client";
import { getExerciseLibraryItem } from "../../../lib/utils/exercise-library";
import {
    ensureRoutineSchema,
    getActiveRoutineForClient,
    getRoutineCalendarForClient,
    getRoutineToday,
} from "../../../lib/utils/routines";
import { getClientByIdForUser } from "../../../lib/utils/client-profile";
import { canManageAssessments, canManageClients } from "../../../lib/auth/roles";
import { getClientTabs } from "../../../lib/utils/client-navigation";

type AttendanceTimeSlot = "morning" | "midday" | "night" | "other";
type AssignmentScope = "today" | "week" | "always";

type WeeklyRoutineOption = {
    id: number;
    name: string;
    objective: string | null;
    level: string | null;
};

const WEEKDAY_LABELS = [
    "Lunes",
    "Martes",
    "Miércoles",
    "Jueves",
    "Viernes",
    "Sábado",
    "Domingo",
];

function getAttendanceTimeSlotLabel(timeSlot: AttendanceTimeSlot | null) {
    switch (timeSlot) {
        case "morning":
            return "Mañana";
        case "midday":
            return "Mediodía";
        case "night":
            return "Noche";
        case "other":
            return "Otro horario";
        default:
            return "Sin horario";
    }
}

const { id } = Astro.params;
const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login");
}

if (!["trainer", "admin", "client", "gym_manager"].includes(String(user.role))) {
    return Astro.redirect("/login?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const clientId = Number(id);
await ensureRoutineSchema();

const [client, activeRoutine, weeklyCalendar] = await Promise.all([
    getClientByIdForUser(clientId, user),
    getActiveRoutineForClient(clientId),
    getRoutineCalendarForClient(clientId),
]);

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const todayInfo = activeRoutine ? getRoutineToday(activeRoutine) : { day: null, dayIndex: null, label: "Sin rutina" };
const todayDay: any = todayInfo.day;
const todayExercises: any[] = todayDay?.exercises ?? [];
const routineDays: any[] = activeRoutine?.days ?? [];
const todayDayId = todayDay?.id ?? null;
const completedRoutineDays = routineDays.filter((day: any) => day.completed_at).length;
const currentAssignment = activeRoutine
    ? await sql`
        SELECT time_slot
             , scope
        FROM routine_assignments
        WHERE routine_id = ${activeRoutine.id}
          AND client_id = ${client.id}
          AND active = TRUE
        ORDER BY created_at DESC, id DESC
        LIMIT 1
      ` as Array<{ time_slot: AttendanceTimeSlot | null; scope: AssignmentScope | null }>
    : [];
const preferredTimeSlot = currentAssignment[0]?.time_slot ?? null;
const preferredScope = currentAssignment[0]?.scope ?? "always";
const isClientView = user.role === "client";
const hasAssignedTrainer = typeof client.trainer_id === "number" && client.trainer_id > 0;
const canManageClient = canManageClients(user.role);
const canManageClientAssessments = canManageAssessments(user.role);
const canManageCalendar = canManageClient || (isClientView && !hasAssignedTrainer);
const canViewExercises = true;
const trainingHref = `/clients/${client.id}/routine/train`;
const status = Astro.url.searchParams.get("status");
const message = Astro.url.searchParams.get("message") ?? "";
const successMessage = status === "success" ? message || "Cambios guardados correctamente." : "";
const weeklyEntries = WEEKDAY_LABELS.map((label, index) => ({
    label,
    weekday: index + 1,
    entry: weeklyCalendar.find((item: { weekday: number }) => item.weekday === index + 1) ?? null,
}));
const availableWeeklyRoutines: WeeklyRoutineOption[] = canManageCalendar && user.role !== "client"
    ? await sql`
        SELECT r.id, r.name, r.objective, r.level
        FROM routines r
        LEFT JOIN users owner ON owner.id = r.trainer_id
        WHERE r.is_template = TRUE
          AND r.active = TRUE
          ${user.role === "trainer" ? sql`AND r.trainer_id = ${user.id}` : user.role === "gym_manager" ? sql`AND owner.gym_id = ${user.gymId}` : sql``}
        ORDER BY r.name ASC, r.id DESC
      ` as WeeklyRoutineOption[]
    : [];

function getExerciseDetailsHref(exercise: any) {
    const libraryItem = getExerciseLibraryItem(exercise.exercise_key ?? exercise.name);

    return `/exercises/${libraryItem?.key ?? exercise.exercise_key ?? exercise.name}`;
}
---

<AppLayout title={`Rutina - ${client.full_name}`}>
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        {successMessage && (
            <div class="mb-6 rounded-3xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm dark:border-emerald-900/40 dark:bg-emerald-950/20">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-700 dark:text-emerald-300">Actualización guardada</p>
                <h2 class="mt-2 text-xl font-bold text-emerald-950 dark:text-emerald-100">{successMessage}</h2>
            </div>
        )}

        <ClientPageHeader
            title={client.full_name}
            description="Rutina simple para el cliente y calendario semanal claro para quien la gestiona."
            accent="emerald"
            tabs={getClientTabs(client.id, "routine")}
        >
            <ClientHeaderActions slot="actions" clientId={client.id} canManageClient={canManageClient} canManageAssessments={canManageClientAssessments} activeView="routine" />
        </ClientPageHeader>

        <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-6">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <div>
                    <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600 dark:text-emerald-400">Calendario semanal</p>
                    <h2 class="mt-2 text-2xl font-bold text-slate-900 dark:text-slate-100">Plan semanal del cliente</h2>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                        {hasAssignedTrainer
                            ? "El entrenador decide qué rutina toca cada día. El cliente solo ve lo que corresponde hoy."
                            : "Como no hay entrenador asignado, este cliente puede organizar su propia semana cuando existan rutinas disponibles."}
                    </p>
                </div>

                <div class="flex flex-wrap gap-2 text-xs font-semibold text-slate-500 dark:text-slate-400 md:max-w-sm md:justify-end">
                    <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800">{weeklyCalendar.length} días configurados</span>
                    {activeRoutine && <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800">Hoy: {activeRoutine.name}</span>}
                </div>
            </div>

            {canManageCalendar && availableWeeklyRoutines.length > 0 ? (
                <form method="POST" action="/api/routines/weekly-schedule" class="mt-5 space-y-4">
                    <input type="hidden" name="client_id" value={client.id} />

                    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                        {weeklyEntries.map(({ label, weekday, entry }) => (
                            <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/60">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Día {weekday}</p>
                                        <h3 class="mt-1 text-lg font-bold text-slate-900 dark:text-slate-100">{label}</h3>
                                    </div>
                                    {entry && <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800 dark:bg-emerald-500/20 dark:text-emerald-200">Activo</span>}
                                </div>

                                <label class="mt-4 block space-y-2">
                                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Rutina asignada</span>
                                    <select name={`weekday_${weekday}`} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                        <option value="">Descanso / sin rutina</option>
                                        {availableWeeklyRoutines.map((routine) => (
                                            <option value={routine.id} selected={entry?.routine_id === routine.id}>
                                                {routine.name}{routine.level ? ` · ${routine.level}` : ""}
                                            </option>
                                        ))}
                                    </select>
                                </label>

                                <label class="mt-3 block space-y-2">
                                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Nota del día</span>
                                    <input name={`notes_${weekday}`} value={entry?.notes ?? ""} placeholder="Brazo suave, movilidad, descarga..." class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100" />
                                </label>

                                {entry && (
                                    <div class="mt-3 rounded-2xl bg-white p-3 text-sm dark:bg-slate-900">
                                        <p class="font-semibold text-slate-900 dark:text-slate-100">{entry.routine_name}</p>
                                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{entry.days_total} días · {entry.exercises_total} ejercicios</p>
                                    </div>
                                )}
                            </div>
                        ))}
                    </div>

                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-2xl bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-900 hover:bg-emerald-300 sm:w-auto">
                        Guardar calendario semanal
                    </button>
                </form>
            ) : (
                <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                    {weeklyEntries.map(({ label, entry }) => (
                        <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/60">
                            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">{label}</p>
                            <p class="mt-2 text-lg font-bold text-slate-900 dark:text-slate-100">{entry?.routine_name ?? "Descanso"}</p>
                            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{entry?.notes ?? entry?.routine_objective ?? "Sin rutina asignada para este día."}</p>
                        </div>
                    ))}
                </div>
            )}
        </section>

        {!activeRoutine ? (
            <div class="mt-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <EmptyState
                    title="Sin rutina para hoy"
                    description="Configura el calendario semanal o deja una rutina activa para que el cliente vea la sesión del día aquí."
                />

                {canManageClient && (
                    <div class="mt-4 flex flex-wrap gap-3">
                        <a href="/routines" class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 transition hover:bg-emerald-300">Asignar rutina</a>
                        <a href="/routines/new" class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">Crear rutina</a>
                    </div>
                )}
            </div>
        ) : (
            <section class="mt-6 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:p-6">
                <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                    <div>
                        <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600 dark:text-emerald-400">Rutina de hoy</p>
                        <h2 class="mt-2 text-2xl font-bold text-slate-900 dark:text-slate-100">{activeRoutine.name}</h2>
                        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                            {activeRoutine.objective ?? "Hoy toca cumplir tu sesión."}
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-2 text-xs font-semibold text-slate-500 dark:text-slate-400 md:max-w-sm md:justify-end">
                        <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800">{routineDays.length} días</span>
                        <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800">{completedRoutineDays} completados</span>
                        <span class="rounded-full bg-slate-100 px-3 py-1 dark:bg-slate-800">{todayInfo.label}</span>
                    </div>
                </div>

                {canManageClient && currentAssignment.length > 0 && (
                    <form method="POST" action="/api/routines/unassign" class="mt-4">
                        <input type="hidden" name="routine_id" value={activeRoutine.id} />
                        <input type="hidden" name="client_id" value={client.id} />
                        <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl border border-red-300 px-4 py-2.5 text-sm font-semibold text-red-600 transition hover:bg-red-50 dark:border-red-900/50 dark:text-red-300 dark:hover:bg-red-950/30 sm:w-auto">
                            Quitar rutina activa del usuario
                        </button>
                    </form>
                )}

                {isClientView && activeRoutine && currentAssignment.length > 0 && (
                    <div class="mt-4 rounded-3xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/60">
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Preferencia temporal</p>
                                <p class="mt-1 text-sm font-semibold text-slate-900 dark:text-slate-100">
                                    {preferredScope === "today" ? "Solo hoy" : preferredScope === "week" ? "Esta semana" : "Siempre"}
                                </p>
                            </div>
                            <a href="#attendance-form" class="rounded-xl border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-white dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-900">Cambiar</a>
                        </div>

                        <form method="POST" action="/api/routines/preference" class="mt-4 grid gap-3 sm:grid-cols-[1fr_1fr_auto]">
                            <input type="hidden" name="routine_id" value={activeRoutine.id} />
                            <input type="hidden" name="client_id" value={client.id} />
                            <label class="block space-y-2">
                                <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Duración</span>
                                <select name="scope" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                    <option value="always" selected={preferredScope === "always"}>Siempre</option>
                                    <option value="week" selected={preferredScope === "week"}>Esta semana</option>
                                    <option value="today" selected={preferredScope === "today"}>Solo hoy</option>
                                </select>
                            </label>

                            <label class="block space-y-2">
                                <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Horario (opcional)</span>
                                <select name="time_slot" class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                    <option value="">Sin definir</option>
                                    <option value="morning" selected={preferredTimeSlot === "morning"}>Mañana</option>
                                    <option value="midday" selected={preferredTimeSlot === "midday"}>Mediodía</option>
                                    <option value="night" selected={preferredTimeSlot === "night"}>Noche</option>
                                    <option value="other" selected={preferredTimeSlot === "other"}>Otro horario</option>
                                </select>
                            </label>

                            <button type="submit" class="w-full rounded-2xl bg-slate-900 px-4 py-3 text-sm font-bold text-white hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200 sm:w-auto sm:self-end">
                                Guardar horario
                            </button>
                        </form>
                    </div>
                )}

                {todayDay ? (
                    <div class="mt-5 rounded-3xl border border-emerald-200 bg-emerald-50 p-4 dark:border-emerald-900/40 dark:bg-emerald-950/20">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-300">Hoy</p>
                                <h3 class="mt-2 text-xl font-bold text-emerald-950 dark:text-emerald-100">{todayDay.title}</h3>
                                <p class="mt-1 text-sm text-emerald-800/80 dark:text-emerald-200/80">{todayDay.focus ?? "Sesión del día"}</p>
                            </div>

                            <a href={trainingHref} class="inline-flex w-full items-center justify-center rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200 sm:w-auto">
                                Entrenar hoy
                            </a>
                        </div>

                        {todayExercises.length > 0 && canViewExercises && (
                            <div class="mt-4 rounded-2xl border border-slate-200 bg-white/60 p-4 dark:border-slate-800 dark:bg-slate-950/40">
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Ejercicios del día</p>
                                <div class="mt-3 flex flex-wrap gap-2">
                                    {todayExercises.slice(0, 6).map((exercise: any) => (
                                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-800 dark:text-slate-200">{exercise.name}</span>
                                    ))}
                                </div>
                                {todayExercises.length > 6 && <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">+ {todayExercises.length - 6} más</p>}
                            </div>
                        )}

                        {isClientView && todayDayId && (
                            <form id="attendance-form" method="POST" action="/api/routines/attendance" class="mt-4 space-y-3 rounded-2xl border border-slate-200 bg-white/60 p-4 dark:border-slate-800 dark:bg-slate-950/40">
                                <input type="hidden" name="routine_day_id" value={todayDayId} />
                                <input type="hidden" name="client_id" value={client.id} />

                                <label class="block text-xs font-semibold text-slate-500 dark:text-slate-400">
                                    Horario
                                    <select name="time_slot" class="mt-1 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100">
                                        <option value="morning" selected={preferredTimeSlot === "morning"}>Mañana</option>
                                        <option value="midday" selected={preferredTimeSlot === "midday"}>Mediodía</option>
                                        <option value="night" selected={preferredTimeSlot === "night"}>Noche</option>
                                        <option value="other" selected={preferredTimeSlot === "other"}>Otro horario</option>
                                    </select>
                                </label>

                                <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                                    <button type="submit" name="status" value="going" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 transition hover:bg-emerald-300 sm:w-auto">
                                        Voy a asistir
                                    </button>

                                    <button type="submit" name="status" value="not_going" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">
                                        No voy a asistir
                                    </button>
                                </div>
                            </form>
                        )}
                    </div>
                ) : (
                    <div class="mt-5">
                        <EmptyState title="Sin día activo" description="Hay calendario semanal, pero hoy no tiene una rutina asignada." />
                    </div>
                )}

                <details id="routine-details" class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/60">
                    <summary class="cursor-pointer list-none text-sm font-semibold text-slate-700 dark:text-slate-200">
                        {isClientView ? "Ver plan completo" : "Ver días de la rutina"}
                    </summary>

                    <div class="mt-4 space-y-3">
                        {routineDays.map((day: any) => (
                            <div class:list={[
                                "rounded-2xl border p-4",
                                day.id === todayDayId
                                    ? "border-emerald-300 bg-emerald-50/70 dark:border-emerald-800 dark:bg-emerald-950/20"
                                    : "border-slate-200 bg-white dark:border-slate-800 dark:bg-slate-900",
                            ]}>
                                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                                    <div>
                                        <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Día {day.day_number}</p>
                                        <p class="mt-1 font-bold text-slate-900 dark:text-slate-100">{day.title}</p>
                                        {day.focus && <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{day.focus}</p>}
                                    </div>

                                    <div class="flex flex-wrap gap-2">
                                        {day.id === todayDayId && <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-800 dark:bg-emerald-500/20 dark:text-emerald-200">Hoy</span>}
                                        <span class:list={[
                                            "rounded-full px-3 py-1 text-xs font-semibold",
                                            day.completed_at
                                                ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"
                                                : "bg-amber-50 text-amber-700 dark:bg-amber-500/10 dark:text-amber-300",
                                        ]}>
                                            {day.completed_at ? "Completado" : "Pendiente"}
                                        </span>

                                        {day.attendance_status && (
                                            <span class:list={[
                                                "rounded-full px-3 py-1 text-xs font-semibold",
                                                day.attendance_status === "going"
                                                    ? "bg-sky-50 text-sky-700 dark:bg-sky-500/10 dark:text-sky-300"
                                                    : "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300",
                                            ]}>
                                                {day.attendance_status === "going" ? "Asistirá" : "No asistirá"}
                                            </span>
                                        )}

                                        {day.attendance_time_slot && (
                                            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-300">
                                                {getAttendanceTimeSlotLabel(day.attendance_time_slot)}
                                            </span>
                                        )}
                                    </div>
                                </div>

                                <div class="mt-3 space-y-2">
                                    {day.exercises.map((exercise: any) => (
                                        <ExerciseCard exercise={exercise} compact detailsHref={getExerciseDetailsHref(exercise)} />
                                    ))}
                                </div>
                            </div>
                        ))}
                    </div>
                </details>
            </section>
        )}

        {canManageClient && <ClientDeleteAction clientId={client.id} />}
    </div>
</AppLayout>
