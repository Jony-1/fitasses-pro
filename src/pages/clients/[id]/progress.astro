---
import AppLayout from "../../../layouts/layout.astro";
import ClientProgressSummary from "../../../components/clients/ClientProgressSummary.astro";
import ClientProgressCharts from "../../../components/clients/ClientProgressCharts.astro";
import ClientSummaryCard from "../../../components/clients/ClientSummaryCard.astro";
import ClientPageHeader from "../../../components/clients/ClientPageHeader.astro";
import { getClientByIdForUser, getProgressHistory } from "../../../lib/utils/client-profile";
import { getClientProgressSummary } from "../../../lib/utils/client-progress";

type ClientDetails = {
    id: number;
    full_name: string;
    gender: string | null;
    birth_date: string | null;
    height_m: string | number | null;
    created_at: string | Date;
    notes: string | null;
};

type AssessmentSummary = {
    weight_kg: number | null;
    body_fat_pct: number | null;
    muscle_pct: number | null;
    bmi: number | null;
};

const { id } = Astro.params;
const user = Astro.locals.user;
const canManageClient = user?.role === "trainer" || user?.role === "admin";

if (!user) {
    return Astro.redirect("/login");
}

if (!["trainer", "admin", "client"].includes(String(user.role))) {
    return Astro.redirect("/login?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const clientId = Number(id);
const [clientRow, progressSummary, progressHistory] = await Promise.all([
    getClientByIdForUser(clientId, user),
    getClientProgressSummary(clientId),
    getProgressHistory(clientId),
]);

const client = clientRow as ClientDetails | null;

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const {
    latestAssessment,
    totalAssessments,
    weightChange,
    bodyFatChange,
    muscleChange,
} = progressSummary;

const summaryLatestAssessment = latestAssessment as AssessmentSummary | null;
const canManageAssessments = user?.role === "trainer" || user?.role === "admin";
const positiveChanges = [
    weightChange !== null && weightChange < 0 ? "Peso a la baja" : null,
    bodyFatChange !== null && bodyFatChange < 0 ? "Grasa corporal a la baja" : null,
    muscleChange !== null && muscleChange > 0 ? "Masa muscular al alza" : null,
].filter(Boolean) as string[];
---

<AppLayout title={`Progreso - ${client.full_name}`}>
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <ClientPageHeader
            title={client.full_name}
            description={`Cliente #${client.id}`}
            accent="sky"
            tabs={[
                { href: `/clients/${client.id}/routine`, label: "Mi rutina" },
                { href: `/clients/${client.id}/progress`, label: "Mi progreso", active: true },
                { href: `/clients/${client.id}/assessments`, label: "Valoraciones" },
            ]}
        >
            {canManageClient && (
                <a slot="actions" href={`/clients/${client.id}/edit`} class="inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/20 px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-white/30">
                    Editar cliente
                </a>
            )}

            {canManageClient && (
                <button slot="actions" type="button" id="delete-client" class="inline-flex items-center justify-center rounded-xl border border-red-300/60 bg-red-500/10 px-4 py-2.5 text-sm font-semibold text-red-950 transition hover:bg-red-500/20">
                    Eliminar cliente
                </button>
            )}

            <a slot="actions" href={`/clients/${client.id}/routine`} class="inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/20 px-4 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-white/30">
                Mi rutina
            </a>

            <a slot="actions" href={`/clients/${client.id}/assessments`} class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-slate-900">
                Valoraciones
            </a>

            {canManageAssessments && (
                <a
                    slot="actions"
                    href={`/clients/${client.id}/assessments/valoration_new`}
                    class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-2.5 text-sm font-bold text-white shadow-lg shadow-emerald-500/25 transition hover:bg-emerald-600 sm:w-auto"
                >
                    + Nueva valoración
                </a>
            )}
        </ClientPageHeader>

        <div class="mb-6 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
            <div class="rounded-3xl border border-sky-200 bg-sky-50 p-5 shadow-sm dark:border-sky-900/40 dark:bg-sky-950/20">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 dark:text-sky-300">Lectura rápida</p>
                <h2 class="mt-2 text-xl font-bold text-sky-950 dark:text-sky-100">Así se ve el avance del cliente</h2>
                <p class="mt-2 text-sm text-sky-800 dark:text-sky-200">
                    {summaryLatestAssessment
                        ? `Última valoración registrada con ${totalAssessments} mediciones acumuladas. Este es el mejor lugar para cerrar, mostrando resultados.`
                        : "Aún no hay una valoración registrada. Cuando la haya, aquí verás el resumen del avance físico."}
                </p>

                {positiveChanges.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {positiveChanges.map((item) => (
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-sky-800 shadow-sm dark:bg-sky-900/40 dark:text-sky-100">{item}</span>
                        ))}
                    </div>
                )}
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600 dark:text-emerald-400">Siguiente acción</p>
                <h2 class="mt-2 text-xl font-bold text-slate-900 dark:text-slate-100">Mantén el flujo activo</h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Después de revisar el progreso puedes volver a la rutina del día o registrar una nueva valoración para seguir comparando resultados.</p>
                <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                    <a href={`/clients/${client.id}/routine`} class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
                        Ver rutina de hoy
                    </a>
                    {canManageAssessments && (
                        <a href={`/clients/${client.id}/assessments/valoration_new`} class="inline-flex items-center justify-center rounded-xl border border-emerald-300 px-4 py-2.5 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50 dark:border-emerald-800 dark:text-emerald-300 dark:hover:bg-emerald-950/30">
                            Registrar valoración
                        </a>
                    )}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <ClientSummaryCard client={client as any} />

            <div class="lg:col-span-2 space-y-6">
                <ClientProgressSummary
                    totalAssessments={totalAssessments}
                    latestAssessment={summaryLatestAssessment}
                    weightChange={weightChange}
                    bodyFatChange={bodyFatChange}
                    muscleChange={muscleChange}
                />

                <ClientProgressCharts progressHistory={progressHistory} />
            </div>
        </div>

        {canManageClient && (
            <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-950/70 p-4 backdrop-blur-sm">
                <div class="w-full max-w-md rounded-3xl border border-slate-800 bg-slate-950 p-6 shadow-2xl">
                    <h3 class="text-xl font-bold text-slate-100">Eliminar cliente</h3>
                    <p class="mt-2 text-sm text-slate-400">Esta acción eliminará al cliente y no se puede deshacer.</p>

                    <div class="mt-6 flex justify-end gap-3">
                        <button id="cancel-delete" type="button" class="rounded-xl border border-slate-700 px-4 py-2.5 text-sm font-semibold text-slate-200 hover:bg-slate-900">Cancelar</button>
                        <button id="confirm-delete" type="button" data-client-id={client.id} class="rounded-xl bg-red-500 px-4 py-2.5 text-sm font-bold text-white hover:bg-red-600">Eliminar cliente</button>
                    </div>
                </div>
            </div>
        )}
    </div>
</AppLayout>

<script>
    const deleteBtn = document.getElementById("delete-client") as HTMLButtonElement | null;
    const modal = document.getElementById("delete-modal") as HTMLDivElement | null;
    const cancelBtn = document.getElementById("cancel-delete") as HTMLButtonElement | null;
    const confirmBtn = document.getElementById("confirm-delete") as HTMLButtonElement | null;

    if (deleteBtn && modal && cancelBtn && confirmBtn) {
        const closeModal = () => {
            modal.classList.add("hidden");
            modal.classList.remove("flex");
        };

        deleteBtn.addEventListener("click", () => {
            modal.classList.remove("hidden");
            modal.classList.add("flex");
        });

        cancelBtn.addEventListener("click", closeModal);
        modal.addEventListener("click", (event) => {
            if (event.target === modal) closeModal();
        });

        confirmBtn.addEventListener("click", async () => {
            const button = confirmBtn as HTMLButtonElement;
            const clientId = confirmBtn.dataset.clientId;
            if (!clientId) return;

            try {
                button.textContent = "Eliminando...";
                button.disabled = true;

                await fetch(`/api/clients/${clientId}`, { method: "DELETE", headers: { Accept: "application/json" } });
                window.location.href = "/clients";
            } catch {
                button.textContent = "Eliminar cliente";
                button.disabled = false;
            }
        });
    }
</script>
