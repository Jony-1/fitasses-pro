---
import AppLayout from "../../../layouts/Layout.astro";
import ClientProgressSummary from "../../../components/clients/ClientProgressSummary.astro";
import ClientProgressCharts from "../../../components/clients/ClientProgressCharts.astro";
import ClientSummaryCard from "../../../components/clients/ClientSummaryCard.astro";
import ClientPageHeader from "../../../components/clients/ClientPageHeader.astro";
import ClientHeaderActions from "../../../components/clients/ClientHeaderActions.astro";
import ClientDeleteAction from "../../../components/clients/ClientDeleteAction.astro";
import { getClientByIdForUser, getProgressHistory } from "../../../lib/utils/client-profile";
import { getClientProgressSummary } from "../../../lib/utils/client-progress";
import { canManageAssessments, canManageClients } from "../../../lib/auth/roles";
import { getClientTabs } from "../../../lib/utils/client-navigation";

type ClientDetails = {
    id: number;
    full_name: string;
    gender: string | null;
    birth_date: string | null;
    height_m: string | number | null;
    created_at: string | Date;
    notes: string | null;
};

type AssessmentSummary = {
    weight_kg: number | null;
    body_fat_pct: number | null;
    muscle_pct: number | null;
    bmi: number | null;
};

const { id } = Astro.params;
const user = Astro.locals.user;

if (!user) {
    return Astro.redirect("/login");
}

const canManageClient = canManageClients(user.role);

if (!["trainer", "admin", "client", "gym_manager"].includes(String(user.role))) {
    return Astro.redirect("/login?error=forbidden");
}

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const clientId = Number(id);
const [clientRow, progressSummary, progressHistory] = await Promise.all([
    getClientByIdForUser(clientId, user),
    getClientProgressSummary(clientId),
    getProgressHistory(clientId),
]);

const client = clientRow as ClientDetails | null;

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const {
    latestAssessment,
    totalAssessments,
    weightChange,
    bodyFatChange,
    muscleChange,
} = progressSummary;

const summaryLatestAssessment = latestAssessment as AssessmentSummary | null;
const canManageClientAssessments = canManageAssessments(user.role);
const positiveChanges = [
    weightChange !== null && weightChange < 0 ? "Peso a la baja" : null,
    bodyFatChange !== null && bodyFatChange < 0 ? "Grasa corporal a la baja" : null,
    muscleChange !== null && muscleChange > 0 ? "Masa muscular al alza" : null,
].filter(Boolean) as string[];
---

<AppLayout title={`Progreso - ${client.full_name}`}>
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <ClientPageHeader
            title={client.full_name}
            description={`Cliente #${client.id}`}
            accent="sky"
            tabs={getClientTabs(client.id, "progress")}
        >
            <ClientHeaderActions slot="actions" clientId={client.id} canManageClient={canManageClient} canManageAssessments={canManageClientAssessments} activeView="progress" />
        </ClientPageHeader>

        <div class="mb-6 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
            <div class="rounded-3xl border border-sky-200 bg-sky-50 p-5 shadow-sm dark:border-sky-900/40 dark:bg-sky-950/20">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 dark:text-sky-300">Lectura rápida</p>
                <h2 class="mt-2 text-xl font-bold text-sky-950 dark:text-sky-100">Así se ve el avance del cliente</h2>
                <p class="mt-2 text-sm text-sky-800 dark:text-sky-200">
                    {summaryLatestAssessment
                        ? `Última valoración registrada con ${totalAssessments} mediciones acumuladas. Este es el mejor lugar para cerrar, mostrando resultados.`
                        : "Aún no hay una valoración registrada. Cuando la haya, aquí verás el resumen del avance físico."}
                </p>

                {positiveChanges.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                        {positiveChanges.map((item) => (
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-sky-800 shadow-sm dark:bg-sky-900/40 dark:text-sky-100">{item}</span>
                        ))}
                    </div>
                )}
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-emerald-600 dark:text-emerald-400">Siguiente acción</p>
                <h2 class="mt-2 text-xl font-bold text-slate-900 dark:text-slate-100">Mantén el flujo activo</h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">Después de revisar el progreso puedes volver a la rutina del día o registrar una nueva valoración para seguir comparando resultados.</p>
                <div class="mt-4 flex flex-col gap-3 sm:flex-row">
                    <a href={`/clients/${client.id}/routine`} class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200">
                        Ver rutina de hoy
                    </a>
                    {canManageClientAssessments && (
                        <a href={`/clients/${client.id}/assessments/valoracion_new`} class="inline-flex items-center justify-center rounded-xl border border-emerald-300 px-4 py-2.5 text-sm font-semibold text-emerald-700 transition hover:bg-emerald-50 dark:border-emerald-800 dark:text-emerald-300 dark:hover:bg-emerald-950/30">
                            Registrar valoración
                        </a>
                    )}
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <ClientSummaryCard client={client} />

            <div class="lg:col-span-2 space-y-6">
                <ClientProgressSummary
                    totalAssessments={totalAssessments}
                    latestAssessment={summaryLatestAssessment}
                    weightChange={weightChange}
                    bodyFatChange={bodyFatChange}
                    muscleChange={muscleChange}
                />

                <ClientProgressCharts progressHistory={progressHistory} />
            </div>
        </div>

        {canManageClient && <ClientDeleteAction clientId={client.id} />}
    </div>
</AppLayout>
