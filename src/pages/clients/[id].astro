---
import AppLayout from "../../layouts/layout.astro";
import { sql } from "../../lib/db/client";
import { formatDateOnly } from "../../lib/utils/date";
import { setupClientDelete } from "../../lib/utils/client-delete";

const { id } = Astro.params;

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const result = await sql`
  SELECT id, full_name, birth_date, height_m, notes, created_at
  FROM clients
  WHERE id = ${Number(id)}
  LIMIT 1
`;

const client = result[0];

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

function formatDateTime(value: unknown) {
    if (!value) return "-";

    const date = value instanceof Date ? value : new Date(String(value));

    if (Number.isNaN(date.getTime())) return "-";

    return date.toLocaleDateString("es-CO");
}

const createdAtFormatted = formatDateTime(client.created_at);
---

<AppLayout title={`Cliente #${client.id}`}>
    <div class="mx-auto max-w-5xl">
        <div class="mb-6 flex items-center justify-between gap-4">
            <div>
                <a
                    href="/clients"
                    class="text-sm font-medium text-slate-500 hover:text-emerald-600"
                >
                    ← Volver a clientes
                </a>

                <h1 class="mt-2 text-3xl font-bold tracking-tight">
                    {client.full_name}
                </h1>

                <div class="mt-4 flex flex-wrap gap-3">
                    <a
                        href={`/clients/${client.id}/edit`}
                        class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50"
                    >
                        Editar cliente
                    </a>

                    <button
                        id="delete-client"
                        type="button"
                        class="rounded-lg bg-red-600 px-4 py-2 text-sm font-bold text-white hover:bg-red-700"
                    >
                        Eliminar cliente
                    </button>
                </div>
            </div>

            <div class="flex flex-wrap gap-3">
                <a
                    href={`/clients/${client.id}/assessments/valoration_new`}
                    class="inline-flex items-center rounded-lg bg-emerald-400 px-4 py-2 text-sm font-bold text-slate-900 hover:bg-emerald-300"
                >
                    + Nueva valoración
                </a>

                <a
                    href={`/clients/${client.id}/assessments`}
                    class="inline-flex items-center rounded-lg bg-blue-400 px-4 py-2 text-sm font-bold text-slate-900 hover:bg-blue-300"
                >
                    Ver valoraciones
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-1">
                <h2 class="mb-4 text-lg font-bold">Datos del cliente</h2>

                <dl class="space-y-4">
                    <div>
                        <dt class="text-sm font-semibold text-slate-500">ID</dt>
                        <dd class="mt-1 text-base font-medium text-slate-900">
                            {client.id}
                        </dd>
                    </div>

                    <div>
                        <dt class="text-sm font-semibold text-slate-500">Nombre</dt>
                        <dd class="mt-1 text-base font-medium text-slate-900">
                            {client.full_name}
                        </dd>
                    </div>

                    <div>
                        <dt class="text-sm font-semibold text-slate-500">Fecha de nacimiento</dt>
                        <dd class="mt-1 text-base text-slate-700">
                            {formatDateOnly(client.birth_date)}
                        </dd>
                    </div>

                    <div>
                        <dt class="text-sm font-semibold text-slate-500">Altura</dt>
                        <dd class="mt-1 text-base text-slate-700">
                            {client.height_m ? `${client.height_m} m` : "-"}
                        </dd>
                    </div>

                    <div>
                        <dt class="text-sm font-semibold text-slate-500">Fecha de registro</dt>
                        <dd class="mt-1 text-base text-slate-700">
                            {createdAtFormatted}
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-bold">Observaciones generales</h2>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                        MVP
                    </span>
                </div>

                <div class="rounded-lg border border-slate-100 bg-slate-50 p-4">
                    {
                        client.notes ? (
                            <p class="leading-7 text-slate-700">{client.notes}</p>
                        ) : (
                            <p class="text-slate-500">
                                Este cliente no tiene observaciones registradas todavía.
                            </p>
                        )
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL -->
    <div id="delete-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-4">
        <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
            <h3 class="text-lg font-bold text-slate-900">Eliminar cliente</h3>

            <p class="mt-2 text-sm text-slate-600">
                Estás a punto de eliminar este cliente.
            </p>

            <p class="mt-2 text-sm font-medium text-red-600">
                Esta acción no se puede deshacer.
            </p>

            <div class="mt-6 flex justify-end gap-3">
                <button
                    id="cancel-delete"
                    type="button"
                    class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
                >
                    Cancelar
                </button>

                <button
                    id="confirm-delete"
                    type="button"
                    data-client-id={client.id}
                    class="rounded-lg bg-red-600 px-4 py-2 text-sm font-bold text-white hover:bg-red-700"
                >
                    Eliminar cliente
                </button>
            </div>
        </div>
    </div>

<script>
    import { setupClientDelete } from "../../lib/utils/client-delete";

    setupClientDelete();
</script>

</AppLayout>