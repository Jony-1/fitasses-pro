---
import AppLayout from "../../layouts/layout.astro";
import { formatDateOnly, formatDateTimeLocal } from "../../lib/utils/date";
import { calculateAge } from "../../lib/utils/age";
import {
    genderEmoji,
    formatMetric,
    formatChange,
    changeColor,
} from "../../lib/utils/client";
import ClientProgressCharts from "../../components/clients/ClientProgressCharts.astro";
import {
    getClientById,
    getProgressHistory,
} from "../../lib/utils/client-profile";
import { getClientProgressSummary } from "../../lib/utils/client-progress";

const { id } = Astro.params;

if (!id || Number.isNaN(Number(id))) {
    return Astro.redirect("/clients");
}

const clientId = Number(id);
const client = await getClientById(clientId);

if (!client) {
    return new Response("Cliente no encontrado", { status: 404 });
}

const age = calculateAge(client.birth_date);

const createdAtFormatted = formatDateTimeLocal(client.created_at);

const {
    latestAssessment,
    firstAssessment,
    totalAssessments,
    weightChange,
    bodyFatChange,
    muscleChange,
} = await getClientProgressSummary(clientId);

const progressHistory = await getProgressHistory(Number(id));
const user = Astro.locals.user;
const isTrainer = user?.role === "trainer";
---

<AppLayout title={`Cliente #${client.id}`}>
    <div class="mx-auto max-w-5xl">
        <div class="mb-6 flex items-center justify-between gap-4">
            <div>
                {
                    isTrainer && (
                        <>
                            <a
                                href="/clients"
                                class="text-sm font-medium text-slate-500 hover:text-emerald-600"
                            >
                                ← Volver a clientes
                            </a>
                        </>
                    )
                }

                <h1 class="mt-2 text-3xl font-bold tracking-tight">
                    {client.full_name}
                </h1>

                <div class="mt-4 flex flex-wrap gap-3">
                    {
                        isTrainer && (
                            <>
                                <a
                                    href={`/clients/${client.id}/edit`}
                                    class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-bold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
                                >
                                    Editar cliente
                                </a>

                                <button
                                    id="delete-client"
                                    type="button"
                                    class="rounded-lg bg-red-600 px-4 py-2 text-sm font-bold text-white hover:bg-red-700"
                                >
                                    Eliminar cliente
                                </button>
                            </>
                        )
                    }
                </div>
            </div>

            <div class="flex flex-wrap gap-3">
                {
                    isTrainer && (
                        <>
                            <a
                                href={`/clients/${client.id}/assessments/valoration_new`}
                                class="inline-flex items-center rounded-lg bg-emerald-400 px-4 py-2 text-sm font-bold text-slate-900 hover:bg-emerald-300 dark:bg-emerald-600 dark:text-slate-100 dark:hover:bg-emerald-500"
                            >
                                + Nueva valoración
                            </a>
                        </>
                    )
                }

                <a
                    href={`/clients/${client.id}/assessments`}
                    class="inline-flex items-center rounded-lg bg-blue-400 px-4 py-2 text-sm font-bold text-slate-900 hover:bg-blue-300 dark:bg-blue-600 dark:text-slate-100 dark:hover:bg-blue-500"
                >
                    Ver valoraciones
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            <div
                class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-1 dark:border-slate-800 dark:bg-slate-900"
            >
                <h2 class="mb-4 text-lg font-bold">Datos del cliente</h2>

                <dl class="space-y-4">
                    <div>
                        <dt class="text-sm font-semibold text-slate-500">ID</dt>
                        <dd
                            class="mt-1 text-base font-medium text-slate-900 dark:text-slate-100"
                        >
                            {client.id}
                        </dd>
                    </div>

                    <div>
                        <dt
                            class="text-sm font-semibold text-slate-500 dark:text-slate-400"
                        >
                            Nombre
                        </dt>
                        <dd
                            class="mt-1 text-base font-medium text-slate-900 dark:text-slate-100"
                        >
                            {client.full_name}
                        </dd>
                    </div>
                    <div>
                        <dt
                            class="text-sm font-semibold text-slate-500 dark:text-slate-400"
                        >
                            Genero
                        </dt>
                        <dd
                            class="mt-1 text-base font-medium text-slate-900 dark:text-slate-100"
                        >
                            {genderEmoji(client.gender)}{" "}{client.gender}
                        </dd>
                    </div>

                    <div>
                        <dt
                            class="text-sm font-semibold text-slate-500 dark:text-slate-400"
                        >
                            Fecha de nacimiento
                        </dt>
                        <dd
                            class="mt-1 text-base text-slate-700 dark:text-slate-100"
                        >
                            {formatDateOnly(client.birth_date)}
                            <p
                                class="mt-1 text-base text-slate-700 dark:text-slate-400"
                            >
                                Edad: <strong>{age ?? "-"} años</strong>
                            </p>
                        </dd>
                    </div>

                    <div>
                        <dt
                            class="text-sm font-semibold text-slate-500 dark:text-slate-400"
                        >
                            Altura
                        </dt>
                        <dd
                            class="mt-1 text-base text-slate-700 dark:text-slate-100"
                        >
                            {client.height_m ? `${client.height_m} m` : "-"}
                        </dd>
                    </div>

                    <div>
                        <dt
                            class="text-sm font-semibold text-slate-500 dark:text-slate-400"
                        >
                            Fecha de registro
                        </dt>
                        <dd
                            class="mt-1 text-base text-slate-700 dark:text-slate-100"
                        >
                            {createdAtFormatted}
                        </dd>
                    </div>
                </dl>
            </div>

            <div
                class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2 dark:border-slate-800 dark:bg-slate-900"
            >
                <div class="mb-4 flex items-center justify-between">
                    <h2 class="text-lg font-bold">Observaciones generales</h2>
                    <span
                        class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-400"
                    >
                        cliente
                    </span>
                </div>

                <div class="rounded-lg border border-slate-100 bg-slate-50 p-4">
                    {
                        client.notes ? (
                            <p class="leading-7 text-slate-700">
                                {client.notes}
                            </p>
                        ) : (
                            <p class="text-slate-500">
                                Este cliente no tiene observaciones registradas
                                todavía.
                            </p>
                        )
                    }
                </div>
                <section class="mt-8">
                    <h2
                        class="text-xl font-bold text-slate-900 dark:text-slate-100"
                    >
                        Resumen de progreso
                    </h2>

                    <div
                        class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3"
                    >
                        <div
                            class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
                        >
                            <p
                                class="text-sm text-slate-500 dark:text-slate-400"
                            >
                                Total valoraciones
                            </p>
                            <p class="text-2xl font-bold">
                                {totalAssessments}
                            </p>
                        </div>

                        <div
                            class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
                        >
                            <p
                                class="text-sm text-slate-500 dark:text-slate-400"
                            >
                                Peso actual
                            </p>
                            <p class="text-2xl font-bold">
                                {
                                    formatMetric(
                                        latestAssessment?.weight_kg,
                                        " kg",
                                    )
                                }
                            </p>
                            <p class={`text-sm ${changeColor(weightChange)}`}>
                                Cambio: {formatChange(weightChange, " kg")}
                            </p>
                        </div>

                        <div
                            class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
                        >
                            <p
                                class="text-sm text-slate-500 dark:text-slate-400"
                            >
                                Grasa corporal
                            </p>
                            <p class="text-2xl font-bold">
                                {
                                    formatMetric(
                                        latestAssessment?.body_fat_pct,
                                        " %",
                                    )
                                }
                            </p>
                            <p class={`text-sm ${changeColor(weightChange)}`}>
                                Cambio: {formatChange(bodyFatChange, " %")}
                            </p>
                        </div>

                        <div
                            class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
                        >
                            <p
                                class="text-sm text-slate-500 dark:text-slate-400"
                            >
                                Masa muscular
                            </p>
                            <p class="text-2xl font-bold">
                                {
                                    formatMetric(
                                        latestAssessment?.muscle_pct,
                                        " %",
                                    )
                                }
                            </p>
                            <p class={`text-sm ${changeColor(weightChange)}`}>
                                Cambio: {formatChange(muscleChange, " %")}
                            </p>
                        </div>

                        <div
                            class="rounded-xl border border-slate-200 bg-white p-4 dark:border-slate-700 dark:bg-slate-800"
                        >
                            <p
                                class="text-sm text-slate-500 dark:text-slate-400"
                            >
                                IMC actual
                            </p>
                            <p class="text-2xl font-bold">
                                {formatMetric(latestAssessment?.bmi)}
                            </p>
                        </div>
                    </div>
                </section>
            </div>
        </div>
        <ClientProgressCharts progressHistory={progressHistory} />
    </div>
    <!-- MODAL -->
    <div
        id="delete-modal"
        class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 p-4"
    >
        <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
            <h3 class="text-lg font-bold text-slate-900">Eliminar cliente</h3>

            <p class="mt-2 text-sm text-slate-600">
                Estás a punto de eliminar este cliente.
            </p>

            <p class="mt-2 text-sm font-medium text-red-600">
                Esta acción no se puede deshacer.
            </p>

            <div class="mt-6 flex justify-end gap-3">
                <button
                    id="cancel-delete"
                    type="button"
                    class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
                >
                    Cancelar
                </button>

                <button
                    id="confirm-delete"
                    type="button"
                    data-client-id={client.id}
                    class="rounded-lg bg-red-600 px-4 py-2 text-sm font-bold text-white hover:bg-red-700"
                >
                    Eliminar cliente
                </button>
            </div>
        </div>
    </div>

    <script>
        import { setupClientDelete } from "../../lib/utils/client-delete";

        setupClientDelete();
    </script>
</AppLayout>
