---
import AppLayout from "../../../layouts/layout.astro";
import AuthNav from "../../../components/ui/AuthNav.astro";

const error = Astro.url.searchParams.get("error");
const status = Astro.url.searchParams.get("status");

const errorMessages: Record<string, string> = {
    missing_fields: "Completa todos los campos obligatorios.",
    invalid_name: "El nombre debe tener entre 3 y 120 caracteres.",
    invalid_email: "Ingresa un correo válido.",
    password_mismatch: "Las contraseñas no coinciden.",
    weak_password:
        "La contraseña debe tener al menos 4 caracteres, una mayúscula y un número.",
    email_exists: "Ese correo ya está registrado.",
    managed_only: "Las cuentas de entrenador se crean desde la administración del gimnasio.",
};

const errorMessage = error ? errorMessages[error] : null;
const infoMessage = status === "managed_only"
    ? "Las cuentas de entrenador ya no se crean directamente desde este formulario."
    : null;
---

<AppLayout title="Registro de entrenador">
    <div class="mx-auto max-w-2xl px-4 py-8 sm:py-10">
        <AuthNav
            items={[
                { href: "/login", label: "Iniciar sesión" },
                { href: "/register", label: "Registro" },
                { href: "/clients/register/client", label: "Cliente" },
                { href: "/clients/register/trainer", label: "Entrenador", active: true },
                { href: "/clients/register/gym-manager", label: "Gestor" },
            ]}
        />

        <div class="mb-6 text-center">
            <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">
                Acceso para entrenadores
            </h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">
                Las cuentas de entrenador se crean desde la administración del gimnasio para que queden asignadas al equipo correcto.
            </p>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-900/95 sm:p-8">
            {
                infoMessage && (
                    <div class="mb-4 rounded-xl border border-sky-200 bg-sky-50 px-4 py-3 text-sm text-sky-700 dark:border-sky-500/30 dark:bg-sky-500/10 dark:text-sky-300">
                        {infoMessage}
                    </div>
                )
            }

            {
                errorMessage && (
                    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300">
                        {errorMessage}
                    </div>
                )
            }

            <div class="space-y-5">
                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-950/70 dark:text-slate-400">
                    <p class="font-semibold text-slate-900 dark:text-slate-200">Cómo obtener acceso</p>
                    <ul class="mt-2 space-y-2">
                        <li>• Un administrador puede crear tu cuenta desde el panel administrativo.</li>
                        <li>• Un gestor de gimnasio puede darte acceso si perteneces a su sede.</li>
                        <li>• Cuando tu cuenta esté lista, solo tendrás que iniciar sesión.</li>
                    </ul>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
                    <a
                        href="/login"
                        class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-400 sm:w-auto"
                    >
                        Iniciar sesión
                    </a>
                    <a
                        href="/register"
                        class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto"
                    >
                        Volver
                    </a>
                </div>
            </div>
        </div>
    </div>
</AppLayout>
