---
import AppLayout from "../../../layouts/layout.astro";
import AuthNav from "../../../components/ui/AuthNav.astro";

const error = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
    missing_fields: "Completa todos los campos obligatorios.",
    invalid_name: "El nombre debe tener entre 3 y 120 caracteres.",
    invalid_email: "Ingresa un correo válido.",
    password_mismatch: "Las contraseñas no coinciden.",
    weak_password:
        "La contraseña debe tener al menos 8 caracteres, una mayúscula y un número.",
    email_exists: "Ese correo ya está registrado.",
    invalid_gym_code: "El código del gimnasio no es válido.",
    gym_not_found: "No encontramos un gimnasio con ese código.",
};

const errorMessage = error ? errorMessages[error] : null;
---

<AppLayout title="Registro de gym manager">
    <div class="mx-auto max-w-2xl px-4 py-8 sm:py-10">
        <AuthNav
            items={[
                { href: "/login", label: "Iniciar sesión" },
                { href: "/register", label: "Registro" },
                { href: "/clients/register/client", label: "Cliente" },
                { href: "/clients/register/trainer", label: "Trainer" },
                { href: "/clients/register/gym-manager", label: "Gym manager", active: true },
            ]}
        />

        <div class="mb-6 text-center">
            <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">
                Crear cuenta de gym manager
            </h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">
                Regístrate con el código de tu gimnasio para gestionar tus trainers y clientes.
            </p>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-900/95 sm:p-8">
            {
                errorMessage && (
                    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300">
                        {errorMessage}
                    </div>
                )
            }

            <form method="POST" action="/api/auth/register-gym-manager" class="space-y-5">
                <div>
                    <label for="name" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Nombre</label>
                    <input id="name" name="name" type="text" required minlength="3" maxlength="120" autocomplete="name" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Tu nombre o nombre profesional" />
                </div>

                <div>
                    <label for="email" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Correo electrónico</label>
                    <input id="email" name="email" type="email" required maxlength="160" autocomplete="email" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="ejemplo@correo.com" />
                </div>

                <div>
                    <label for="gym_code" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Código del gimnasio</label>
                    <input id="gym_code" name="gym_code" type="text" required maxlength="32" autocomplete="off" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Código de invitación" />
                </div>

                <div>
                    <label for="password" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Contraseña</label>
                    <input id="password" name="password" type="password" required minlength="8" maxlength="72" autocomplete="new-password" pattern="^(?=.*[A-Z])(?=.*\d).{8,72}$" title="Debe tener al menos 8 caracteres, una mayúscula y un número." class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Crea una contraseña con mayúscula y número" />
                </div>

                <div>
                    <label for="confirm_password" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200">Confirmar contraseña</label>
                    <input id="confirm_password" name="confirm_password" type="password" required minlength="8" maxlength="72" autocomplete="new-password" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" placeholder="Repite tu contraseña" />
                </div>

                <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-950/70 dark:text-slate-400">
                    <p class="font-semibold text-slate-900 dark:text-slate-200">Importante</p>
                    <p class="mt-1">El código del gimnasio lo entrega el administrador. Con él se asignará tu cuenta al gimnasio correcto.</p>
                </div>

                <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                    <a href="/register" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">Volver</a>
                    <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-400 sm:w-auto">Crear cuenta</button>
                </div>
            </form>
        </div>
    </div>
</AppLayout>
