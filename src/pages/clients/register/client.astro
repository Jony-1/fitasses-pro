---
import AppLayout from "../../../layouts/layout.astro";
import { sql } from "../../../lib/db/client";
import ClientFormFields from "../../../components/clients/ClientFormFields.astro";
import AuthNav from "../../../components/ui/AuthNav.astro";

const error = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
    missing_fields: "Completa todos los campos obligatorios.",
    invalid_name: "El nombre debe tener entre 3 y 120 caracteres.",
    invalid_email: "Ingresa un correo válido.",
    password_mismatch: "Las contraseñas no coinciden.",
    weak_password:
        "La contraseña debe tener al menos 8 caracteres, una mayúscula y un número.",
    email_exists: "Ese correo ya está registrado.",
    invalid_birth_date: "La fecha de nacimiento no es válida.",
    invalid_gender: "El género seleccionado no es válido.",
    invalid_height: "La altura ingresada no es válida.",
    invalid_notes: "Las observaciones son demasiado largas.",
    invalid_trainer: "Debes seleccionar un trainer válido.",
    trainer_not_found: "El trainer seleccionado no existe.",
};

const errorMessage = error ? errorMessages[error] : null;

const trainers = JSON.parse(
    JSON.stringify(
        await sql`
    SELECT id, name, email
    FROM users
    WHERE role = 'trainer'
    ORDER BY name ASC, id ASC
        `,
    ),
) as { id: number; name: string; email: string }[];

const trainerOptions = trainers as unknown as {
    id: number;
    name: string;
    email: string;
}[];
---

<AppLayout title="Registro de cliente">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:py-10">
        <AuthNav
            items={[
                { href: "/login", label: "Iniciar sesión" },
                { href: "/register", label: "Registro" },
                { href: "/clients/register/client", label: "Cliente", active: true },
                { href: "/clients/register/trainer", label: "Trainer" },
                { href: "/clients/register/gym-manager", label: "Gym manager" },
            ]}
        />

        <div class="mb-6 text-center">
            <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">
                Crear cuenta de cliente
            </h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">
                Regístrate para consultar tu progreso, valoraciones e historial con tu trainer asignado.
            </p>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-900/95 sm:p-8">
            {
                errorMessage && (
                    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/30 dark:bg-red-500/10 dark:text-red-300">
                        {errorMessage}
                    </div>
                )
            }

            <form method="POST" action="/api/auth/register-client" class="space-y-6">
                <ClientFormFields showTrainerSelect={true} trainers={trainerOptions} />

                <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                    <div>
                        <label
                            for="email"
                            class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200"
                        >
                            Correo electrónico
                        </label>
                        <input
                            id="email"
                            name="email"
                            type="email"
                            required
                            maxlength="160"
                            autocomplete="email"
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
                            placeholder="ejemplo@correo.com"
                        />
                    </div>

                    <div>
                        <label
                            for="password"
                            class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200"
                        >
                            Contraseña
                        </label>
                        <input
                            id="password"
                            name="password"
                            type="password"
                            required
                            minlength="8"
                            maxlength="72"
                            autocomplete="new-password"
                            pattern="^(?=.*[A-Z])(?=.*\d).{8,72}$"
                            title="Debe tener al menos 8 caracteres, una mayúscula y un número."
                            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
                            placeholder="Crea una contraseña con mayúscula y número"
                        />
                    </div>
                </div>

                <div>
                    <label
                        for="confirm_password"
                        class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-200"
                    >
                        Confirmar contraseña
                    </label>
                    <input
                        id="confirm_password"
                        name="confirm_password"
                        type="password"
                        required
                        minlength="8"
                        maxlength="72"
                        autocomplete="new-password"
                        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none focus:border-emerald-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
                        placeholder="Repite tu contraseña"
                    />
                </div>

                <div
                    class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-950/70 dark:text-slate-400"
                >
                    <p class="font-semibold text-slate-900 dark:text-slate-200">
                        Requisitos de la contraseña
                    </p>
                    <ul class="mt-2 space-y-1">
                        <li>• Mínimo 8 caracteres</li>
                        <li>• Al menos una mayúscula</li>
                        <li>• Al menos un número</li>
                    </ul>
                </div>

                <div class="flex flex-col-reverse gap-3 sm:flex-row sm:justify-end">
                    <a href="/register" class="inline-flex w-full items-center justify-center rounded-xl border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800 sm:w-auto">
                        Volver
                    </a>

                    <button
                        type="submit"
                        class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-5 py-3 text-sm font-bold text-white transition hover:bg-emerald-400 sm:w-auto"
                    >
                        Crear cuenta
                    </button>
                </div>

                <p
                    class="text-center text-sm text-slate-600 dark:text-slate-400"
                >
                    ¿Ya tienes cuenta?
                    <a
                        href="/login"
                        class="font-semibold text-emerald-600 hover:text-emerald-500 hover:underline dark:text-emerald-400 dark:hover:text-emerald-300"
                    >
                        Inicia sesión
                    </a>
                </p>
            </form>
        </div>
    </div>
</AppLayout>
