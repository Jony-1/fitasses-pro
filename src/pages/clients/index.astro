---
import AppLayout from "../../layouts/layout.astro";
import { sql } from "../../lib/db/client";
import { formatDateOnly } from "../../lib/utils/date";

const clients = await sql`
  SELECT id, full_name, birth_date, height_m, gender
  FROM clients
  ORDER BY id DESC
`;

function genderEmoji(gender: string | null) {
  const g = String(gender || "").toLowerCase();

  if (g === "hombre") return "👨";
  if (g === "mujer") return "👩";

  return "🧑";
}
---

<AppLayout title="Clientes">
    <div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8">
        <h1
            class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100"
        >
            Client Directory
        </h1>
        <p class="mt-2 max-w-2xl text-sm text-slate-600 dark:text-slate-400">
            Gestiona y consulta los clientes registrados.
        </p>

        <a
            href="/clients/new"
            class="inline-flex items-center justify-center rounded-xl bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-900 hover:bg-emerald-300 sm:w-auto mt-6"
        >
            + Nuevo cliente
        </a>
        <div class="mb-6 mt-6">
            <div class="relative">
                <span
                    class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"
                >
                    🔍
                </span>

                <input
                    id="client-search"
                    type="text"
                    placeholder="Buscar cliente..."
                    class="w-full rounded-xl border border-slate-300 bg-white px-10 py-3 text-sm
                focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200
                dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100"
                />
            </div>
        </div>

        <!-- MOBILE CARDS -->
        <div class="space-y-4 md:hidden mt-8">
            {
                clients.length === 0 ? (
                    <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-6 text-center text-slate-500 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400">
                        No hay clientes registrados todavía.
                    </div>
                ) : (
                    clients.map((client) => (
                        <a
                            href={`/clients/${client.id}`}
                            class="client-card block rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-emerald-300 hover:shadow dark:border-slate-700 dark:bg-slate-800 dark:hover:border-emerald-700"
                            data-name={client.full_name.toLowerCase()}
                            data-gender={client.gender?.toLowerCase() ?? ""}
                        >
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                                        Cliente #{client.id}
                                    </p>
                                    <p class="font-bold">
                                        {genderEmoji(client.gender)}{" "}
                                        {client.full_name}
                                    </p>
                                </div>
                                <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
                                    Ver
                                </span>
                            </div>
                            <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
                                <div class="rounded-xl bg-slate-50 p-3">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                                        Nacimiento
                                    </p>
                                    <p class="mt-1 font-medium text-slate-700">
                                        {formatDateOnly(client.birth_date)}
                                    </p>
                                </div>
                                <div class="rounded-xl bg-slate-50 p-3">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">
                                        Altura
                                    </p>
                                    <p class="mt-1 font-medium text-slate-700">
                                        {client.height_m
                                            ? `${client.height_m} m`
                                            : "-"}
                                    </p>
                                </div>
                            </div>
                        </a>
                    ))
                )
            }
        </div>

        <!-- DESKTOP TABLE -->
        <div
            class="hidden overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm md:block mt-8 dark:border-slate-700 dark:bg-slate-800"
        >
            {
                clients.length === 0 ? (
                    <div class="p-8 text-center text-slate-500">
                        No hay clientes registrados todavía.
                    </div>
                ) : (
                    <table class="min-w-full dark:text-slate-100">
                        <thead class="bg-slate-50 dark:bg-slate-800">
                            <tr class="text-left">
                                <th class="px-6 py-4 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                    ID
                                </th>
                                <th class="px-6 py-4 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                    Nombre
                                </th>
                                <th class="px-6 py-4 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                    Fecha nacimiento
                                </th>
                                <th class="px-6 py-4 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                    Altura
                                </th>
                                <th class="px-6 py-4 text-sm font-semibold text-slate-600 dark:text-slate-400">
                                    Acciones
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                            {clients.map((client) => (
                                <tr
                                    class="client-card hover:bg-slate-50 dark:hover:bg-slate-700"
                                    data-name={client.full_name.toLowerCase()}
                                    data-gender={
                                        client.gender?.toLowerCase() ?? ""
                                    }
                                >
                                    <td class="px-6 py-4 text-sm text-slate-700 dark:text-slate-100">
                                        {client.id}
                                    </td>
                                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-slate-100">
                                        {genderEmoji(client.gender)}{" "}
                                        {client.full_name}
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-700 dark:text-slate-100">
                                        {formatDateOnly(client.birth_date)}
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-700 dark:text-slate-100">
                                        {client.height_m
                                            ? `${client.height_m} m`
                                            : "-"}
                                    </td>
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-2">
                                            <a
                                                href={`/clients/${client.id}`}
                                                class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700"
                                            >
                                                Ver
                                            </a>
                                            <a
                                                href={`/clients/${client.id}/edit`}
                                                class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800 dark:bg-slate-700 dark:hover:bg-slate-600"
                                            >
                                                Editar
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                )
            }
        </div>
    </div>
    <script>
        const searchInput = document.getElementById("client-search");
        const clientCards = document.querySelectorAll(".client-card");

        searchInput?.addEventListener("input", () => {
            const term = searchInput.value.toLowerCase().trim();

            clientCards.forEach((client) => {
                const element = client;
                const name = element.dataset.name || "";
                const gender = element.dataset.gender || "";

                const matches = name.includes(term) || gender.includes(term);

                element.style.display = matches ? "" : "none";
            });
        });
    </script>
</AppLayout>
