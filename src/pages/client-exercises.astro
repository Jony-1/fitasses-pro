---
import AppLayout from "../layouts/layout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { exerciseLibrary, getExerciseLibraryItem } from "../lib/utils/exercise-library";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/login");
}

const search = Astro.url.searchParams.get("q")?.trim().toLowerCase() ?? "";
const category = Astro.url.searchParams.get("category") ?? "Todos";
const muscle = Astro.url.searchParams.get("muscle") ?? "Todos";
const equipment = Astro.url.searchParams.get("equipment") ?? "Todos";

const catalog = exerciseLibrary.filter((exercise) => {
  const matchesSearch = !search || `${exercise.name} ${exercise.category} ${exercise.muscle} ${exercise.equipment}`.toLowerCase().includes(search);
  const matchesCategory = category === "Todos" || exercise.category === category;
  const matchesMuscle = muscle === "Todos" || exercise.muscle === muscle;
  const matchesEquipment = equipment === "Todos" || exercise.equipment === equipment;

  return matchesSearch && matchesCategory && matchesMuscle && matchesEquipment;
});

const categories = ["Todos", ...new Set(exerciseLibrary.map((exercise) => exercise.category))];
const muscles = ["Todos", ...new Set(exerciseLibrary.map((exercise) => exercise.muscle))];
const equipments = ["Todos", ...new Set(exerciseLibrary.map((exercise) => exercise.equipment))];
---

<AppLayout title="Biblioteca de ejercicios">
  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Solo visual"
      title="Ejercicios / biblioteca"
      description="Consulta ejercicios, imágenes y guía rápida sin opciones de edición."
    >
      <a slot="actions" href="/dashboard" class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
        Volver
      </a>
    </SectionHeader>

    <form method="GET" class="grid gap-4 rounded-3xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900 sm:grid-cols-2 xl:grid-cols-4">
      <label class="space-y-2 sm:col-span-2 xl:col-span-1">
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Buscar</span>
        <input name="q" value={search} placeholder="Sentadilla, press..." class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100" />
      </label>

      <label class="space-y-2">
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Categoría</span>
        <select name="category" value={category} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100">
          {categories.map((item) => <option value={item}>{item}</option>)}
        </select>
      </label>

      <label class="space-y-2">
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Músculo</span>
        <select name="muscle" value={muscle} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100">
          {muscles.map((item) => <option value={item}>{item}</option>)}
        </select>
      </label>

      <label class="space-y-2">
        <span class="text-sm font-semibold text-slate-700 dark:text-slate-200">Equipo</span>
        <select name="equipment" value={equipment} class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100">
          {equipments.map((item) => <option value={item}>{item}</option>)}
        </select>
      </label>

      <div class="sm:col-span-2 xl:col-span-4 flex flex-wrap gap-3">
        <button type="submit" class="rounded-xl bg-emerald-400 px-4 py-2.5 text-sm font-bold text-slate-900 hover:bg-emerald-300">
          Aplicar filtros
        </button>
        <a href="/client-exercises" class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
          Limpiar
        </a>
      </div>
    </form>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      {catalog.map((exercise) => {
        const libraryItem = getExerciseLibraryItem(exercise.key);

        return (
          <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <div class="h-2 w-full" style={`background:${exercise.accent}`}></div>
            <img src={libraryItem?.image ?? exercise.image} alt={exercise.name} onerror="this.onerror=null;this.src='/favicon.png';" class="h-52 w-full object-cover" />
            <div class="p-5">
              <div class="flex flex-wrap gap-2 text-[11px] font-semibold text-slate-500 dark:text-slate-400">
                <span class="rounded-full bg-slate-100 px-2.5 py-1 dark:bg-slate-800">{exercise.category}</span>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 dark:bg-slate-800">{exercise.muscle}</span>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 dark:bg-slate-800">{exercise.equipment}</span>
              </div>

              <h2 class="mt-3 text-xl font-bold text-slate-900 dark:text-slate-100">{exercise.name}</h2>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{exercise.source === "custom" ? "Personalizado" : "Biblioteca base"}</p>

              <div class="mt-4 flex flex-wrap gap-3">
                <a href={`/exercises/${exercise.key}`} class="rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
                  Ver guía
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</AppLayout>
