---
import AppLayout from "../layouts/layout.astro";
import AuthNav from "../components/ui/AuthNav.astro";

const user = Astro.locals.user;

if (user) {
    return Astro.redirect(String(user.role) === "gym_manager" ? "/gym-manager" : "/dashboard");
}

const error = Astro.url.searchParams.get("error");

let errorMessage = "";

if (error === "missing_fields") {
    errorMessage = "Debes ingresar correo y contraseña.";
} else if (error === "invalid_credentials") {
    errorMessage = "Correo o contraseña incorrectos.";
} else if (error === "server_error") {
    errorMessage = "Ocurrió un error interno al iniciar sesión.";
} else if (error === "unauthorized") {
    errorMessage = "Debes iniciar sesión para continuar.";
} else if (error === "forbidden") {
    errorMessage = "No tienes permisos para acceder a esa sección.";
}
---

<AppLayout title="Iniciar sesión | FitAssess Pro">
    <div class="mx-auto max-w-md px-4 py-8 sm:py-10">
        <AuthNav
            items={[
                { href: "/login", label: "Iniciar sesión", active: true },
                { href: "/register", label: "Registro" },
            ]}
        />

        <div class="mb-6 text-center">
            <h1
                class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white"
            >
                Iniciar sesión
            </h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                Accede como cliente, trainer, gym manager o administrador.
            </p>
        </div>

        {
            errorMessage && (
                <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800 shadow-sm dark:border-red-900 dark:bg-red-950/30 dark:text-red-300">
                    {errorMessage}
                </div>
            )
        }

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-900/95 sm:p-8">
            <div class="mb-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-950/60 dark:text-slate-400">
                <p class="font-semibold text-slate-900 dark:text-slate-200">Acceso según tu rol</p>
                <p class="mt-1">Los gym managers entran a su panel del gimnasio, los trainers a sus clientes y los administradores al panel general.</p>
            </div>

            <form action="/api/auth/login" method="POST" class="space-y-5">
                <div>
                    <label
                        for="email"
                        class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
                    >
                        Correo electrónico
                    </label>
                    <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        autocomplete="email"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-emerald-500 dark:focus:ring-emerald-900/40"
                        placeholder="ejemplo@correo.com"
                    />
                </div>

                <div>
                    <label
                        for="password"
                        class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
                    >
                        Contraseña
                    </label>
                    <input
                        id="password"
                        name="password"
                        type="password"
                        required
                        autocomplete="current-password"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200 dark:border-slate-700 dark:bg-slate-950 dark:text-white dark:focus:border-emerald-500 dark:focus:ring-emerald-900/40"
                        placeholder="Ingresa tu contraseña"
                    />
                </div>

                <button
                    type="submit"
                    class="inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-600"
                >
                    Entrar
                </button>
            </form>
            <p class="mt-4 text-center text-sm text-slate-400">
                ¿No tienes cuenta?
                <a
                    href="/register"
                    class="font-semibold text-emerald-400 hover:text-emerald-300 hover:underline"
                >
                    Regístrate aquí
                </a>
            </p>
        </div>
    </div>
</AppLayout>
