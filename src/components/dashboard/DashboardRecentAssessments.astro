---
import { formatDateOnly, formatDateTimeLocal } from "../../lib/utils/date";
import type { DashboardRecentAssessment } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardRecentAssessment[];
}

const { items } = Astro.props as Props;

function metric(value: unknown, suffix = "") {
    if (value === null || value === undefined || value === "") return "-";

    const num = Number(value);
    if (Number.isNaN(num)) return "-";

    return `${num.toFixed(2)}${suffix}`;
}
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4 flex items-center justify-between gap-3">
        <div>
            <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Actividad reciente</h2>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Últimas valoraciones registradas.</p>
        </div>
    </div>

    {items.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-slate-300 px-4 py-5 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
            Aún no hay actividad reciente.
        </div>
    ) : (
        <div class="space-y-3">
            {items.map((item) => (
                <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-950/40">
                    <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <p class="text-sm font-semibold text-slate-500 dark:text-slate-400">{item.client_name}</p>
                            <h3 class="mt-1 text-base font-bold text-slate-900 dark:text-slate-100">
                                {formatDateOnly(item.assessment_date)}
                            </h3>
                            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                                Creada {formatDateTimeLocal(item.created_at)}
                            </p>
                        </div>

                        <div class="flex flex-wrap gap-2">
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-900 dark:text-slate-300">Peso {metric(item.weight_kg, " kg")}</span>
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-900 dark:text-slate-300">Grasa {metric(item.body_fat_pct, " %")}</span>
                            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-900 dark:text-slate-300">Músculo {metric(item.muscle_pct, " %")}</span>
                            <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">IMC {metric(item.bmi)}</span>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    )}
</section>
