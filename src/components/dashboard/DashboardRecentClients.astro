---
import { formatDateTimeLocal } from "../../lib/utils/date";
import type { DashboardRecentClient } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardRecentClient[];
}

const { items } = Astro.props as Props;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Clientes recientes</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Altas más recientes dentro de tu alcance.</p>
    </div>

    {items.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-slate-300 px-4 py-5 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
            Aún no hay clientes recientes.
        </div>
    ) : (
        <div class="space-y-3">
            {items.map((item) => (
                <article class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between dark:border-slate-800 dark:bg-slate-950/40">
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-slate-100">{item.full_name}</h3>
                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                            Creado {formatDateTimeLocal(item.created_at)}
                        </p>
                    </div>

                    <span class={`rounded-full px-3 py-1 text-xs font-semibold ${item.active ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300" : "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-300"}`}>
                        {item.active ? "Activo" : "Inactivo"}
                    </span>
                </article>
            ))}
        </div>
    )}
</section>
