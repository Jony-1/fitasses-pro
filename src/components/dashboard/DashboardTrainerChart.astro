---
import type { DashboardTrainerClientCount } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardTrainerClientCount[];
    title?: string;
    description?: string;
}

const { items, title = "Clientes por entrenador", description = "Distribución de clientes asignados a cada entrenador del gimnasio." } = Astro.props as Props;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-6">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">{title}</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{description}</p>
    </div>

    {items.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">Aún no hay entrenadores con clientes asignados.</p>
    ) : (
        <div class="space-y-4">
            {items.map((item) => {
                const maxClients = Math.max(...items.map(i => i.clientCount), 1);
                const percentage = maxClients > 0 ? (item.clientCount / maxClients) * 100 : 0;
                
                return (
                    <div key={item.trainerId}>
                        <div class="flex items-center justify-between text-sm">
                            <span class="font-medium text-slate-900 dark:text-slate-100">{item.trainerName}</span>
                            <span class="font-semibold text-emerald-600 dark:text-emerald-400">{item.clientCount} cliente{item.clientCount !== 1 ? 's' : ''}</span>
                        </div>
                        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-slate-200 dark:bg-slate-700">
                            <div 
                                class="h-full rounded-full bg-emerald-500 transition-all duration-500"
                                style={`width: ${percentage}%;`}
                            />
                        </div>
                    </div>
                );
            })}
        </div>
    )}
</section>