---
import { formatDateOnly } from "../../lib/utils/date";
import type { DashboardRiskClient } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardRiskClient[];
}

const { items } = Astro.props as Props;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Clientes en riesgo</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Clientes sin seguimiento en los últimos 30 días o sin valoración previa.</p>
    </div>

    {items.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-slate-300 px-4 py-5 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
            No hay clientes en riesgo por ahora.
        </div>
    ) : (
        <div class="space-y-3">
            {items.map((item) => (
                <article class="flex flex-col gap-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between dark:border-amber-900/40 dark:bg-amber-950/20">
                    <div>
                        <h3 class="font-semibold text-slate-900 dark:text-slate-100">{item.full_name}</h3>
                        <p class="mt-1 text-xs text-slate-600 dark:text-slate-300">
                            {item.last_assessment_date
                                ? `Última valoración: ${formatDateOnly(item.last_assessment_date)}`
                                : "Sin valoraciones registradas"}
                        </p>
                    </div>

                    <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-slate-900 dark:text-amber-300">
                        {item.days_since_last_assessment === null
                            ? "Sin historial"
                            : `${item.days_since_last_assessment} días`}
                    </span>
                </article>
            ))}
        </div>
    )}
</section>
