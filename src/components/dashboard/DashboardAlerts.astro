---
import type { DashboardAlert } from "../../lib/utils/dashboard";

interface Props {
    alerts: DashboardAlert[];
}

const { alerts } = Astro.props as Props;

const toneClasses = {
    warning:
        "border-amber-200 bg-amber-50 text-amber-800 dark:border-amber-900/40 dark:bg-amber-950/30 dark:text-amber-200",
    info:
        "border-sky-200 bg-sky-50 text-sky-800 dark:border-sky-900/40 dark:bg-sky-950/30 dark:text-sky-200",
    success:
        "border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-200",
} as const;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Alertas</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Puntos de atención para revisar el seguimiento.</p>
    </div>

    {alerts.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-slate-300 px-4 py-5 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
            Sin alertas por ahora.
        </div>
    ) : (
        <div class="space-y-3">
            {alerts.map((alert) => (
                <a
                    href={alert.href ?? "#"}
                    class={`block rounded-2xl border px-4 py-4 transition hover:-translate-y-0.5 ${toneClasses[alert.tone]}`}
                >
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <h3 class="font-semibold">{alert.title}</h3>
                            <p class="mt-1 text-sm opacity-90">{alert.description}</p>
                        </div>
                        <span class="text-sm font-semibold">→</span>
                    </div>
                </a>
            ))}
        </div>
    )}
</section>
