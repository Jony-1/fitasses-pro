---
import type { DashboardAttendanceSummary } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardAttendanceSummary[];
}

const { items } = Astro.props as Props;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Asistencias por horario</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Confirmaciones del mes para facilitar la lectura del entrenador.</p>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
            <thead class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
                <tr>
                    <th class="py-2 pr-4 font-semibold">Horario</th>
                    <th class="py-2 pr-4 font-semibold">Total</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                {items.map((item) => (
                    <tr>
                        <td class="py-3 pr-4 font-medium text-slate-900 dark:text-slate-100">{item.label}</td>
                        <td class="py-3 pr-4 text-slate-600 dark:text-slate-300">{item.count}</td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
</section>
