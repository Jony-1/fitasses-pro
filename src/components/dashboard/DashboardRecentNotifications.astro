---
import type { DashboardNotification } from "../../lib/utils/dashboard";

interface Props {
    items: DashboardNotification[];
}

const { items } = Astro.props as Props;

const toneClasses = {
    warning: "border-amber-200 bg-amber-50 text-amber-800 dark:border-amber-900/40 dark:bg-amber-950/30 dark:text-amber-200",
    info: "border-sky-200 bg-sky-50 text-sky-800 dark:border-sky-900/40 dark:bg-sky-950/30 dark:text-sky-200",
    success: "border-emerald-200 bg-emerald-50 text-emerald-800 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-200",
} as const;
---

<section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="mb-4">
        <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100">Notificaciones recientes</h2>
        <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">Avisos de asistencia enviados al entrenador.</p>
    </div>

    {items.length === 0 ? (
        <div class="rounded-2xl border border-dashed border-slate-300 px-4 py-5 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
            Sin notificaciones por ahora.
        </div>
    ) : (
    <div class="space-y-3">
            {items.map((item) => (
                <a href={item.href ?? "#"} class={`block rounded-2xl border px-4 py-4 transition hover:-translate-y-0.5 ${toneClasses[item.tone]}`}>
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <h3 class="font-semibold">{item.title}</h3>
                            <p class="mt-1 text-sm opacity-90">{item.description}</p>
                        </div>
                        <span class="text-sm font-semibold">→</span>
                    </div>
                </a>
            ))}
        </div>
    )}
</section>
