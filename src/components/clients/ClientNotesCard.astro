---
interface Props {
  notes: string | null;
}

const { notes } = Astro.props;
---

<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950/80">
  <div class="mb-4 flex items-start justify-between gap-3">
    <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100">Observaciones generales</h2>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 dark:bg-slate-800 dark:text-slate-400">cliente</span>
  </div>

  <div class="rounded-lg border border-slate-100 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900/70">
    {notes ? (
      <p class="leading-7 text-slate-700 dark:text-slate-200">{notes}</p>
    ) : (
      <p class="text-slate-500 dark:text-slate-400">Este cliente no tiene observaciones registradas todavía.</p>
    )}
  </div>
</div>
