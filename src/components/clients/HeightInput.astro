---
interface Props {
    name?: string;
    label?: string;
    placeholder?: string;
    min?: number;
    max?: number;
    value?: string;
}

const {
    name = "height_m",
    label = "Altura (m)",
    placeholder = "Ej. 1.70",
    min = 0.5,
    max = 2.5,
    value = "",
} = Astro.props;

const uid = `height-${Math.random().toString(36).slice(2, 10)}`;
---

<div
    class="height-input-component"
    data-min={min}
    data-max={max}
    data-initial={value}
>
    <label
        for={`${uid}-display`}
        class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
    >
        {label}
    </label>

    <div class="relative">
        <input
            id={`${uid}-display`}
            type="text"
            inputmode="decimal"
            value={value}
            placeholder={placeholder}
            maxlength="5"
            class="height-display w-full rounded-xl border border-slate-300 bg-white px-4 py-3 pr-10 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:ring-emerald-500/10"
            autocomplete="off"
        />

        <span
            class="height-status absolute right-3 top-1/2 -translate-y-1/2 text-sm text-slate-400 dark:text-slate-500"
        >
            m
        </span>
    </div>

    <input type="hidden" name={name} value="" class="height-hidden" />

    <p class="height-message mt-2 text-xs text-slate-500 dark:text-slate-400">
        Entre {min.toFixed(2)} m y {max.toFixed(2)} m — coma o punto aceptados
    </p>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        function setupHeightInput(root) {
            const min = Number(root.dataset.min || 0.5);
            const max = Number(root.dataset.max || 2.5);
            const isDark = document.documentElement.classList.contains("dark");

            const displayInput = root.querySelector(".height-display");
            const hiddenInput = root.querySelector(".height-hidden");
            const message = root.querySelector(".height-message");
            const status = root.querySelector(".height-status");

            if (!displayInput || !hiddenInput || !message || !status) return;

            const display = displayInput;
            const hidden = hiddenInput;
            const messageEl = message;
            const statusEl = status;

            function renderState(rawValue) {
                let raw = rawValue;

                raw = raw.replace(/[^0-9.,]/g, "");
                raw = raw.replace(",", ".");

                const parts = raw.split(".");
                if (parts.length > 2) {
                    raw = parts[0] + "." + parts.slice(1).join("");
                }

                if (!raw.includes(".") && raw.length >= 2) {
                    raw = raw[0] + "." + raw.slice(1);
                }

                if (raw.includes(".")) {
                    const [int, dec] = raw.split(".");
                    if (dec && dec.length > 2) {
                        raw = int + "." + dec.slice(0, 2);
                    }
                }

                display.value = raw;

                const num = parseFloat(raw);

                if (raw === "" || raw === ".") {
                    display.style.borderColor = "#d1d5db";
                    hidden.value = "";
                    messageEl.textContent = `Entre ${min.toFixed(2)} m y ${max.toFixed(2)} m — coma o punto aceptados`;
                    messageEl.className =
                        "height-message mt-2 text-xs text-slate-400";
                    statusEl.textContent = "m";
                    statusEl.style.color = "#94a3b8";
                    return;
                }

                if (Number.isNaN(num)) {
                    display.style.borderColor = "#ef4444";
                    hidden.value = "";
                    messageEl.textContent = "Valor inválido";
                    messageEl.className = "height-message mt-2 text-xs text-red-500";
                    statusEl.textContent = "✕";
                    statusEl.style.color = "#ef4444";
                    return;
                }

                if (num < min) {
                    display.style.borderColor = "#ef4444";
                    hidden.value = "";
                    messageEl.textContent = `Mínimo ${min.toFixed(2)} m`;
                    messageEl.className = "height-message mt-2 text-xs text-red-500";
                    statusEl.textContent = "✕";
                    statusEl.style.color = "#ef4444";
                    return;
                }

                if (num > max) {
                    display.style.borderColor = "#ef4444";
                    hidden.value = "";
                    messageEl.textContent = `Máximo ${max.toFixed(2)} m`;
                    messageEl.className = "height-message mt-2 text-xs text-red-500";
                    statusEl.textContent = "✕";
                    statusEl.style.color = "#ef4444";
                    return;
                }

                const normalized = num.toFixed(2);

                display.style.borderColor = "#22c55e";
                hidden.value = normalized;
                messageEl.textContent = `${normalized} m registrado ✓`;
                messageEl.className = "height-message mt-2 text-xs text-emerald-600";
                statusEl.textContent = "✓";
                statusEl.style.color = "#22c55e";
            }

            display.addEventListener("input", (e) => {
                const target = e.target;
                renderState(target?.value ?? "");
            });

            display.addEventListener("keydown", (e) => {
                if (e.key === ",") {
                    e.preventDefault();

                    const value = display.value;
                    if (!value.includes(".")) {
                        const newValue = value + ".";
                        renderState(newValue);

                        requestAnimationFrame(() => {
                            const pos = display.value.length;
                            display.setSelectionRange(pos, pos);
                        });
                    }
                }
            });

            renderState(display.value || "");
        }

        document
            .querySelectorAll(".height-input-component")
            .forEach(setupHeightInput);
    });
</script>
