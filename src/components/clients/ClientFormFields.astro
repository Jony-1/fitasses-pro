---
import HeightInput from "../HeightInput.astro";
import GenderSelector from "./GenderSelector.astro";

type TrainerOption = {
    id: number;
    name: string;
    email: string;
};

interface Props {
    showTrainerSelect?: boolean;
    trainers?: Array<{
        id: number;
        name: string;
        email: string;
    }>;
    values?: {
        trainer_id?: number | string | null;
        full_name?: string;
        birth_date?: string;
        gender?: string;
        height_m?: string | number | null;
        notes?: string;
    };
}

const { showTrainerSelect = false, trainers = [], values = {} } = Astro.props;
---

{
    showTrainerSelect && (
        <div>
            <label
                for="trainer_id"
                class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
            >
                Entrenador asignado
            </label>
            <select
                id="trainer_id"
                name="trainer_id"
                required
                class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10"
            >
                <option value="">Selecciona un entrenador</option>
                {trainers.map((trainer) => (
                    <option
                        value={trainer.id}
                        selected={
                            String(values.trainer_id ?? "") ===
                            String(trainer.id)
                        }
                    >
                        {trainer.name} ({trainer.email})
                    </option>
                ))}
            </select>
        </div>
    )
}

<div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <div>
        <label
            for="full_name"
            class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
        >
            Nombre completo
        </label>
        <input
            id="full_name"
            name="full_name"
            type="text"
            required
            value={values.full_name ?? ""}
            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:placeholder:text-slate-500 dark:focus:ring-emerald-500/10"
            placeholder="Ej. Juan Rincón"
        />
    </div>

    <div>
        <label
            for="birth_date"
            class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300"
        >
            Fecha de nacimiento
        </label>
        <input
            id="birth_date"
            name="birth_date"
            type="date"
            value={values.birth_date ?? ""}
            class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10"
        />
    </div>

    <div class="md:col-span-2">
        <GenderSelector value={values.gender ?? null} />
    </div>

    <div>
    <HeightInput
        name="height_m"
        label="Altura (m)"
        value={String(values.height_m ?? "")}
    />
</div>
</div>

<div>
    <label for="notes" class="mb-2 block text-sm font-semibold text-slate-700 dark:text-slate-300">
        Observaciones generales
    </label>
    <textarea
        id="notes"
        name="notes"
        rows="4"
        class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 outline-none transition focus:border-emerald-400 focus:ring-4 focus:ring-emerald-100 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:focus:ring-emerald-500/10"
        placeholder="Ej. Molestias, restricciones, notas iniciales..."
    >{values.notes ?? ""}</textarea>
</div>
