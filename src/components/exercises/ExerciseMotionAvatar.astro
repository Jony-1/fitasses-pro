<style>
  .motion-avatar {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 1.75rem;
    background: linear-gradient(145deg, color-mix(in srgb, var(--accent) 88%, white 12%), #0f172a 72%);
    box-shadow: 0 24px 50px rgba(2, 6, 23, 0.24);
  }

  .motion-avatar__svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .motion-avatar__pose {
    transform-box: fill-box;
    transform-origin: center;
    animation: drift 3.8s ease-in-out infinite;
  }

  .motion-avatar--squat .motion-avatar__pose--squat,
  .motion-avatar--press .motion-avatar__pose--press,
  .motion-avatar--bench .motion-avatar__pose--bench,
  .motion-avatar--row .motion-avatar__pose--row,
  .motion-avatar--hang .motion-avatar__pose--hang,
  .motion-avatar--hinge .motion-avatar__pose--hinge,
  .motion-avatar--bridge .motion-avatar__pose--bridge,
  .motion-avatar--lunge .motion-avatar__pose--lunge,
  .motion-avatar--plank .motion-avatar__pose--plank,
  .motion-avatar--twist .motion-avatar__pose--twist,
  .motion-avatar--jump .motion-avatar__pose--jump,
  .motion-avatar--mobility .motion-avatar__pose--mobility,
  .motion-avatar--raise .motion-avatar__pose--raise,
  .motion-avatar--swing .motion-avatar__pose--swing,
  .motion-avatar--default .motion-avatar__pose--default {
    animation-duration: 3s;
  }

  .motion-avatar--squat .motion-avatar__pose--squat { animation-name: squat; }
  .motion-avatar--press .motion-avatar__pose--press { animation-name: press; }
  .motion-avatar--bench .motion-avatar__pose--bench { animation-name: bench; }
  .motion-avatar--row .motion-avatar__pose--row { animation-name: row; }
  .motion-avatar--hang .motion-avatar__pose--hang { animation-name: hang; }
  .motion-avatar--hinge .motion-avatar__pose--hinge { animation-name: hinge; }
  .motion-avatar--bridge .motion-avatar__pose--bridge { animation-name: bridge; }
  .motion-avatar--lunge .motion-avatar__pose--lunge { animation-name: lunge; }
  .motion-avatar--plank .motion-avatar__pose--plank { animation-name: plank; }
  .motion-avatar--twist .motion-avatar__pose--twist { animation-name: twist; }
  .motion-avatar--jump .motion-avatar__pose--jump { animation-name: jump; }
  .motion-avatar--mobility .motion-avatar__pose--mobility { animation-name: mobility; }
  .motion-avatar--raise .motion-avatar__pose--raise { animation-name: raise; }
  .motion-avatar--swing .motion-avatar__pose--swing { animation-name: swing; }

  @keyframes drift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }

  @keyframes squat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(10px) scale(0.985); }
  }

  @keyframes press {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes bench {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @keyframes row {
    0%, 100% { transform: translateY(0) rotate(-2deg); }
    50% { transform: translateY(4px) rotate(2deg); }
  }

  @keyframes hang {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  @keyframes hinge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  @keyframes bridge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes lunge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  @keyframes plank {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  @keyframes twist {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(6deg); }
  }

  @keyframes jump {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes mobility {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(3deg); }
  }

  @keyframes raise {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @keyframes swing {
    0%, 100% { transform: translateY(0) rotate(-1deg); }
    50% { transform: translateY(5px) rotate(1deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-avatar__pose { animation: none !important; }
  }
</style>
