---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
  <div>
    {eyebrow && (
      <p class="text-xs font-bold uppercase tracking-[0.18em] text-emerald-600 dark:text-emerald-500">
        {eyebrow}
      </p>
    )}
    <h1 class="mt-1.5 text-2xl font-black tracking-tight text-slate-900 dark:text-slate-50 sm:text-3xl">
      {title}
    </h1>
    {description && (
      <p class="mt-2 max-w-2xl text-sm text-slate-500 dark:text-slate-400">
        {description}
      </p>
    )}
  </div>

  <div class="flex w-full shrink-0 flex-col gap-2 sm:w-auto sm:flex-row sm:flex-wrap">
    <slot name="actions" />
  </div>
</div>
