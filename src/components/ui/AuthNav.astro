---
interface Item {
    href: string;
    label: string;
    active?: boolean;
}

interface Props {
    items: Item[];
}

const { items } = Astro.props as Props;
const activeIndex = items.findIndex((item) => item.active);
---

<nav aria-label="Navegación de autenticación" class="mb-8 flex gap-2 overflow-x-auto rounded-2xl border border-slate-200 bg-white/80 p-2 shadow-sm backdrop-blur dark:border-slate-800 dark:bg-slate-900/70">
    {items.map((item, index) => (
        <a
            href={item.href}
            aria-current={index === activeIndex ? "page" : undefined}
            class:list={[
                "whitespace-nowrap rounded-xl px-4 py-2 text-sm font-semibold transition",
                index === activeIndex
                    ? "bg-emerald-500 text-white shadow-sm"
                    : "text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800",
            ]}
        >
            {item.label}
        </a>
    ))}
</nav>
