---
interface Props {
  label: string;
  value: string | number;
  valueClass?: string;
  note?: string;
  noteClass?: string;
  icon?: string;
  accent?: "emerald" | "violet" | "amber" | "sky" | "rose";
}

const {
  label,
  value,
  valueClass,
  note,
  noteClass,
  icon,
  accent = "emerald",
} = Astro.props;

const accentMap = {
  emerald: { top: "from-emerald-500 to-teal-400",  text: "text-emerald-600 dark:text-emerald-400",  bg: "bg-emerald-500/10 dark:bg-emerald-500/15" },
  violet:  { top: "from-violet-500 to-purple-400", text: "text-violet-600 dark:text-violet-400",    bg: "bg-violet-500/10 dark:bg-violet-500/15" },
  amber:   { top: "from-amber-500 to-yellow-400",  text: "text-amber-600 dark:text-amber-400",      bg: "bg-amber-500/10 dark:bg-amber-500/15" },
  sky:     { top: "from-sky-500 to-blue-400",      text: "text-sky-600 dark:text-sky-400",          bg: "bg-sky-500/10 dark:bg-sky-500/15" },
  rose:    { top: "from-rose-500 to-pink-400",     text: "text-rose-600 dark:text-rose-400",        bg: "bg-rose-500/10 dark:bg-rose-500/15" },
};

const a = accentMap[accent];
const finalValueClass = valueClass ?? `text-slate-900 dark:text-slate-50 font-black`;
---

<div class="relative overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm transition-shadow hover:shadow-md dark:border-white/[0.07] dark:bg-[#0f1629]">
  <!-- Top accent line -->
  <div class={`absolute left-0 right-0 top-0 h-0.5 bg-gradient-to-r ${a.top}`}></div>

  <div class="flex items-start justify-between gap-3">
    <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">{label}</p>
    {icon && (
      <span class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-xl text-base ${a.bg}`}>{icon}</span>
    )}
  </div>

  <p class={`mt-3 text-3xl sm:text-4xl ${finalValueClass}`}>{value}</p>
  {note && <p class={`mt-2 text-xs leading-5 ${noteClass ?? "text-slate-500 dark:text-slate-500"}`}>{note}</p>}
</div>
