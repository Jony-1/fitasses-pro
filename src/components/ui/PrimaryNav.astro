---
import type { NavItem } from "../../lib/utils/navigation";

interface Props {
  items: NavItem[];
  variant: "desktop" | "mobile";
}

const { items, variant } = Astro.props as Props;
---

<nav
  aria-label={variant === "desktop" ? "Navegación principal" : "Navegación móvil"}
  class:list={[
    variant === "desktop" ? "flex-1 space-y-2 p-4" : "flex gap-2 overflow-x-auto pb-1",
  ]}
>
  {
    items.map((item) => (
      <a
        href={item.href}
        aria-current={item.active ? "page" : undefined}
        class:list={
          variant === "desktop"
            ? [
                "flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium transition",
                item.active
                  ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"
                  : "text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800",
              ]
            : [
                "whitespace-nowrap rounded-xl px-3 py-2 text-sm font-semibold transition",
                item.active
                  ? "bg-emerald-50 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300"
                  : "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-200",
              ]
        }
      >
        <span class={variant === "desktop" ? "text-base" : "mr-1"}>{item.icon}</span>
        <span>{item.label}</span>
      </a>
    ))
  }
</nav>
