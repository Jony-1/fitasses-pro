---
interface Props {
  title: string;
  description: string;
  actionHref?: string;
  actionLabel?: string;
  icon?: string;
}

const { title, description, actionHref, actionLabel, icon = "📭" } = Astro.props;
---

<div class="flex flex-col items-center rounded-2xl border border-dashed border-slate-200 bg-slate-50/50 px-6 py-12 text-center dark:border-white/[0.07] dark:bg-white/[0.02]">
  <span class="text-4xl opacity-60">{icon}</span>
  <h2 class="mt-4 text-base font-bold text-slate-700 dark:text-slate-300">{title}</h2>
  <p class="mt-1.5 max-w-xs text-sm text-slate-400 dark:text-slate-500">{description}</p>

  {actionHref && actionLabel && (
    <a
      href={actionHref}
      class="mt-6 inline-flex items-center justify-center rounded-xl bg-emerald-500 px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-emerald-500/25 transition hover:bg-emerald-600 active:scale-[0.97]"
    >
      {actionLabel}
    </a>
  )}
</div>
