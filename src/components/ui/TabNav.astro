---
interface Item {
    href: string;
    label: string;
    active?: boolean;
}

interface Props {
    items: Item[];
}

const { items } = Astro.props as Props;
const activeIndex = items.findIndex((item) => item.active);
---

<nav class="flex gap-2 overflow-x-auto rounded-2xl p-1 sm:flex-wrap sm:overflow-visible">
    {items.map((item, index) => (
        <a
            href={item.href}
            class:list={[
                "whitespace-nowrap inline-flex items-center justify-center rounded-xl px-4 py-2.5 text-sm font-semibold transition",
                index === activeIndex
                    ? "bg-emerald-500 text-white shadow-lg shadow-emerald-500/20"
                    : "text-slate-300 hover:bg-white/10 hover:text-white dark:text-slate-300 dark:hover:bg-slate-800",
            ]}
        >
            {item.label}
        </a>
    ))}
</nav>
