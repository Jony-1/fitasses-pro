---
interface Item {
    href: string;
    label: string;
    active?: boolean;
}

interface Props {
    items: Item[];
}

const { items } = Astro.props as Props;
---

<nav class="mb-6 flex gap-2 overflow-x-auto rounded-2xl border border-slate-200 bg-white p-2 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    {items.map((item) => (
        <a
            href={item.href}
            class:list={[
                "whitespace-nowrap inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold transition",
                item.active
                    ? "bg-emerald-500 text-white shadow-sm"
                    : "text-slate-600 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800",
            ]}
        >
            {item.label}
        </a>
    ))}
</nav>
