---
import ExerciseCard from "../exercises/ExerciseCard.astro";
import type { RoutineDay } from "../../lib/utils/routines";

interface Props {
  day: RoutineDay;
  clientId?: number | null;
  showCompletion?: boolean;
}

const {
  day,
  clientId = null,
  showCompletion = false,
} = Astro.props as Props;
---

<section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-950/80">
  <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Día {day.day_number}</p>
      <h2 class="mt-1 text-xl font-bold text-slate-900 dark:text-slate-100">{day.title}</h2>
      {day.focus && <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{day.focus}</p>}
    </div>

    <div class="flex items-center gap-3">
      {day.completed_at ? (
        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300">
          Completado
        </span>
      ) : (
        <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-500/10 dark:text-amber-300">
          Pendiente
        </span>
      )}
    </div>
  </div>

  {day.notes && <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">{day.notes}</p>}

  <div class="mt-5 space-y-3">
    {day.exercises.map((exercise) => (
      <ExerciseCard exercise={exercise} detailsHref={`/exercises/${exercise.exercise_key ?? exercise.name}`} />
    ))}
  </div>

  {showCompletion && clientId && (
    <form method="POST" action="/api/routines/complete-day" class="mt-5 flex flex-wrap items-center gap-3">
      <input type="hidden" name="routine_day_id" value={day.id} />
      <input type="hidden" name="client_id" value={clientId} />
      <input
        name="notes"
        class="min-w-0 flex-1 rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-100"
        placeholder="Nota rápida del día"
      />
      <button
        type="submit"
        class:list={[
          "rounded-xl px-4 py-3 text-sm font-bold transition",
          day.completed_at
            ? "bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400"
            : "bg-emerald-400 text-slate-900 hover:bg-emerald-300 dark:bg-emerald-500 dark:text-slate-950 dark:hover:bg-emerald-400",
        ]}
      >
        {day.completed_at ? "Ya completado" : "Marcar completado"}
      </button>
    </form>
  )}
</section>
